      <constraints>
        <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="28b5-b99f-253c-cbab" type="max"/>
      </constraints>
      <rules>
        <rule id="50aa-6f5d-d8e0-15b3" name="Miembro de las Krak-Kalim" hidden="false">
          <description>Karra tiene la regla especial Culto de Koka-Kalim. Además, la unidad de Devotas de Koka-Kalim a la que se una Karra obtendrá la regla especial Esquivar (+5) por +2 puntos por miniatura. Este bonificador se mantiene aunque Karra sea retirada como baja. Sin embargo, la unidad no podrá incluir otros personajes ni tomar el Liderazgo de Madre Samantha para realizar sus chequeos. Adicionalmente, si incluyes esta Saga de Karra en tu lista de ejército, no podrás incluir unidades de Redimidas de Koka-Kalim.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="3933-c580-f298-1a81" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="2688-6b82-4a06-2e62" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Eslizones)"/>
          </modifiers>
        </infoLink>
        <infoLink id="ef1b-aebd-5e45-c2fe" name="Cruzar (bosques)" hidden="false" targetId="9d01-387d-269d-5a44" type="rule"/>
        <infoLink id="38f0-d4ee-8176-2faf" name="Culto de Koka-Kalim" hidden="false" targetId="1e5d-4d25-0303-76c4" type="rule"/>
        <infoLink id="fab1-a70e-01d9-658b" name="Inmune al miedo" hidden="false" targetId="9dea-6e2e-9d06-f5f7" type="rule"/>
      </infoLinks>
