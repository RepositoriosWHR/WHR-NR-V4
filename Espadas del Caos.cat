              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene la regla especial Aura demoníaca (5+, o +1 a su Aura demoníaca si ya disponía de una) y se verá afectado por todos aquellos hechizos o efectos que afecten a miniaturas con la regla especial Demonio.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d677-3d76-3517-82a8" name="Aura demoníaca (5+)" hidden="false" targetId="e5ed-5149-3d72-6aa4" type="rule"/>
