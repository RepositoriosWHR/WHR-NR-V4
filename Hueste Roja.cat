        <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="10bb-4758-3e4c-6dc4" type="max"/>
      </constraints>
      <rules>
        <rule id="ae45-fa17-6d58-0784" name="Nubarrón zumbante" hidden="false">
          <description>Todos los ataques y disparos dirigidos contra los Insectos de la Jungla que no cuenten con la regla especial Ataques flamígeros o Ataques solo flamígeros obtendrán un penalizador de -2 en sus tiradas para impactar. Además, los Insectos de la Jungla obtienen un bonificador de +1 en sus tiradas para impactar en combate contra las unidades que no sean de tipo Enjambre, que aumenta a +2 contra unidades con la regla especial Objetivo grande.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="d633-e520-8dfb-799e" name="Enjambre" hidden="false" targetId="d477-174e-9843-a1b7" type="rule"/>
        <infoLink id="2eac-7124-a08c-8fb5" name="Flotar (8)" hidden="false" targetId="7465-4e8e-6ec8-2a0f" type="rule"/>
