              <rules>
                <rule id="c005-0120-0352-1802" name="Marca de Khorne. Elegidos del Caos" hidden="false">
                  <description>Obtienen las reglas especiales Furia asesina y Resistencia mágica (2). Además, no perderán su Furia asesina aunque sean derrotados en combate.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="679e-1a8c-5c1f-c7fc" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
