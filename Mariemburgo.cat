      </constraints>
      <rules>
        <rule id="c456-b35a-70fc-dfb6" name="Odio (Pielesverdes y Skavens)" hidden="false">
          <description>Una miniatura que Odie podrá repetir los resultados de 1 obtenidos en sus tiradas para impactar en combate cuerpo a cuerpo contra aquellos a quienes odie.</description>
        </rule>
        <rule id="32df-3ef8-54ee-a6f7" name="Montaraces" hidden="false">
          <description>Los Montaraces ignoran la regla especial Mover o disparar de sus armas de proyectiles. Además, al inicio de la batalla, antes del despliegue, elige entre las reglas especiales Vanguardia o Exploradores: los Montaraces obtendrán esa regla especial.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="548c-7bb0-72af-0b60" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
