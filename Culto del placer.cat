    <selectionEntry id="09e3-4c25-3274-0f21" name="[E] - Netrak Grimbane, El primero de los Ungidos" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="32c4-70ff-588f-f74b" type="max"/>
      </constraints>
      <rules>
        <rule id="e936-810f-e5e2-9f25" name="Magia de Netrak Grimbane" hidden="false">
          <description>Se trata de un hechicero de nivel dos que elige sus hechizos de entre el Saber de Slaanesh.</description>
        </rule>
        <rule id="8303-9efc-f7af-3829" name="Icono de Slaanesh" hidden="false">
          <description>Un Ungido de Slaanesh tiene la regla especial Tozudez. Además, si el Ungido de Slaanesh es el General del ejército, todas las unidades con la clave CULTO DEL PLACER dentro del radio de su Presencia inspiradora serán Inmunes a Psicología.</description>
        </rule>
        <rule id="92de-484a-f5f1-ca28" name="Avatar de Slaanesh" hidden="false">
          <description>La tirada de salvación especial por aura demoníaca de Netrak también lo protege contra hechizos y armas mágicas. Además, tiene un bonificador de +1 al lanzar hechizps del saber de Slaanesh. Si Morathi no está presente en tu lista de ejército, Netrak debe ser el general del ejército.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="5bae-51da-c64f-6a9a" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="09e3-4c25-3274-0f21" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="eba7-e0cd-3901-1101" type="equalTo"/>
