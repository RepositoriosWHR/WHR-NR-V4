          <rules>
            <rule id="30a6-dacc-4fe1-8851" name="Casta de serpiente" hidden="false">
              <description>Puede pertenecer a una Casta serpiente al coste de puntos indicado y sólo podrá unirse a unidades pertenecientes a la misma casta:</description>
            </rule>
          </rules>
          <selectionEntries>
