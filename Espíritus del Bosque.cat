          </constraints>
          <profiles>
            <profile id="510f-9f4b-d4d6-f29c" name="Colonia de ujanos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Al inicio de la batalla, tras el despliegue, tira 1D3+1: ese será el número de tiradas que pueda repetir el personaje durante la partida. Puede tratarse de tiradas para impactar, para herir, salvaciones por armadura o especiales, chequeos de atributo (incluyendo de Liderazgo), tiradas de regeneración o dados de energía o dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
