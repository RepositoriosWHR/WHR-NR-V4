            <profile id="0194-f8c9-5390-2f94" name="Kaldero de nieblaz" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Objeto portahechizos, nivel de energía 3. Se trata de un hechizo de potenciación que toma como objetivo a una unidad amiga a 12” o menos del chamán, y permanece un turno. Por la duración del hechizo, otorga a la unidad la regla especial Veloces; todos los ataques de disparo y cuerpo a cuerpo contra la unidad tendrán un penalizador de -1 para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ee64-62dc-23fc-67c6" name="Baztón Kolmillo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6084-a1e2-9b79-ffe9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a073-a4b2-c27d-d49f" type="max"/>
          </constraints>
          <profiles>
            <profile id="afab-5b38-94cd-ffa2" name="Baztón Kolmillo" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El portador puede guardar un dado de magia no utilizado al final de cada fase de magia para utilizarlo en una fase posterior. Además, el portador tiene un bonificador de +1 en sus tiradas de lanzamiento de hechizos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9052-0e89-24da-1cd1" name="Mázkara de loz mil ojoz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e726-7b7d-dca3-ac4f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e16b-c893-c555-7b43" type="max"/>
          </constraints>
          <profiles>
            <profile id="8aed-54a0-fd01-b44d" name="Mázkara de loz mil ojoz" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Objeto portahechizos, nivel de energía 1D6. Contiene un hechizo de potenciación que afecta a todas las unidades amigas a 12” o menos del portador y permanece un turno. Por la duración del conjuro, las unidades afectadas podrán repetir sus tiradas para impactar fallidas con proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2bbf-7df8-3b37-53d2" name="Objetos hechizados. Goblins silvanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="914e-fa50-6e68-b604" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="27aa-49de-82d8-499c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="84cc-f9fb-d3be-117f" name="Veneno Matabeztiaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9ea5-91da-7853-efa9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7420-7dfc-548f-ed39" type="max"/>
          </constraints>
          <profiles>
            <profile id="2889-c69f-a438-3c40" name="Veneno Matabeztiaz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un sólo uso. Puede utilizarse al inicio de cualquier fase de disparo o de combate cuerpo a cuerpo, con un único disparo o un único ataque de combate cuerpo a cuerpo (tira con un dado de color diferente); ese disparo o ataque obtiene la regla especial Heridas múltiples (1D6); no afecta a miniaturas Inmunes a veneno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a676-8c47-c164-7389" name="Piedro de atraer flechaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5182-fb92-6abe-09fd" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cde3-1821-40fd-17de" type="max"/>
          </constraints>
          <profiles>
            <profile id="7cf8-4c53-4ab2-66d5" name="Piedro de atraer flezchaz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un sólo uso. Puede “arrojarse” sobre una unidad enemiga a 12” o menos (no es necesario efectuar tiradas) al inicio de cualquiera de tus fases de disparo. Durante ese turno, todos los disparos dirigidos contra la unidad podrán repetir todas sus tiradas fallidas para impactar. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f092-15a3-2174-eac4" name="Ojo de la araña" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5354-b388-e54d-e10c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="42a7-9f4e-fb37-c430" type="max"/>
          </constraints>
          <profiles>
            <profile id="1b3a-3d0f-01bb-82e9" name="Ojo de la araña" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Al inicio de cada uno de tus turnos, el portador puede recuperar una herida que hubiesen sufrido con anterioridad durante la batalla. Además, el portador obtiene la regla especial Regeneración (6+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="dcbe-eaa3-b7fa-d7d2" name="Regeneración (6+)" hidden="false" targetId="4aee-7485-a141-cd20" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="33cb-cf75-4805-05a4" name="Korona mágika" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d29f-d81a-2a51-20c2" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="bf43-8ec9-0b22-4efa" type="max"/>
          </constraints>
          <profiles>
            <profile id="cd5d-b655-e301-2b2f" name="Korona mágika" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un sólo uso. Puede activarse en cualquier momento de tu turno o el de tu oponente. Hasta el final del turno de jugador en que es activada, la Korona Mágika aumenta el liderazgo del portador hasta 10.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="957f-19f9-05f4-84a5" name="Kachivache Trukulento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="51ee-f88c-4ae5-de57" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3ff0-719d-9cbe-d660" type="max"/>
          </constraints>
          <profiles>
            <profile id="3cfa-e206-4529-84ca" name="Kachivache Trukulento" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Ni el portador ni ninguna miniatura (amiga o enemiga) en contacto peana con peana podrá efectuar tiradas de salvación especiales (excepto las de Esquivar, como es habitual). </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d4bc-1ee3-ee2e-b558" name="Pózima enmarañadora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="04b6-d11d-ca9d-db4f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ee42-925e-e5d0-6eef" type="max"/>
          </constraints>
          <profiles>
            <profile id="a24a-fa7d-727f-2bf7" name="Pózima enmarañadora" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo 3 usos. Puede utilizarse como un Arma de aliento (tanto en tu fase de disparo como para aguantar y disparar) de F1. Cualquier unidad impactada verá sus atributos de Iniciativa y Movimiento reducidos a la mitad (redondeando hacia arriba) y perderá la regla especial Veloz hasta el inicio de la siguiente fase de disparo de los goblins. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f182-8423-9f77-70ea" name="Arma de aliento" hidden="false" targetId="3438-0c27-972c-d418" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(F1)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ce00-da01-18e4-5874" name="Objetos hechizados. Goblins silvanos. Personajes con arco" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="679c-c103-b541-f920" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ad92-d324-fa0b-492a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2bfd-fd56-fc8e-757c" name="Zetaz venenozaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="b436-ae3f-5c54-a813" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="038d-4d92-1726-c9e2" type="max"/>
          </constraints>
          <profiles>
            <profile id="682c-04fb-8cd5-5475" name="Zetaz venenozaz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo personajes equipados con arco corto o arko de huezo. Los disparos realizados con su arco obtienen las reglas especiales Disparos múltiples (1D6), Ataques envenenados y Ataques mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4e65-130c-5a02-88eb" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="3f2f-bc11-20a7-d4cf" name="Ataques mágicos" hidden="false" targetId="7cc5-d3fc-a37a-3d4a" type="rule"/>
            <infoLink id="2b85-1248-c486-a7df" name="Disparos múltiples (1D6)" hidden="false" targetId="477b-5ffd-646c-e546" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="039a-1d9d-efb9-0dbd" name="Flechaz pinchadoraz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f0b9-26f0-81d0-e631" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2d9a-782d-b215-5db1" type="max"/>
          </constraints>
          <profiles>
            <profile id="2166-1bc2-8939-462f" name="Flechaz pinchadoraz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo personajes equipados con Arco corto o Arko de Huezo. Los disparos realizados con su arco se resuelven con +1 Fuerza y la regla especial Poder de penetración.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="80ac-0141-7888-ade1" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1aae-79ef-148d-9df6" name="Estandartes mágicos. Reliquias. Goblins silvanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fd31-aab9-5275-42f5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66f7-7497-d97c-254a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c922-2e6a-0b92-21f0" name="Bandera del Pozo Negro" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8fdc-8c35-f61c-99e9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5ffe-1bd4-9e39-0489" type="max"/>
          </constraints>
          <profiles>
            <profile id="d19e-7d6a-45d9-69c8" name="Bandera del Pozo Negro" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Todas las unidades amigas a 12” o menos del portador verán aumentada su tirada de salvación especial en +1 (máximo de 3+); si no disponían de tirada de salvación especial, obtendrán una tirada de salvación especial de 6+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="0e15-9260-3692-18c2" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="75.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0b22-be1e-eadc-70e4" name="Estandartes mágicos. Goblins silvanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4fea-f687-498a-51fe" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f22a-3559-8985-3734" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9eba-c897-b67c-f344" name="Eztandarte de la zaetaz" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5579-3dd0-6e50-b9c8" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7c72-6e8d-a00f-db07" type="max"/>
          </constraints>
          <profiles>
            <profile id="b459-9561-78ac-be32" name="Eztandarte de laz zaetaz" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtienen la regla especial Disparos múltiples (2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e912-bf0b-82de-922e" name="Disparos múltiples (2)" hidden="false" targetId="f150-3b7d-99ed-c809" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a11b-106c-b1e3-7461" name="Eztandarte burlón" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="bf96-6e8e-66bc-084e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e856-4946-fcb8-14cd" type="max"/>
          </constraints>
          <profiles>
            <profile id="dfb8-6b43-5cfb-3d44" name="Eztandarte burlón" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Al inicio de cada turno enemigo, todas las unidades enemigas que puedan cargar contra la unidad que porte este estandarte deberán hacerlo, a menos que superen un chequeo de Liderazgo. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5e0a-e22a-c811-de77" name="Eztandarte aráknido" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ed13-c1e5-76f5-bcb5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1d91-dec5-647c-1be7" type="max"/>
          </constraints>
          <profiles>
            <profile id="869b-85e8-af02-4fda" name="Eztandarte aráknido" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Todos los goblins silvanos de la unidad (y sus monturas) obtienen la regla especial Ataques envenenados. Si ya tenían esa regla, estos surtirán efecto con un resultado de 5+ en lugar del habitual 6. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d49f-7d81-1bb6-fe7f" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="230b-cd2b-8559-e27f" name="Banderola de loz kolmilloz" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7fca-7673-a6f9-5412" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6d68-78d5-4050-79c2" type="max"/>
          </constraints>
          <profiles>
            <profile id="13f4-5537-bc6f-e3fe" name="Banderola de loz kolmilloz" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad aumentan en 6” el alcance de todos sus arcos (de cualquier tipo); además, no aplicarán penalizador por larga distancia al disparar por sus arcos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7a7f-2e36-cc5d-c541" name="Eztandarte del ojo maliziozo" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="cc33-03a0-6a41-afc3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e8c8-bd22-5e40-a59a" type="max"/>
          </constraints>
          <profiles>
            <profile id="310b-ef1b-1adc-9016" name="Eztandarte del ojo maliziozo" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Todas las miniaturas de la unidad obtienen un bonificador de +1 en sus tiradas para impactar con proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0e0a-1f26-639c-6e19" name="Banderola del cháman" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="043f-2ec3-4c6f-a064" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6cb3-a229-0421-89f2" type="max"/>
          </constraints>
          <profiles>
            <profile id="7818-1152-2b8d-f21e" name="Banderola del cháman" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Al inicio de cada fase de magia tira 1D6, sumando 1 al resultado por cada otra unidad con la clave orcos o goblins a 12” del portador del estandarte con potencia de unidad de 10 o superior y que no esté huyendo: si el resultado final es de 5 ó superior, el estandarte genera un dado de energía o dispersión para esa fase de magia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f1f1-f3b4-83c2-a5c4" name="Talismanes mágicos. Goblins silvanos. Chamanes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0a52-d294-9a8d-d85d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2f27-de39-40c0-9817" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="befb-967e-6898-6560" name="Kareto de la Zuerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e3fd-cdcf-27d8-5ff3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="aac0-4a15-c936-5bb3" type="max"/>
          </constraints>
          <profiles>
            <profile id="2794-2519-2bc7-272f" name="Kareto de la Zuerte" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Sólo chamanes. El portador podrá repetir sus tiradas de salvación especial fallidas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="82d4-7433-3d95-5c87" name="Zenderoz. Chamán y Gran Chamán" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f2c9-6cd2-bc9b-1c31" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4026-b313-19b8-1049" name="Zendero de la Gran Araña" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2145-a9c5-e74a-cd33" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8427-936f-5b8b-96b5" type="max"/>
          </constraints>
          <profiles>
            <profile id="a892-42e3-0d26-3cdc" name="Zendero de la Gran Araña" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo chamán o gran chamán montado en Aracnarock. Una vez por fase de magia el chamán puede repetir la tirada de uno de sus dados de energía al lanzar un hechizo, o uno de sus dados de dispersión al dispersar un hechizo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8c8a-d1cf-91c7-9bb0" name="New SelectionEntry" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ceb7-6693-c9a8-93c1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="981f-4ce6-94dd-bd84" type="max"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8fc6-8526-5915-f19e" name="Zendero del Kulto" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2168-b030-54a9-0c17" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9304-8578-47d2-6fca" type="max"/>
          </constraints>
          <profiles>
            <profile id="4517-0f89-7767-43cb" name="Zendero del Kulto" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Chamán o Gran chamán. El personaje no puede elegir ninguna montura y sólo podrá unirse a unidades del Kulto de la Araña. El personaje obtiene la regla especial Inmune a Miedo, y conocerá un hechizo adicional.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bafb-d940-cb1d-acfe" name="Inmune al miedo" hidden="false" targetId="9dea-6e2e-9d06-f5f7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b8c6-c7db-b53f-69ee" name="Zendero del Bozke Zinieztro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6b42-a093-891e-efed" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a7f1-2884-af81-9c6f" type="max"/>
          </constraints>
          <profiles>
            <profile id="190c-30a0-c6c5-3c45" name="Zendero del Bozke Zinieztro" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo chamán o gran chamán. El hechicero puede tirar un dado adicional para Canalizar si se encuentra a 12” o menos de un bosque. Además, al inicio de cada uno de sus turnos, puede elegir un elemento de escenografía en el campo de batalla que no sea un Edificio: hasta el inicio de tu siguiente turno, dicho elemento de escenografía se considera Terreno peligroso para todas las unidades que no tengan la clave GOBLINS SILVANOS.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c299-cf6b-bdc6-dd8e" name="Zenderoz. Kaudillo o Gran jefe. Araña gigantesca" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c05f-f868-d4b9-172f" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7f53-958e-7e78-2ea2" name="Zendero Zagrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c9bf-b206-e869-3e7c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b301-d132-4676-e1ea" type="max"/>
          </constraints>
          <profiles>
            <profile id="c68c-d89d-f60f-7293" name="Zendero Zagrado" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe montado en Araña gigantesca. El personaje sólo puede unirse a unidades de Guerreroz Zagradoz. El personaje y su unidad causarán Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2f9f-93bb-91ef-a31f" name="Terror" hidden="false" targetId="ca57-1f1f-8bc0-d9ab" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1238-387e-08a4-a579" name="Zenderoz. Kaudillo o Gran jefe. Sin montura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4c30-63e9-202c-8ae8" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="85ea-3f3b-b6cf-dd5f" name="Zendero de la ezpezura" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7dfa-e94c-1858-a730" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4a26-ebdb-66b9-2693" type="max"/>
          </constraints>
          <profiles>
            <profile id="0ecf-d460-a256-fdbf" name="Zendero de la ezpezura" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe. El personaje no puede elegir ninguna montura, y sólo puede unirse a unidades de Ezploradorez. El personaje obtiene un bonificador de +1 a su atributo de Habilidad de Proyectiles y las reglas especiales Inmune a pánico, Explorador, Disparo rápido y Francotirador, así como la regla especial Okultoz (ver Ezploradorez).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="9b9c-555b-38ea-f9ef" name="Okultoz" hidden="false">
              <description>Todos los disparos contra los exploradorez deben resolverse con un penalizdor de -1 en sus tiradas para impactar. Además, los ezploradorez tienen la regla especial Esquivar (5+), que se incrementa a 4+ si la unidad se encuentra mayoritariamente dentro de un bosque.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="7cd8-c082-ebae-c999" name="Inmune al pánico" hidden="false" targetId="06f4-bd6a-c34d-baed" type="rule"/>
            <infoLink id="d922-66c6-1d80-735b" name="Exploradores" hidden="false" targetId="462e-27b4-5c07-747d" type="rule"/>
            <infoLink id="c6fd-8115-b321-8dbd" name="Disparo rápido" hidden="false" targetId="e198-cb4f-6dfc-1dcc" type="rule"/>
            <infoLink id="df3c-b4f1-6e81-d5e8" name="Francotirador" hidden="false" targetId="8fa0-a4f6-e454-dbfe" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="797f-b23c-fcbf-2826" name="Zendero del Danzante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0843-4b28-2e16-286b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4339-69c0-5c94-6f3c" type="max"/>
          </constraints>
          <profiles>
            <profile id="49f9-436f-61be-1792" name="Zendero del Danzante" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe. El personaje no puede elegir ninguna montura, no puede equiparse con armas de proyectiles (y pierde el Arco corto) y sólo puede unirse a unidades de Danzantez del Árbol de la Telaraña. El personaje obtiene un bonificador de +1 a sus atributos de Movimiento, Habilidad de Armas y Ataques, así como las reglas especiales Esquivar (4+) y Danzaz de guerra de la Araña (ver Danzantez del Árbol de la Telaraña).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="1718-7f33-233d-b326" name="Danzaz de guerra de la Araña" hidden="false">
              <description>Al inicio de cada fase de combate cuerpo a cuerpo, debes elegir una de las Danzaz listadas a continuación para la unidad. No pueden usar la misma danza en dos fases de combate consecutivas. Los efectos de las Danzaz durarán hasta el inicio de la siguiente Fase de Combate. 

-Bailezito irritante: Las tiradas de salvación por Esquivar de la unidad aumentan en +1 (máximo 3+).

-Danza de laz pìkaduraz: Los ataques envenenados de la unidad surtirán efecto con resultados de 5+.

-Kuchilladaz por todaz partez: La unidad podrán repetir las tiradas para impactar fallidas en combate cuerpo a cuerpo.

-Korrer y ezkonderze: En combate, los ataques enemigos contra las miniaturas de esta unidad solamente impactarán obteniendo un resultado natural de 6. Las miniaturas de la unidad verán reducido su número de ataques a 1 y obtendrán la regla especial Impasibles hasta el final del turno.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="1b99-839c-776f-ef1d" name="Esquivar (4+)" hidden="false" targetId="89b2-357c-6f88-920c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="37ef-e813-a328-c14c" name="Zenderoz. Kaudillo o Gran jefe" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7ca9-d073-133d-f7f7" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="618e-389a-7a95-490c" name="Zendero del laz flechaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f3db-924c-9086-a84a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d9e3-8a54-57c6-403f" type="max"/>
          </constraints>
          <profiles>
            <profile id="4e54-bf39-f732-9b31" name="Zendero del laz flechaz" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe. El personaje y su unidad podrán repetir los resultados de 1 en sus tiradas para impactar al disparar con Arco corto o Arko de huezo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5bc3-4c87-65b1-ac06" name="Zendero del Zeñor de laz beztiaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a5f7-434d-bd35-5185" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ef78-6cf8-f976-1acd" type="max"/>
          </constraints>
          <profiles>
            <profile id="adcc-96df-c8ad-84dd" name="Zendero del Zeñor de laz beztiaz" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran Jefe. Todas las Arañas gigantes, Arañas gigantescas, Aracnarock y Enjambres de arañas a 12” o menos del personaje podrán repetir los resultados naturales de 1 en sus tiradas para impactar y herir.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8b0b-8422-66c6-1e30" name="Zendero del veneno" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="eab3-b591-3b94-41e2" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0bfe-fb6b-8043-f8f2" type="max"/>
          </constraints>
          <profiles>
            <profile id="5caa-abb5-22f2-0d01" name="Zendero del veneno" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe. El personaje obtiene la regla especial Inmune a veneno. Los Ataques envenenados exitosos del personaje y su unidad se resuelven con un penalizador adicional de -1 a la tirada de salvación por armadura del oponente.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="10c9-6312-6351-2e40" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5c1b-d097-2e0f-8cbe" name="Zenderoz. Kaudillo o Gran jefe. Araña gigante" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c244-a0c5-f4a8-0685" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="def9-a545-ef45-a1ba" name="Zendero del Jinete de arañaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7f1f-fd8d-1e5b-fde8" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4247-9db7-dfbd-4547" type="max"/>
          </constraints>
          <profiles>
            <profile id="ee1e-2a05-4ec8-d410" name="Zendero del Jinete de arañaz" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe montado en Araña gigante. El personaje sólo podrá unirse a unidades de Jinetez de araña o Chikoz duroz. Tanto el personaje como su unidad podrán repetir sus tiradas de huída y persecución.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f75b-5ff0-bebb-32c1" name="Zenderoz. Kaudillo o Gran jefe. Troll amaeztrado de río" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7daa-b6b9-a0d2-d05a" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e7b4-7d93-7d42-8180" name="Zendero del Río" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5560-e0e2-dba8-e4ec" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="19ee-191f-0296-330c" type="max"/>
          </constraints>
          <profiles>
            <profile id="5847-9f74-92f9-6f5b" name="Zendero del Río" hidden="false" typeId="cff3-8c5a-f6b1-332b" typeName="Zendero">
              <characteristics>
                <characteristic name="Regla especial" typeId="8fcb-d2b4-a02d-6041">Sólo Kaudillo o Gran jefe montado en Troll amaeztrado de río. El personaje sólo puede unirse a unidades de Trolls de río. El personaje y su unidad obtienen la regla especial Sangre fría para realizar chequeos de Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
