        <selectionEntryGroup id="e81d-b354-c0ba-fc1d" name="Marca del Caos" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d963-2ad7-619c-c745" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a42-52f9-ac84-02bf" type="min"/>
          </constraints>
          <entryLinks>
            <entryLink id="1871-ebaa-938d-7f2f" name="Marca de Tzeentch. Personajes" hidden="false" collective="false" import="true" targetId="b312-1e7c-fa30-c5e6" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4441-8580-f61b-30a5" type="max"/>
              </constraints>
              <rules>
                <rule id="b8ee-a362-9d3a-d83a" name="Marca de Tzeentch. Hechicero de los Espadas de Caos" hidden="false">
                  <description>Obtiene la regla especial Ataques flamígeros y una tirada de salvación especial de 5+ (o +2 si ya disponía de ella). Además, tiene un bonificador de +1 en sus tiradas de lanzamiento de hechizos.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="a27a-6b32-8855-705b" name="Ataques flamígeros" hidden="false" targetId="6985-722e-1ce4-b838" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="15.0"/>
              </costs>
            </entryLink>
            <entryLink id="fed3-f03c-1cff-e4fe" name="Marca del Caos absoluto. Personajes" hidden="false" collective="false" import="true" targetId="4d95-b7b0-28d0-e70a" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="afdc-6a73-a2ae-5afb" type="max"/>
              </constraints>
              <rules>
                <rule id="50bb-556e-40ce-8654" name="Marca del Caos absoluto. Hechicero de los Espadas de Caos" hidden="false">
                  <description>Al inicio de la batalla, efectúa una tirada en la tabla de Ojo de los dioses y aplica el efecto al personaje toda la batalla (considera los resultados de 2 como 3) y podrá repetir las tiradas en la tabla del Ojo de los dioses.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="10.0"/>
              </costs>
            </entryLink>
            <entryLink id="9a11-c3e2-f39a-4d9e" name="Marca de Slaanesh. Personajes" hidden="false" collective="false" import="true" targetId="4c3b-ee1f-c149-ac33" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9873-7963-5a27-8483" type="max"/>
              </constraints>
              <infoLinks>
                <infoLink id="f484-2166-1add-9020" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
                <infoLink id="a2a6-cf55-0681-81e0" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
                <infoLink id="3c84-9987-7d09-b5f5" name="Sangre fría" hidden="false" targetId="fae6-f2eb-1a70-1084" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="10.0"/>
              </costs>
            </entryLink>
            <entryLink id="ca0d-f68f-d441-8e71" name="Marca de Nurgle. Personajes" hidden="false" collective="false" import="true" targetId="7076-7792-e821-b83e" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e18d-52e1-dc72-a3f2" type="max"/>
              </constraints>
              <rules>
                <rule id="c588-5225-7c3a-04e5" name="Marca de Nurgle. Hechicero de los Espadas de Caos" hidden="false">
                  <description>Obtiene las reglas especiales Ataques envenenados e Inmune a veneno.. Además, los enemigos tienen un penalizador de -1 para impactarle con proyectiles y los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="9a89-8dc1-653a-02cb" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="dc62-12ca-7d1d-4e63" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="15.0"/>
              </costs>
            </entryLink>
          </entryLinks>
        </selectionEntryGroup>
        <selectionEntryGroup id="34f5-07d5-f07f-cd17" name="Montura" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b1bc-7586-028e-1f67" type="max"/>
