    <selectionEntryGroup id="0345-7308-c26d-9413" name="Armas mágicas. Culto del placer. Ballesta de repetición" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c3e5-9b59-5c22-a7df" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cfef-193a-6351-965d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7ecf-0572-4222-e7fd" name="Tomador de vidas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="edb7-8046-1090-7243" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a9a1-774c-9141-660c" type="max"/>
          </constraints>
          <profiles>
            <profile id="b8bc-767a-d04f-71a6" name="Tomador de vidas" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Ballesta de repetición. Los disparos realizados con esta arma se resuelven con las reglas especiales Ataques envenenados y disparos múltiples (3). Además, los impactos causados por esta ballesta herirán con un resultado de 2 o más, sin importar la resistencia del objetivo. Esta propiedad no tendrá efecto contra miniaturas que tengan la regla especial Inmune a veneno. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="61da-b296-8979-54a5" name="Ballesta de repetición" hidden="false" targetId="d112-b6f1-9bbe-7c8b" type="profile"/>
            <infoLink id="fc91-a0e4-f911-10aa" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="e212-a2ba-a36b-a7d1" name="Disparos múltiples (3)" hidden="false" targetId="37f9-b9ff-09a3-3dba" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1f1c-0cde-0f46-2eb7" name="Armas mágicas. Culto del placer. Lanza de caballería" hidden="false" collective="false" import="true">
