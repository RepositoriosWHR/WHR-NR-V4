      <rules>
        <rule id="ecbc-9c4c-20b4-b7bb" name="Guardia del chamán" hidden="false">
          <description>Mientras un personaje con la clave hechicero esté unido a una unidad del Kulto de la Araña, ambos obtienen la regla especial Tozudez.</description>
        </rule>
        <rule id="3d77-15c2-497c-4b3e" name="Veteranoz" hidden="false">
          <description>Las unidades del Kulto pueden repetir sus chequeos de Pánico fallidos.</description>
        </rule>
      </rules>
