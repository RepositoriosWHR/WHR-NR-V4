            <profile id="f2f5-5ab2-af6b-4612" name="Espada sideral" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Sólo humanos. Arma de mano. La portadora podrá repetir sus tiradas fallidas para impactar y para herir en combate cuerpo a cuerpo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
