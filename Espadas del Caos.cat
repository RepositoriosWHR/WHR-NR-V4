            <profile id="1ec0-5584-0cd1-6c67" name="Pabellón del odio" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador (y la unidad en la que se encuentre) obtendrán la regla especial Odio (todos los enemigos). Los resultados de 1 para impactar (después de repetir) se resolverán para herir contra la propia unidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
