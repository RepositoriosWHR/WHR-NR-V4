              </constraints>
              <profiles>
                <profile id="aa66-61be-82e9-5c0e" name="Hacha de perdizión de Arlad" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadora. Los ataques con este arma se resuelven con un bonificador de +1 Fuerza. Además, permite a Borgut repetir sus tiradas de salvación por armadura fallidas. Ten en cuenta que Borgut usa el Hacha junto con una Rebanadora.</characteristic>
                  </characteristics>
