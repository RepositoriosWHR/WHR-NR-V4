            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9ab8-03d7-4a9c-351a" type="max"/>
          </constraints>
          <profiles>
            <profile id="7c9c-3ea2-bee3-b6b6" name="Elegido del caos" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Sólo Paladín del Caos o Señor del Caos. Sustituye el efecto de la Marca del Caos del personaje por la Marca del Caos de los Elegidos equivalente. El personaje tan sólo puede unirse a unidades de Elegidos del Caos (ya sean a pie o montados, de cualquier tipo si su Marca del Caos se lo permite).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
