              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">El demonio aumenta su Iniciativa hasta 10 y puede repetir sus tiradas para impactar fallidas en combate cuerpo a cuerpo.</characteristic>
              </characteristics>
