        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8a65-913a-7f62-5d89" type="max"/>
      </constraints>
      <rules>
        <rule id="6276-2e83-3a12-8d45" name="Magia de Durthu, el Anciano" hidden="false">
          <description>Durthu es un hechicero de nivel de magia 2 que elige sus hechizos del Saber de la Vida o de las Bestias.</description>
        </rule>
        <rule id="4b49-17ea-5e45-a42c" name="Reverenciado" hidden="false">
          <description>Las unidades amigas con la clave ESPÍRITUS DEL BOSQUE situadas a 12” o menos de Durthu obtienen la regla especial Tozudez.</description>
        </rule>
        <rule id="f567-e4fe-5ac4-c23d" name="Eterno" hidden="false">
          <description>Durthu tiene una tirada de salvación especial de 5+.</description>
        </rule>
        <rule id="cfcc-1e9a-4e32-60dc" name="Infestado de duendes" hidden="false">
          <description>Se trata de un ataque de proyectiles con un alcance de 12” que siempre impacta a 3+ y se resuelve con Fuerza 2 y las reglas especiales Disparos múltiples (1D6) y Ataques envenenados. Durthu puede efectuar este ataque en combate contra la unidad enemiga con la que se encuentre trabado en combate, resolviendo estos ataques con HA2, F2 e I8 y las reglas especiales Ataques aleatorios (1D6) y Ataques envenenados. Cualquier unidad que reciba una o más heridas por los duendes obtendrá un penalizador de -1 a su Habilidad de armas e Iniciativa hasta el final de ese turno.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="45e1-7cf4-4749-fce7" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
        <infoLink id="6f80-0b75-784e-808e" name="Inflamable" hidden="false" targetId="93e4-15ce-63a5-ad92" type="rule"/>
        <infoLink id="ebfc-63bd-487c-1eca" name="Piel escamosa (1+)" hidden="false" targetId="5e2e-d24c-0c35-66d9" type="rule"/>
        <infoLink id="f2c6-d716-9f43-8dbc" name="Espíritu del bosque" hidden="false" targetId="4167-a553-c1d2-3a27" type="rule"/>
