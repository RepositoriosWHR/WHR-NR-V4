          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="43be-7169-37b3-81f4" name="Grito del bosque" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1147-f0fe-06d1-a216" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3f02-8952-2290-5936" type="max"/>
          </constraints>
          <profiles>
            <profile id="9590-68bd-25ff-c46c" name="Grito del bosque" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El espíritu del bosque tiene un Arma de aliento. Cualquier miniatura bajo la plantilla deberá superar un chequeo de Iniciativa o sufrirá una herida sin salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4336-a57d-ba73-b393" name="Arma de aliento" hidden="false" targetId="3438-0c27-972c-d418" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(chequeo de Iniciativa, sin salvacion por amadura))"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6cdd-132a-cdb2-9e10" name="Corteza de alcornoque" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9e89-55a4-2bf2-c03b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f3f9-204c-15c1-5cb8" type="max"/>
          </constraints>
          <profiles>
            <profile id="c0c2-7071-050a-0815" name="Corteza de alcornoque" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Los resultados de 1, 2 y 3 en las tiradas para herir contra el espíritu del bosque siempre se consideran un fallo, independientemente de la Fuerza del ataque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
