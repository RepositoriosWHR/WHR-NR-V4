        <selectionEntry id="f5ed-e08e-3d68-d8b3" name="Kollar Chungo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a235-2e68-41bd-19de" type="max"/>
