            <selectionEntry id="d9ea-eeb4-9c98-9345" name="Kuchillo de Zakrifizioz" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fd71-b7e6-6c7f-5bf2" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="207d-758e-1f9c-ebae" type="min"/>
              </constraints>
              <profiles>
                <profile id="e4cd-f76d-b95b-7388" name="Kuchillo de Zakrifizioz" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Las heridas causadas por el Kuchillo no permiten tirada de salvación por armadura. Además, por cada herida causada por el Kuchillo en combate cuerpo a cuerpo, puedes añadir un dado adicional de energía o dispersión (según corresponda) en tu siguiente fase de magia.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="bf4c-875a-2f9b-3e2c" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="a7a3-edda-22bc-acf1" name="Mázkara" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="573a-46fa-33d0-f722" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ed70-ce39-6e77-9a96" type="min"/>
              </constraints>
              <profiles>
                <profile id="ce27-63eb-2b4e-6ab3" name="Mázkara" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">La “Mázkara” proporciona a Zeke 1D3 hechizos adicionales, que deben generarse del Saber de la Muerte. Además, proporciona un dado de energía o dispersión adicional (según corresponda) al inicio de cada fase de magia. Por último, la “Mázkara” hace que Zeke cause Terror.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="0a1c-550c-0e80-9c78" name="Terror" hidden="false" targetId="ca57-1f1f-8bc0-d9ab" type="rule"/>
              </infoLinks>
              <entryLinks>
