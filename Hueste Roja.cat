          <profiles>
            <profile id="d9e6-24da-cc8e-2118" name="Desove sagrado de Tzcatli" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove generan un ataque adicional con cada 6 que obtengan al impactar en combate cuerpo a cuerpo (estos nuevos ataques no pueden generar más ataques).</characteristic>
