      <rules>
        <rule id="8540-1c28-a3b9-b08a" name="Potencia de unidad 5" hidden="false">
          <modifiers>
            <modifier type="set" field="name" value="Potencia de unidad 9">
              <conditions>
                <condition field="selections" scope="69f0-c8ec-d7d1-eb54" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="39d5-9560-cc83-9163" type="equalTo"/>
