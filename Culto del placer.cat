    <selectionEntry id="c3e5-ec42-064a-f267" name="[E] - Morathi, La reina madre" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="febf-9577-1895-e674" type="max"/>
      </constraints>
      <rules>
        <rule id="1f55-8587-b626-e6be" name="Magia Morathi, la reina madre" hidden="false">
          <description>Morathi es una hechicera con nivel de magia 4 y conocer todos los hechizos del Saber de Slaanesh y de Magia Oscura. </description>
        </rule>
        <rule id="b62f-a4d9-811d-b8d6" name="Reina madre" hidden="false">
          <description>Morathi tiene la regla especial Presencia inspiradora (sea o no la general del ejército), cuyo radio se verá incrementado hasta las 18”.</description>
        </rule>
        <rule id="1b61-594a-cb9d-fc32" name="Sirvienta del Príncipe Oscuro" hidden="false">
          <description>Posee la Marca de Slaanesh, por lo que tiene las reglas especiales Poder de penetración, Inmune a la psicología y Sangre fría.</description>
        </rule>
        <rule id="02fe-5d38-fb61-b4f5" name="Mil y una bendiciones oscuras" hidden="false">
          <description>Morathi tiene una tirada de Salvación Especial (4+) y la regla especial Resistencia a la magia (2).</description>
        </rule>
        <rule id="04d7-2210-292b-07a5" name="Insaciable" hidden="false">
          <description>Uno de los oficiales de ejercito de elfos oscuros podrá equiparse con un objeto mágico adicional de los permitidos (sin límite en puntos). </description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="6698-6a2a-9773-9960" name="Caballería monstruosa" hidden="false" targetId="a7be-2cd9-f3c6-b091" type="rule"/>
        <infoLink id="4693-a427-29f6-0641" name="Destreza marcial" hidden="false" targetId="e5aa-68a1-bd85-74d0" type="rule"/>
