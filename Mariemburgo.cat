                </rule>
                <rule id="d12d-ea58-daa5-e7a6" name="Frío entumecedor" hidden="false">
                  <description>El Pagowyrm tiene la regla especial Aura de frío, la cual afecta a todas las enemigas a 6” o menos del Pagowyrm.</description>
