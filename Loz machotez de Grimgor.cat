              <profiles>
                <profile id="6328-4991-b6d3-ba70" name="Koraza dura de pelar de Drog" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura pesada. Proporciona a Borgut una tirada de salvación por armadura de 1+, en lugar del habitual 5+ por ser armadura pesada.</characteristic>
