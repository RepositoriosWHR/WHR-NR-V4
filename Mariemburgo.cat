        <infoLink id="70ae-deb2-cb95-8e2f" name="Regimientos de renombre" hidden="false" targetId="a07a-2bc2-efde-20d3" type="rule"/>
        <infoLink id="d6a5-a7db-36d9-2d06" name="No Muerto (1D6)" hidden="false" targetId="3bfe-7c39-626b-9094" type="rule"/>
      </infoLinks>
      <categoryLinks>
