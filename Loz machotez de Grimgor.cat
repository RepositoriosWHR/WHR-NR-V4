        <infoLink id="519b-7f8d-535c-604d" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
        <infoLink id="9eeb-b0f7-58df-0664" name="Piel escamosa (6+)" hidden="false" targetId="1d04-d136-a7a6-eb68" type="rule"/>
