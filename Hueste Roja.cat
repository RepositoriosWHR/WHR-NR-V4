    <selectionEntry id="0cec-1bb5-6bf5-f51a" name="Estegadón anciano" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="dbef-6886-6d3f-4c8f" value="2.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="170b-06ad-215f-f891" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="dbef-6886-6d3f-4c8f" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3673-aaa8-d1d9-e6c2" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="dbef-6886-6d3f-4c8f" type="max"/>
      </constraints>
      <rules>
        <rule id="c980-eaee-4ceb-adbe" name="Dotación del castillo Estegadón anciano" hidden="false">
          <description>El Estegadón anciano está tripulado por una dotación de al menos 4 Eslizones, aunque se consideran una única miniatura. En cuerpo a cuerpo, el Estegadón anciano y la dotación pueden atacar con normalidad a cualquier miniatura en contacto peana con peana. Todos los impactos se resuelven utilizando la Resistencia, Heridas y tirada de salvación del Estegadón anciano. Usa la HP de la dotación para resolver los ataques de disparo. Utiliza el valor de Liderazgo del Estegadón anciano en lugar del de los eslizones. Su Potencia de unidad es de 10, con un bonificador de +1 por cada eslizón adicional. </description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="ffd4-02da-6cd8-4834" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
        <infoLink id="c568-7af8-a54f-8176" name="Piel escamosa (2+)" hidden="false" targetId="4c17-1353-fcdd-fe40" type="rule"/>
