      <entryLinks>
        <entryLink id="dfc8-4e81-2715-6961" name="Marca del Caos absoluto. Personajes" hidden="false" collective="false" import="true" targetId="4d95-b7b0-28d0-e70a" type="selectionEntry">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2c73-80b6-4d5c-b083" type="min"/>
          </constraints>
          <rules>
            <rule id="8e68-3aff-786c-5ad5" name="Marca del Caos absoluto. Vardek Crom" hidden="false">
              <description>Crom porta la Marca del Caos absoluto, que le permite repetir las tiradas en la tabla del Ojo de los dioses. Además, al inicio de la batalla, efectúa una tirada en la tabla de Ojo de los dioses y aplica el efecto a Crom toda la batalla (considera los resultados de 2 como 3).</description>
            </rule>
          </rules>
        </entryLink>
      </entryLinks>
      <costs>
        <cost name="pts" typeId="points" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="887d-49c5-d4dd-b23d" name="[E]  - Archaón, Ungido del Caos, Señor de los Espadas del Caos" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="increment" field="0916-0337-b1bf-c53f" value="1.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="c658-826b-9ab1-afa2" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="046a-1c36-705e-1c0e" type="equalTo"/>
          </conditions>
