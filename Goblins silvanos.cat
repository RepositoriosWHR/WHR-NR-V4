    <selectionEntry id="b058-439e-5464-3163" name="Danzantez del Árbol de la Telaraña" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="751b-a926-8a92-994a" value="2.0">
          <conditions>
