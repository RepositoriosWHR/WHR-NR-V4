    <selectionEntry id="d741-7675-ad77-14ef" name="[R] - Matadores piratas de Drong el largo" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="7e7c-6a65-13dd-3fcd" value="0.0">
          <comment>Pielesverdes</comment>
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="4465-4d4a-8a56-acc4" type="atLeast"/>
          </conditions>
        </modifier>
        <modifier type="set" field="7e7c-6a65-13dd-3fcd" value="0.0">
          <comment>Clave: Caos</comment>
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="7859-8066-fb2b-c7c8" type="atLeast"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7e7c-6a65-13dd-3fcd" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f254-826e-5272-232b" type="max"/>
      </constraints>
      <rules>
        <rule id="0428-117a-fd75-555b" name="Ron enano" hidden="false">
          <description>Todos los enemigos que ataquen en combate cuerpo a cuerpo a los matadores piratas tienen un penalizador de -1 en sus tiradas para impactar. Esto no afecta a demonios o no muertos.</description>
        </rule>
        <rule id="1548-76a9-b2bf-b163" name="Muchas pistolas" hidden="false">
          <description>Los matadores piratas pueden efectuar todas las fases de combate todos sus ataques con F4 y poder de penetración, ya que llevan innumerables pistolas.</description>
        </rule>
        <rule id="0a79-5911-07ca-0c91" name="Falta de higiene" hidden="false">
          <description>Los matadores Piratas no podrán desplegarse a 6” o menos de ninguna unidad aliada y viceversa.</description>
        </rule>
        <rule id="7900-e167-d768-493e" name="Matadores piratas" hidden="false">
          <description>Cuando una miniatura con esta regla especial es retirada como baja durante una fase de combate cuerpo a cuerpo, podrá hacer inmediatamente un único ataque con pistola contra la unidad que acabó con él. Estos ataques se realizan inmediatamente, y cuentan para la resolución del combate</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="eb60-8ea5-e406-3e4c" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="d7eb-bd08-3de4-1914" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
        <infoLink id="0128-c09c-3108-7971" name="Inflamable" hidden="false" targetId="93e4-15ce-63a5-ad92" type="rule"/>
