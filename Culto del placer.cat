          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d53-5834-d6ca-0739" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="19b7-e73f-426b-45c7" type="max"/>
          </constraints>
          <profiles>
            <profile id="bf3d-85c1-69ac-3bf5" name="Mirada disforme" hidden="false" typeId="4a21-6ede-290c-54cb" typeName="Recompensa del Caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ac18-bd08-5794-1799">El personaje obtiene un ataque de disparo que tiene un alcance de 12”, puede dispararse aunque el personaje marche y se resuelve con Fuerza 4 y las reglas especiales Francotirador, Disparo rápido y Ataques mágicos. La Mirada disforme puede utilizarse incluso si el personaje está trabado en combate cuerpo a cuerpo, aunque en este caso sólo podrá utilizarse contra una unidad trabada con el personaje. Se recuerda que no se puede usar el mismo turno en el que se ha cargado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d9e2-aeb3-79b3-1f79" name="Francotirador" hidden="false" targetId="8fa0-a4f6-e454-dbfe" type="rule">
