              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Proporcionan una tirada de salvación especial de 4+; además, su portador estará sujeto a la regla especial Furia asesina, y no la perderá aunque pierda un combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
