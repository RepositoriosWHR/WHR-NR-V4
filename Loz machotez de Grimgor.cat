        <selectionEntry id="71ef-c4bc-b91a-87bf" name="Ezkudo de Gorglok" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8d63-4e1a-5e68-aaff" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b4ad-f5f0-5940-ddf4" type="max"/>
          </constraints>
          <profiles>
            <profile id="b056-9e77-2eb3-00ff" name="Ezkudo de Gorglok" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Solo Orcos negros. Escudo. Proporciona un bonificador adicional de +1 a la tirada de salvación por armadura del portador y un penalizador de -1 a su Iniciativa. Adicionalmente, por cada tirada de salvación por armadura exitosa que realice en combate cuerpo a cuerpo, el portador verá aumentado en uno su atributo de Ataques para esa ronda de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="832f-4bb4-8404-0950" name="Escudo" hidden="false" targetId="c028-354e-9169-7463" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
