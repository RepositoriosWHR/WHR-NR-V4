              </constraints>
              <rules>
                <rule id="b6f7-b6ac-3ce7-b1f9" name="Sapo de la rabia" hidden="false">
                  <description>Al inicio de la partida, después de desplegar los Exploradores, puedes desplegar el marcador de sapo junto una unidad enemiga que se encuentre en la mesa. Cuando los Destripadáctilos ataquen a la unidad marcada por el sapo, pueden repetir sus tiradas fallidas para impactar en combate cuerpo a cuerpo.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="20.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
