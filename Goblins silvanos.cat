        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="51f8-a977-c5ab-57b8" type="max"/>
      </constraints>
      <rules>
        <rule id="725e-7738-d7c0-f834" name="Magia Zeke" hidden="false">
          <description>Zeke es un hechicero de nivel 2 que siempre utiliza hechizos del Saber del Pequeño Waaagh!</description>
        </rule>
        <rule id="c8c9-2b73-a00e-0b3c" name="Ziempre kon arañaz" hidden="false">
          <description>Zeke es Inmune a veneno, y puede sumar +1 a su tirada en la tabla de disfunciones mágicas. Además, en combate cuerpo a cuerpo, Zeke puede efectuar 1D6 Ataques adicionales, que se resuelven con HA2, F2, I3 y las reglas especiales Ataques envenenados y Poder de penetración.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="0f41-f053-5634-5317" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="5948-a67d-8f06-d2e9" name="Miedo a loz orejotaz" hidden="false" targetId="45ff-044b-b650-84f8" type="rule"/>
        <infoLink id="03bd-a3ca-5664-b7e4" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
        <infoLink id="9d2d-5ce8-13d4-4714" name="Cruzar (bosques)" hidden="false" targetId="9d01-387d-269d-5a44" type="rule"/>
        <infoLink id="a9e9-9998-077f-2404" name="Inmune al pánico" hidden="false" targetId="06f4-bd6a-c34d-baed" type="rule"/>
        <infoLink id="baf8-dc4c-8821-0880" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
      </infoLinks>
