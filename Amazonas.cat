            <selectionEntry id="52ba-8123-72b2-d2ce" name="Manifestación de Kalith" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b24-9790-9f86-310d" type="max"/>
