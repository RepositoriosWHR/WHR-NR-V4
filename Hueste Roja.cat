            <profile id="7965-7416-1807-c3e4" name="Bendición solar" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Otorga al portador una tirada de salvación especial de 5+ y la regla especial Inmune a fuego. El portador no podrá utilizar ni incluirse dentro de una unidad con la regla especial Exploradores. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
