        </selectionEntry>
        <selectionEntry id="6c25-3702-a7a9-1e34" name="Maestro en toxinas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="85ed-bbc1-d169-f600" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0650-5c5e-4c27-d727" type="max"/>
          </constraints>
          <profiles>
            <profile id="3ff0-da2c-1fa3-feca" name="Maestro en toxinas" hidden="false" typeId="9846-934f-6342-2762" typeName="Senda">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">Otorga al personaje la regla especial Ataques envenenados (si ya dispone de esta regla especial, tendrán éxito también con resultados de 5+). Adicionalmente, al elaborar la lista de ejército, una unidad de Iniciados del culto, Lanceros del culto, Ballesteros del culto, Buscadores del dolor o Guardia de la ciudad de tu ejército podrá tener Ataques envenenados (+2 puntos por miniatura); o una unidad de Espadachines druchii que tenga la regla especial Ataques envenenados, estos ataques tendrán éxito también con resultados de 5+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="81eb-6399-8fc0-b6b3" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ec35-cf48-092c-458c" name="Senda de la depravación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="79bd-979a-f664-fdeb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3e59-32ac-b2a0-713e" type="max"/>
