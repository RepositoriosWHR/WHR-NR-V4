              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">El personaje puede repetir todas sus tiradas fallidas para impactar en combate cuerpo a cuerpo, pero no puede elegir ninguna montura.</characteristic>
              </characteristics>
