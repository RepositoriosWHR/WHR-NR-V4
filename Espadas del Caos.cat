        <selectionEntry id="923b-fec7-dade-21a0" name="Marca del Caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5516-4192-d565-47e6" type="max"/>
