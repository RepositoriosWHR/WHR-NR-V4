    <selectionEntry id="b8ab-27b4-699f-2215" name="Miembro de las Krak-Kalim" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="439f-ab05-8c90-d6af" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b683-bab3-33b2-bc3d" type="max"/>
      </constraints>
      <rules>
        <rule id="3e69-2b59-6fc0-8d72" name="Miembro de las Krak-Kalim" hidden="false">
          <description>Karra tiene la regla especial Culto de Koka-Kalim. Además, la unidad de Devotas de Koka-Kalim a la que se una Karra obtendrá la regla especial Esquivar (+5) por +2 puntos por miniatura. Este bonificador se mantiene aunque Karra sea retirada como baja. Sin embargo, la unidad no podrá incluir otros personajes ni tomar el Liderazgo de Madre Samantha para realizar sus chequeos. Adicionalmente, si incluyes esta Saga de Karra en tu lista de ejército, no podrás incluir unidades de Redimidas de Koka-Kalim.</description>
        </rule>
      </rules>
      <costs>
        <cost name="pts" typeId="points" value="0.0"/>
      </costs>
    </selectionEntry>
