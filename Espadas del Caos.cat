          <rules>
            <rule id="3cc1-a268-f04e-2066" name="Marca de Khorne. Haargroth el Carnicero" hidden="false">
              <description>Haargroth porta la Marca de Khorne, que le otorga las reglas especiales Furia asesina y Resistencia mágica (2). No pierde su Furia asesina si es derrotado en combate.</description>
            </rule>
          </rules>
