    <selectionEntry id="4cdd-8e2f-3cb2-e838" name="Trono del Príncipe Negro" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="ae04-3eb3-cdf9-30c6" name="Potencia de unidad 4" hidden="false"/>
        <rule id="d162-3a7b-eba8-0ae8" name="Trono del Príncipe Negro" hidden="false">
          <description>Un Trono del Príncipe Negro puede unirse, si se desea, a una unidad de Iniciados de Slaanesh, para lo cual debe seguir las reglas habituales de personajes uniéndose a unidades. Ten en cuenta el tamaño de la &quot;huella&quot; del Trono del Príncipe Negro, que será de 60x100mm. El Trono del Príncipe Negro contará como las mismas miniaturas de Iniciados de Slaanesh que ocuparían su posición a la hora de extrapolar el bonificador por filas de la unidad, y podrá marchar mientras esté unido a la unidad. A la hora de disparar contra un Trono del Príncipe Negro, éste deberá considerarse un objetivo independiente de su unidad (es decir, que el oponente decidirá si dispara al Trono del Príncipe Negro o a la unidad de Iniciados de Slaanesh). </description>
        </rule>
        <rule id="b754-f6f0-97fe-422f" name="Foco de Slaanesh" hidden="false">
          <description>Todas las unidades con la clave CULTO DEL PLACER a 12” o menos del Trono del Príncipe Negro obtienen las reglas especiales Aura demoníaca (5+) y Poder de penetración; si ya disponían de Aura demoníaca, ésta mejorará en un punto (hasta un máximo de 3+, o de 4+ si se trata de una miniatura de Potencia de unidad 5 o superior). Si el trono está unido a una unidad, dicha unidad obtendrá la regla especial Aura demoníaca (4+); esto ya incluye la mejora que proporciona el Foco de Slaanesh.</description>
        </rule>
        <rule id="4084-bbd3-a6f4-65d6" name="Imbuir frenesí (Súcubu)" hidden="false">
          <description>Se trata de un Objeto portahechizos con nivel de energía 2 que contiene el hechizo Frenesí histérico del Saber de Slaanesh.</description>
        </rule>
        <rule id="1503-2aa6-4a8e-19cc" name="Marca de Slaanesh. Trono del Príncipe Negro" hidden="false">
          <description>Porta la Marca de Slaanesh, que le otorga la regla especial Sangre fría.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="e96a-9290-3f8b-daf9" name="Carro" hidden="false" targetId="c761-ad12-6530-fab7" type="rule"/>
        <infoLink id="f627-1c8a-a188-486b" name="Terror" hidden="false" targetId="ca57-1f1f-8bc0-d9ab" type="rule"/>
        <infoLink id="ee2e-569e-e5a7-bbee" name="Odio (Altos elfos)" hidden="false" targetId="54ab-9e52-1a7a-8fb2" type="rule"/>
        <infoLink id="4121-a0b4-c49d-de54" name="Protección por montura (2)" hidden="false" targetId="e265-bb6c-2315-231a" type="rule"/>
        <infoLink id="fec3-24ca-b620-c5c8" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
        <infoLink id="5ffb-69eb-859a-9433" name="Objetivo grande" hidden="false" targetId="71eb-6467-3a39-bdb6" type="rule"/>
        <infoLink id="252a-e578-9d1f-48c9" name="Almizcle soporífero" hidden="false" targetId="31a4-d777-494d-ffe7" type="rule"/>
        <infoLink id="65e7-9152-1dba-a6a1" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
        <infoLink id="c210-e0cb-6bb6-7756" name="Aura demoníaca (4+)" hidden="false" targetId="79f2-17bc-18d1-75e3" type="rule"/>
        <infoLink id="b230-9a41-b833-9392" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule">
          <modifiers>
