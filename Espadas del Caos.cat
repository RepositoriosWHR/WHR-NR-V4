          </constraints>
          <entryLinks>
            <entryLink id="0263-4a39-56b8-38fe" name="Marca de Khorne. Personajes" hidden="false" collective="false" import="true" targetId="eb2e-e161-ff39-cbf6" type="selectionEntry">
              <rules>
                <rule id="ccb6-76f1-3b8c-c230" name="Marca de Khorne. Paladin de los Espadas del Caos" hidden="false">
                  <description>Obtiene las reglas especiales Furia asesina y Resistencia mágica (2). Además, no perderá su Furia asesina aunque sea derrotado en combate.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="a0bc-d0fe-9759-0af1" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
                <infoLink id="149d-598a-7eca-dc59" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="15.0"/>
              </costs>
            </entryLink>
            <entryLink id="b019-59e6-29b7-e9cb" name="Marca de Tzeentch. Personajes" hidden="false" collective="false" import="true" targetId="b312-1e7c-fa30-c5e6" type="selectionEntry">
              <rules>
                <rule id="4d9d-cf08-d21b-c781" name="Marca de Tzeentch. Paladin de los Espadas del Caos" hidden="false">
                  <description>Obtiene las reglas especiales Ataques flamígeros y Ataques mágicos y una tirada de salvación especial de 5+ (o +2 si ya disponía de ella).</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="1488-f45a-2d9f-af28" name="Ataques flamígeros" hidden="false" targetId="6985-722e-1ce4-b838" type="rule"/>
                <infoLink id="acc8-c542-897d-8fc5" name="Ataques mágicos" hidden="false" targetId="7cc5-d3fc-a37a-3d4a" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="10.0"/>
              </costs>
            </entryLink>
            <entryLink id="19bc-c8d1-2e64-f17e" name="Marca del Caos absoluto. Personajes" hidden="false" collective="false" import="true" targetId="4d95-b7b0-28d0-e70a" type="selectionEntry">
              <rules>
                <rule id="bfe8-4dd7-b73d-3dc9" name="Marca del Caos absoluto. Paladín de los espadas del Caos" hidden="false">
                  <description>Al inicio de la batalla, efectúa una tirada en la tabla de Ojo de los dioses y aplica el efecto al personaje toda la batalla (considera los resultados de 2 como 3) y podrá repetir las tiradas en la tabla del Ojo de los dioses.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="10.0"/>
              </costs>
            </entryLink>
            <entryLink id="c5e5-7254-02a7-0169" name="Marca de Slaanesh. Personajes" hidden="false" collective="false" import="true" targetId="4c3b-ee1f-c149-ac33" type="selectionEntry">
              <infoLinks>
                <infoLink id="56bd-59f5-063f-1701" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
                <infoLink id="9149-77e4-1c87-129b" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
                <infoLink id="6ee0-6178-f670-fcc2" name="Sangre fría" hidden="false" targetId="fae6-f2eb-1a70-1084" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="10.0"/>
              </costs>
            </entryLink>
            <entryLink id="d282-2246-5b71-7df4" name="Marca de Nurgle. Personajes" hidden="false" collective="false" import="true" targetId="7076-7792-e821-b83e" type="selectionEntry">
              <rules>
                <rule id="0dd0-c83d-98e6-1b45" name="Marca de Nurgle. Paladin de los Espadas del Caos" hidden="false">
                  <description>Obtiene las reglas especiales Ataques envenenados e Inmune a veneno.. Además, los enemigos tienen un penalizador de -1 para impactarle con proyectiles y los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="4fe1-bec9-fd9c-4872" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="a5b9-2d64-c53a-058a" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="15.0"/>
              </costs>
            </entryLink>
          </entryLinks>
