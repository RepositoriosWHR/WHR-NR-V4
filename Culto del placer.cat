            <profile id="0b3e-4afe-f6fd-53e2" name="Armadura de la locura inmortal" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura pesada. Otorga a su portador una tirada de salvación por armadura de 4+ (en lugar de 5+). Aumenta en 1 el valor de los atributos de R y H de su portador y le otorga las reglas especiales Aura demoníaca (4+) y Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6ace-ce76-84cf-6a9b" name="Armadura pesada" hidden="false" targetId="1ee5-2441-2c69-5965" type="profile"/>
            <infoLink id="50d4-8518-f38e-aac7" name="Aura demoníaca (4+)" hidden="false" targetId="79f2-17bc-18d1-75e3" type="rule"/>
            <infoLink id="cbf1-f09a-fb22-9e7b" name="Estupidez" hidden="false" targetId="eff6-2d64-db5e-d51e" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="45fd-dd6a-ecc3-485d" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
