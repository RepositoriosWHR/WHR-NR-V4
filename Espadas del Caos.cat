          <entryLinks>
            <entryLink id="8661-ba8a-130a-dbe7" name="Marca del Caos absoluto. Unidades" hidden="false" collective="false" import="true" targetId="24b7-05f6-36ce-099c" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="4.0">
                  <repeats>
                    <repeat field="selections" scope="71da-f694-3a3b-9435" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="266c-f7b2-d0da-fd04" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="de21-80be-1f06-80a4" name="Marca del Caos absoluto. Elegidos del Caos" hidden="false">
                  <description>Al inicio de la batalla, antes del despliegue, efectúa una tirada en la tabla del Ojo de los dioses y aplica el resultado a toda la unidad durante la batalla; considera los resultados de 2 como 3. Además, podrán repetir sus tiradas de Ojo de los dioses.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="adc4-a0d5-2d32-3b67" name="Ojo de los dioses" hidden="false" targetId="0799-cc58-3276-4a94" type="rule"/>
              </infoLinks>
              <entryLinks>
                <entryLink id="3998-5119-fe26-495e" name="Los Guerreros Kul" hidden="false" collective="false" import="true" targetId="2798-70b4-9929-8cc7" type="selectionEntry"/>
              </entryLinks>
            </entryLink>
            <entryLink id="b40b-bf49-e0d9-cbd1" name="Marca de Khorne. Unidades" hidden="false" collective="false" import="true" targetId="0cf1-1763-4dd8-caba" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="5.0">
                  <repeats>
                    <repeat field="selections" scope="71da-f694-3a3b-9435" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="266c-f7b2-d0da-fd04" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="0236-49e3-72da-c67d" name="Marca de Khorne. Elegidos del Caos" hidden="false">
                  <description>Obtienen las reglas especiales Furia asesina y Resistencia mágica (2). Además, no perderán su Furia asesina aunque sean derrotados en combate.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="c256-b5c7-d4af-91fd" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
                <infoLink id="0ba4-501e-d04c-8024" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
              </infoLinks>
            </entryLink>
            <entryLink id="1213-92b6-3bad-c0fb" name="Marca de Nurgle. Unidades" hidden="false" collective="false" import="true" targetId="0adb-14f6-3d62-89cf" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="5.0">
                  <repeats>
                    <repeat field="selections" scope="71da-f694-3a3b-9435" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="266c-f7b2-d0da-fd04" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="1cef-450e-9d50-88dd" name="Marca de Nurgle. Elegidos del Caos" hidden="false">
                  <description>Obtienen las reglas especiales Ataques envenenados e Inmune a veneno. Los enemigos tienen un penalizador de -1 para impactarles con proyectiles. Los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="a89d-5bc6-f8b3-7e05" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="747b-c7a9-32e0-6280" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
