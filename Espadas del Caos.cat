                <modifier type="increment" field="points" value="7.0">
                  <repeats>
                    <repeat field="selections" scope="4a60-7c1b-2d90-5206" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b28f-acb1-3bc9-8804" repeats="1" roundUp="false"/>
