    <selectionEntryGroup id="f193-6ed4-85d1-3eaa" name="Brotes ancestrales de Savia milenaria" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="7a38-7309-5a89-0428" name="Brote de la Raíz Serpenteante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="876e-2c3a-2297-ccb9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="191f-89cc-a817-fae6" type="max"/>
          </constraints>
          <profiles>
            <profile id="e58c-7b7f-2b95-5504" name="Brote de la Raíz Serpenteante" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Un sólo uso. Puedes utilizarlo al final de cualquiera de tus fases de movimiento si el portador y su unidad se encuentran dentro de un Bosque, hay al menos otro Bosque en el campo de batalla y no se encuentran en contacto con una o más unidades enemigas. Retira la unidad del campo de batalla y colócala inmediatamente en el interior de otro Bosque del campo de batalla a tu elección: debes ser capaz de colocar la unidad completamente dentro del Bosque para hacer uso de este Brote Ancestral.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a06a-f02c-f31e-6974" name="Brote de Espina Sangrienta" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="be0d-c9b5-ceff-347f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="053a-cca4-06ac-e352" type="max"/>
          </constraints>
          <profiles>
            <profile id="fc64-6ad6-3d21-6e20" name="Brote de Espina Sangrienta" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">La unidad gana la regla especial Ataques envenenados. Si una miniatura ya tiene esta regla especial, herirá automáticamente con resultados de 5+ para impactar en lugar de 6.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="50e1-d5c2-6a63-918a" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2fd5-f50a-816a-e48f" name="Brote de las Eras Olvidadas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a2e2-3a38-55a4-99d5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5e48-d8bc-fe83-bd3a" type="max"/>
          </constraints>
          <profiles>
            <profile id="c5a2-a25a-ccac-381f" name="Brote de las Eras Olvidadas" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Las miniaturas de unidad que lo porten obtendrán la regla especial Furia asesina y si ya disponían de esta regla no perderán su Furia asesina aunque sea derrotada en combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2367-cfd8-281d-0631" name="Raíz de Sangre de Savia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4d99-5eb5-0d42-170d" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a19c-d328-0b49-18e2" type="max"/>
          </constraints>
          <profiles>
            <profile id="24ad-9c3e-4c97-5fca" name="Raíz de Sangre de Savia" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">El portador y su unidad obtienen la regla especial Regeneración (5+) o aumenta en +1 si ya la tenían.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1593-56e4-3a3f-613d" name="Regeneración (5+)" hidden="false" targetId="515b-514f-7ee3-6cc3" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e872-1349-36b4-ed7a" name="Brote de la Primavera Eterna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c625-ddf2-0304-546e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="36ad-4b45-7f38-f365" type="max"/>
          </constraints>
          <profiles>
            <profile id="dfcc-beca-462b-e0c8" name="Brote de la Primavera Eterna" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Objeto portahechizos de nivel de energía 4. Contiene el hechizo Resurrección del Saber de la Vida en su versión no potenciada. Si la unidad objetivo del hechizo se encuentra en un Bosque (sigue las reglas de Elemento de área) el hechizo restaurará +1 herida adicional.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ab34-c67c-bb10-37ec" name="Brotes ancestrales de Savia milenaria. Solo Espectro del bosque" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="f459-4374-4bbe-4f5f" name="Brote del Roble Desgarrador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6189-2e90-7107-00e3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f8d3-5d9d-0b50-40f2" type="max"/>
          </constraints>
          <profiles>
            <profile id="abd5-7feb-9767-c4a4" name="Brote del Roble Desgarrador" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Solo Espectro de los Árboles. El portador y cualquier miniatura en su unidad ganan la regla especial Carga Devastadora y podrán repetir los resultados 1 en sus tiradas para herir en combate cuerpo a cuerpo. Además, el Espectro de los Árboles puede repetir las tiradas para impactar y para herir cuando participe en un Desafío.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6478-1421-873b-5059" name="Carga devastadora" hidden="false" targetId="dbe6-c910-7f37-aeac" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a301-111f-8035-96f4" name="Brote de Corteza de Hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="050e-dd42-0708-6b06" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="eb61-71c9-dc00-7345" type="max"/>
          </constraints>
          <profiles>
            <profile id="2c8c-c165-9b90-80c9" name="Brote de Corteza de Hierro" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Solo Espectro de los Árboles. El portador y todas las miniaturas aliadas con la regla especial Espíritu del bosque situadas a 12” o menos del portador de este Brote Ancestral obtienen la regla especial Piel escamosa (5+) o +1 si
ya tenían esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="340f-7966-83f7-ce5c" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="65.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="bb22-7686-0e1f-0986" name="Rasgos, Duendes y Hadas de los Espectros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a25d-1c3a-f76b-47f7" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4a41-6d30-c849-ebee" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e10f-8c9f-b857-5386" name="Metamorfosis" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6480-06e4-4521-b805" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ad4d-7ce8-8221-c795" type="max"/>
          </constraints>
          <profiles>
            <profile id="443c-6ec9-7fa1-e872" name="Metamorfosis" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Al inicio de cada fase de combate, el personaje debe elegir una de las formas de árbol listadas a continuación. No puede usar la misma forma de árbol en dos fases de combate consecutivas. Los efectos durarán hasta el inicio de la siguiente fase de combate. Puedes elegir una única unidad de Dríades de tu ejército para que gane este rasgo de manera adicional por +3 puntos por miniatura. La unidad debe obtener la regla especial Hostigadores, pasa a considerarse Unidad especial y gana la capacidad de elegir una de las formas de árbol de la misma manera que el personaje. Tanto el personaje como la unidad deberán escoger la misma forma de árbol en cada fase de combate cuerpo a cuerpo. En este caso, el Espectro del bosque deberá unirse a esa unidad de Dríades y no podrá abandonarla. Ningún otro personaje podrá unirse a la unidad.

Forma de abedul: Obtiene +1 a sus Ataques.
Forma de roble Obtiene +1 a la Fuerza.
Forma de fresno Los ataques sin las reglas especiales Ataques mágicos y/o Ataques flamígeros tienen unpenalizador de -1 en sus tiradas para herir contra el espíritu del bosque. Adicionalmente, obtiene la regla especial Piel escamosa (5+) o +1 si ya tenía esta regla especial.
Forma de sauce Las miniaturas que dirijan uno o más ataques en combate cuerpo a cuerpo contra el espíritudel bosque sufrirán un penalizador de -1 a impactar y -1 a su Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d2ad-af0f-3cc9-2dbb" name="Luz de hada" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9162-4849-7c79-6837" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="da5b-c0fd-228c-1407" type="max"/>
          </constraints>
          <profiles>
            <profile id="dde4-a3e6-d152-af3b" name="Luz de hada" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Los ataques realizados en combate cuerpo a cuerpo por el personaje se resuelven con la regla especial Golpe letal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8a69-1ea4-02a1-891f" name="Golpe letal" hidden="false" targetId="9f1c-d301-bd0e-af81" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="896c-e58f-0dc4-9eed" name="Guía del Sendero Oculto" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="0d9d-7a8e-89a5-2c9c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="459e-7cee-695c-484a" type="max"/>
          </constraints>
          <profiles>
            <profile id="07a4-f374-8ebf-fffb" name="Guía del Sendero Oculto" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Puede sumar +1 a la tirada de Refuerzos de la unidad donde se encuentre unido este Espectro para determinar si entra al campo de batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="acd9-7fdb-89b3-80fc" name="Desconexión con el plano material" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="594c-8201-79a8-ec7a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f00a-b2ba-e361-3a35" type="max"/>
          </constraints>
          <profiles>
            <profile id="214c-8af1-5f23-b9f1" name="Desconexión con el plano material" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje obtiene la regla especial Etéreo. No puede beneficiarse de ningún tipo de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fbe0-6ea0-c758-e334" name="Etéreo" hidden="false" targetId="34c4-9e60-1a62-eda5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a56e-2223-dfe6-e0cc" name="Ciclón de Corteza Espectral" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="78d3-a6f7-7a9b-5d80" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0faa-faa9-66ea-bee8" type="max"/>
          </constraints>
          <profiles>
            <profile id="93e5-e141-00a8-5847" name="Ciclón de Corteza Espectral" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El Espectro aumenta su Iniciativa hasta 10 y puede repetir sus tiradas para impactar fallidas en combate cuerpo a cuerpo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="556e-c277-055d-2892" name="Custodio Supremo de las Bóvedas del invierno" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4e34-a061-09a1-1629" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9ac9-96e7-9761-7046" type="max"/>
          </constraints>
          <profiles>
            <profile id="cd99-934a-9718-bb20" name="Custodio Supremo de las Bóvedas del invierno" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje obtiene las reglas especiales Poder de penetración, Ataques envenenados, Tozudez, Odio (Caos) y un +1 a su valor de la regla de Piel escamosa. Su tirada de salvación de Aura demoníaca mejora en +1. Además, el personaje y la unidad a la que está unido ganan la regla especial Aura de frio.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f0a7-6d3a-3c10-8257" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
            <infoLink id="9f55-0f79-4b2d-0ee6" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="d900-1d81-ef60-5ac3" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule"/>
            <infoLink id="753e-df41-4dc3-8632" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Caos)"/>
              </modifiers>
            </infoLink>
            <infoLink id="90a2-3074-697b-9d98" name="Aura de frio" hidden="false" targetId="a75b-8c16-3718-ea3c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
