              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arco corto. Tiene la regla especial Disparos múltiples (X), donde X es el valor de Ataques del perfil del portador. Además, cada vez que dispares con este arco, tira 1D6 para determinar la Fuerza de sus disparos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="33f5-b8a8-b30e-d5f1" name="Arco corto" hidden="false" targetId="bc9b-e19b-4f02-1726" type="profile"/>
