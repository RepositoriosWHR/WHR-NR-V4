        <selectionEntry id="ae37-5422-6fff-71eb" name="Desove sagrado de Chotek" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9172-0819-e817-ca0e" type="max"/>
          </constraints>
          <profiles>
            <profile id="3361-82a0-cb24-6ec6" name="Desove sagrado de Chotek" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove obtienen la regla especial Veloz. Los Kroxigores de las unidades de Guerreros eslizón se ven beneficiados por estos efectos si su unidad contiene al menos cinco eslizones por cada króxigor. Un personaje con este Desove sagrado no obtiene los beneficios del desove si está montado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9acf-1773-1992-e5f4" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cdbf-7fe6-d4fc-43cd" name="Desove sagrado de Huanchi" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5e61-1c95-eb61-cca3" type="max"/>
          </constraints>
          <profiles>
            <profile id="430c-ce38-d9c7-020e" name="Desove sagrado de Huanchi" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove obtienen la regla especial Cruzar (Bosques).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8f74-779a-2d74-d2c1" name="Cruzar (bosques)" hidden="false" targetId="9d01-387d-269d-5a44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="88cf-040e-dbb5-c0ac" name="Desove sagrado de Itzl" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8469-aa74-52c9-c9d0" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b8e-673c-afbc-f0b3" name="Desove sagrado de Itzl" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove obtienen la regla especial Tozudez. Los personajes pertenecientes a este Desove sagrado que lleven de montura un Gélido cornudo sólo podrán unirse a unidades de Jinetes de Gélido cornudo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e84f-8632-467e-2af8" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ef31-e933-9040-c276" name="Desove sagrado de Quetzl" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e20f-41bd-215c-606d" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb30-12cc-d149-d6b7" name="Desove sagrado de Quetzl" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove mejoran su regla especial Piel escamosa en +1. En caso de no disponer de esta, obtienen la regla especial Piel escamosa (6+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6475-4cb1-2d4e-98cf" name="Piel escamosa (6+)" hidden="false" targetId="1d04-d136-a7a6-eb68" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
