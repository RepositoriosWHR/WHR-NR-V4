              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Los ataques y disparos efectuados por el personaje (y por su montura) obtendrán la regla especial Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
