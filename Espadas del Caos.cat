            <profile id="9ed5-5154-4e2e-8ef0" name="Fuerza mortífera" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene +1 a su Fuerza.</characteristic>
