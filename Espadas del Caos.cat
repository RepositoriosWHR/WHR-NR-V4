      </profiles>
      <rules>
        <rule id="29c4-ad97-ab86-2ec5" name="Jinetes infernales" hidden="false">
          <description>Puede declarar Huir como reacción a una carga (reagrupándose inmediatamente tras recorrer la distancia de huida) pese a ser Indesmoralizables. Además, pueden repetir sus tiradas de persecución.</description>
        </rule>
        <rule id="801d-7302-1c04-ee43" name="Reptar sinuoso" hidden="false">
          <description>A efectos de movimiento, consideran el Terreno difícil como Terreno abierto, y el Terreno muy difícil como Terreno difícil.</description>
        </rule>
      </rules>
      <infoLinks>
