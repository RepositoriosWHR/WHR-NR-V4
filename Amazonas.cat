      </constraints>
      <rules>
        <rule id="d80b-106e-fb8f-c412" name="Seguidoras de Kalith" hidden="false">
          <description>Si la general del ejército tiene la regla especial Culto de Koka-Kalim (o se trata de una Manifestación de Kalith o Madre Samantha), hasta una unidad de Amazonas Tribales de tu lista de ejército podrán ser Seguidoras de Kalith (+1 punto por miniatura); obtienen las reglas especiales Furia asesina y Culto de Koka-Kalim. Además, podrán tener acceso a una opción del listado de Elixires y venenos. Sin embargo, no pueden equiparse con Escudo.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="2af5-9366-daa2-561a" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
        <infoLink id="1d18-27c6-bc4f-dc8f" name="Culto de Koka-Kalim" hidden="false" targetId="1e5d-4d25-0303-76c4" type="rule"/>
      </infoLinks>
