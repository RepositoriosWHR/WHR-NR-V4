      </constraints>
      <rules>
        <rule id="8168-2b7b-ed7d-850c" name="Convicción ciega" hidden="false">
          <description>Tienen las reglas especiales Vanguardia y Odio (¡todos los enemigos!). Además, una vez por batalla podrán superar de forma automática un único chequeo de desmoralización (debes declarar esto antes de tirar los dados). </description>
        </rule>
        <rule id="f75e-9fed-51b4-fa5d" name="Destino de redención" hidden="false">
          <description>Las Redimidas de Kalith no provocan chequeos de Pánico en otras unidades de Amazonas si las atraviesan o si son destruidas.</description>
        </rule>
      </rules>
