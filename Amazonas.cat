          <selectionEntries>
            <selectionEntry id="bf72-6580-1c7b-8141" name="Energía celestial" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a634-49b6-3aaa-06ff" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="45ec-7d9b-4fd4-615e" type="max"/>
              </constraints>
              <profiles>
                <profile id="9015-db8e-d295-4388" name="Energía celestial" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">La máquina de guerra dispara como un cañón que puede estimar 0-12 dados (más el dado de artillería) Sus impactos se resuelven con Fuerza 10 y las reglas especiales Ataques flamígeros y Heridas múltiples (1D6). Adicionalmente, considera que siempre obtiene un rebote de 10&quot; (no tires el dado de artillería para calcular la distancia del rebote).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="03d7-0d11-c20d-3144" name="Ataques flamígeros" hidden="false" targetId="6985-722e-1ce4-b838" type="rule"/>
                <infoLink id="9b4d-04f3-4535-d434" name="Heridas múltiples (1D6)" hidden="false" targetId="e658-6033-5e1f-c1c4" type="rule"/>
                <infoLink id="2193-39fa-f8ae-9587" name="Cañón" hidden="false" targetId="9f6a-5d0b-f0a6-dbab" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="60.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="873e-9881-b10b-7ec2" name="Bombas divinas" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ab53-3024-247d-eb6e" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e13a-7f85-5c7e-192b" type="max"/>
              </constraints>
              <profiles>
                <profile id="a9d5-0bac-b226-7524" name="Bombas divinas" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">La máquina de guerra dispara como una catapulta tal y como se describe en el reglamento de Warhammer Reforged que realiza sus disparos con alcance de 18-72&quot;, los cuales se resuelven con Fuerza 5 utilizando la plantilla redonda grande y las reglas especiales Poder de penetración. El impacto central se resuelve con Fuerza 10 y la regla especial Heridas múltiples (1D6+1).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
