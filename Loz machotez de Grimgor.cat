      </constraints>
      <rules>
        <rule id="282f-1d1f-9cfc-d5ac" name="Guted el múziko" hidden="false">
          <description>En el turno en el que la unidad de Eeza y Guted realice una carga con éxito, ambas unidades deberán tirar 1D6 y sumar sus atributos de Liderazgo; la unidad de Eeza tendrá un bono de +1 a esta tirada por el grito de Guted. Si el resultado obtenido por la unidad enemiga es inferior al de la unidad de Eeza y Guted, la unidad enemiga quedará Apabullada hasta el final del turno.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9555-cf86-b38b-d47a" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
