              <profiles>
                <profile id="7f44-7ee7-e26f-4774" name="Manifestación de Kalith" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">Obtiene las reglas especiales Culto de Koka-Kalim, Furia asesina, Ataques envenenados y Odio (¡todos los enemigos!), así como un bonificador de +1 en sus atributos de Habilidad de Armas, Fuerza, Iniciativa y Ataques. Además, podrá repetir sus chequeos de Liderazgo fallidos. </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="d231-a8c9-6e29-201e" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
                <infoLink id="a1de-0a8e-52a5-ced8" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="6f33-5854-4056-0cfd" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
                <infoLink id="feae-e622-7b38-6791" name="Culto de Koka-Kalim" hidden="false" targetId="1e5d-4d25-0303-76c4" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="75.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="f80a-4b9b-4f43-0a8d" name="Manifestación de Rigg" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
