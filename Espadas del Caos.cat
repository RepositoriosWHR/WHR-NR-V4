        <selectionEntryGroup id="d85c-5a36-eb1b-0bfb" name="Marca del Caos" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5e77-96fb-a54e-985d" type="max"/>
