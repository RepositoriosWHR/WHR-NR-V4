    <selectionEntry id="77ac-fdba-908c-9b94" name="Ungido de Slaanesh" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2e93-f820-a661-1190" type="max"/>
      </constraints>
      <rules>
        <rule id="dd26-0acf-5ce1-c0a8" name="Magia de Ungido de Slaanesh" hidden="false">
          <description>Puede convertirse en hechicero de nivel 1 por +40 puntos, o en hechicero de nivel 2 por +70 puntos. En cualquiera de los casos, puede elegir sus hechizos de entre el Saber de Slaanesh y/o Magia Oscura.</description>
        </rule>
        <rule id="595d-8971-bde3-795b" name="Icono de Slaanesh" hidden="false">
          <description>Un Ungido de Slaanesh tiene la regla especial Tozudez. Además, si el Ungido de Slaanesh es el General del ejército, todas las unidades con la clave CULTO DEL PLACER dentro del radio de su Presencia inspiradora serán Inmunes a Psicología.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="0a5d-f3c9-d08a-8246" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule">
