      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3587-6734-3d15-e1ab" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4dea-b99e-4856-27d7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1cf5-fd5a-ecf0-ff3f" name="Estandarte sagrado de Tzeentch" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e82c-7f47-6d50-e96e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f725-58f9-bba5-dee0" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b8c-7dfd-4993-f565" name="Estandarte sagrado de Tzeentch" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Sólo miniaturas con la Marca de Tzeentch. El portador (y la unidad en la que se encuentre) obtendrán una tirada de salvación especial de 5+ contra proyectiles normales y mágicos, y una tirada de salvación especial de 6+ frente al resto de heridas que sufran. Además, al inicio de cada ronda de combate, todas las miniaturas enemigas en contacto peana con peana con el portador y su unidad sufren un impacto de F4 con la regla especial Ataques sólo flamígeros; las bajas causadas por este efecto cuentan para el resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5c25-b174-3216-6e60" name="Recompensas del Caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="roster" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eb73-07d3-f766-9a81" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5324-2467-5a40-276f" name="Muchos brazos" hidden="false" collective="false" import="true" type="upgrade">
