            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="afdf-3e86-c29a-6621" type="max"/>
          </constraints>
          <profiles>
            <profile id="0905-f3ed-47f5-6e49" name="Aplastakráneos" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadora a dos manos. Una vez por batalla, al inicio de cualquier fase de combate cuerpo a cuerpo, el portador puede desatar el poder del Aplastakráneos, lo cual le otorga un bonificador de +3 a su Fuerza (adicional al +2 por ser Rebanadora a dos manos). El bonificador dura hasta el final de la fase de combate cuerpo a cuerpo en curso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="40dc-f5ef-3d9e-7d84" name="Rebanadora a dos manos" hidden="false" targetId="045b-d3b9-e43a-5ee6" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
