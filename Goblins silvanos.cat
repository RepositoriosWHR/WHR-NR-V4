    <selectionEntry id="0540-228a-860a-4ca1" name="[Ex] - Cocatriz" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="d912-9a1e-f5fa-76b3" value="2.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="170b-06ad-215f-f891" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="d912-9a1e-f5fa-76b3" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3673-aaa8-d1d9-e6c2" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a7c9-be80-08a2-aff3" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d912-9a1e-f5fa-76b3" type="max"/>
      </constraints>
      <rules>
        <rule id="e3f5-d8f9-da81-da2f" name="Vomitar bilis" hidden="false">
          <description>Se trata de un Arma de aliento de Fuerza 2 que no permite tirada de salvación por armadura. Ten en cuenta que una Cocatriz puede usar su Arma de aliento y su Mirada petrificadora en una misma fase de disparo, aunque no al aguantar y disparar (deberá elegir en ese caso).</description>
        </rule>
        <rule id="b420-acb4-2ac2-fe24" name="Mirada petrificadora" hidden="false">
          <description>La Mirada petrificadora se considera un ataque de disparo (puede disparar incluso aunque haya marchado) con un alcance de 12” con las reglas especiales Francotirador, Disparo rápido, Ataques mágicos y Golpe letal heroico y que se resuelve con Fuerza 6, pero tira para herir contra la Iniciativa de su objetivo en vez de contra su Resistencia y no permite tirada de salvación por armadura.</description>
        </rule>
        <rule id="8ef4-99ce-d004-5ef9" name="Luchar a ciegas" hidden="false">
          <description>Todos los enemigos que ataquen a una Cocatriz en combate cuerpo a cuerpo deberán aplicar un penalizador de -1 en sus tiradas para impactar. Esta regla no afecta a miniaturas con la reglas especiales Demonio, No muerto o Etéreo, o la clave Constructo.</description>
        </rule>
        <rule id="46f7-c3ba-90b2-053a" name="Cobardía infame" hidden="false">
          <description>Pese a ser un Monstruo, una Cocatriz no es Impasible.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="57ba-59e7-5f9d-7f36" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
        <infoLink id="cd63-68ce-81b4-c5d0" name="Volar (10)" hidden="false" targetId="be56-917b-a9d5-2c76" type="rule"/>
        <infoLink id="e36a-fc7a-7b81-af2e" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
        <infoLink id="151c-43e9-d745-cf13" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
        <infoLink id="0739-58cb-cf56-7365" name="Arma de aliento" hidden="false" targetId="3438-0c27-972c-d418" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(F2, No permite salvación por armadura)"/>
          </modifiers>
        </infoLink>
