      </constraints>
      <rules>
        <rule id="ff17-8de8-ca38-2605" name="Bestias sin mente" hidden="false">
          <description>Los Engendros del Caos no pueden tomar objetivos ni cuentan nunca como unidades que puntúan en determinados escenarios, como Romper la línea o Defensa a ultranza (no puntúan ni para el jugador que los controla ni para el oponente).</description>
        </rule>
      </rules>
      <infoLinks>
