    <selectionEntry id="c8e6-957d-7d8d-2343" name="Gran oráculo eslizón" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="788b-cd95-f0a6-b9e9" name="Magia de Gran oráculo eslizón" hidden="false">
          <description>Nivel de magia 2. Puede mejorarse a nivel de magia 3 por +50 puntos. Puede elegir sus hechizos de entre los saberes de los Cielos, Luz, Bestias o Vida.</description>
