      <rules>
        <rule id="90f9-6645-2916-1a18" name="Guardia nobiliar" hidden="false">
          <description>Si la general del ejército es una Noble Amazona o una Campeona Amazona, una unidad de Guardianas Tótem de tu ejército puede obtener la regla especial Odio (¡todos los enemigos!) por +1 punto por miniatura.</description>
        </rule>
