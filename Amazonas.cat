      <constraints>
        <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="970f-431e-d8cc-bbd2" type="max"/>
      </constraints>
      <rules>
        <rule id="8114-16e2-cd1d-59e5" name="Cocopulta" hidden="false">
          <description>La Cocopulta dispara como una Catapulta con un alcance de 6-30”, utiliza la plantilla redonda pequeña y sus impactos se resuelven con F3 y la regla especial Poder de penetración; no tiene impacto central diferenciado.</description>
        </rule>
        <rule id="7aa0-b5af-f8ca-a8e4" name="Elemento de guerra natural" hidden="false">
          <description>La Cocopulta tiene 360º de línea de visión para realizar sus disparos. Sin embargo, no podrán ser desplegadas en Edificios ni mover durante la batalla.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="386c-7e00-3f05-a4df" name="Máquina de guerra" hidden="false" targetId="48ca-c3bc-f385-15fc" type="rule"/>
