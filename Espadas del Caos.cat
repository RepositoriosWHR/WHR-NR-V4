          </constraints>
          <rules>
            <rule id="5410-215a-034f-7fc8" name="Marca de Nurgle. Feytor el Corrupto" hidden="false">
              <description>Feytor porta la Marca de Nurgle, lo que le otorga las reglas especiales Ataques envenenados e Inmune a veneno, los enemigos tienen un penalizador de -1 para impactarle con proyectiles y los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="aec8-c889-b55c-9322" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="cd93-26f4-9115-1f7f" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
          </infoLinks>
