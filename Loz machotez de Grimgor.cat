      </constraints>
      <rules>
        <rule id="eb50-3142-5949-425c" name="Antorchas" hidden="false">
          <description>Todos los ataques y disparos realizados por los Incurzorez 
orcoz tienen la regla especial Ataques flamígeros.</description>
        </rule>
        <rule id="4fad-b954-b964-1bd2" name="Ezzpertoz zalteadorez" hidden="false">
          <description>Tienen la regla especial Disparo rápido.</description>
        </rule>
