      <rules>
        <rule id="2fb4-a863-143e-1e6e" name="Carente de Escrúpulos" hidden="false">
          <description>Theophilus y la unidad que se encuentre podrán repetir todos sus chequeos fallidos de Liderazgo.</description>
        </rule>
        <rule id="67d1-e6d8-2354-2f07" name="Incorruptible" hidden="false">
          <description>Theophilus y la unidad de Sombreros Negros en la que sea desplegado al inicio de la batalla obtienen la regla especial Odio (¡todos los enemigos!).</description>
        </rule>
      </rules>
