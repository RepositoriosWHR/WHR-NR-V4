                  <profiles>
                    <profile id="2fc5-e5e5-1256-d798" name="Vara celestial" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">Arma a dos manos. Puede guardar hasta dos Dados de magia que podrá utilizar en una fase de magia posterior. Además, mientras mantenga dos Dados de magia almacenados en la vara, el Taumaturgo zoat obtendrá un bonificador de +1 en sus tiradas de dispersión contra hechizos de los Saberes del Viento de magia oscura.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
