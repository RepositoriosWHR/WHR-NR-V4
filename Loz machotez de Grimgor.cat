              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadoras emparejadas. El portador obtiene Furia asesina y sus ataques se resuelven con un bonificador de +1 en sus tiradas para impactar y las reglas especiales Poder de penetración y Ataques flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
