        <infoLink id="ab01-9b8b-4699-c51f" name="Golpe letal" hidden="false" targetId="9f1c-d301-bd0e-af81" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Luchar sucio)"/>
          </modifiers>
