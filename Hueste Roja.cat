      <constraints>
        <constraint field="selections" scope="parent" value="2.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="08ee-0307-9176-9dda" type="max"/>
      </constraints>
      <rules>
        <rule id="b396-b774-31ac-58ca" name="Dotación del castillo Estegadón" hidden="false">
          <description>El Estegadón está tripulado por una dotación de al menos 4 Eslizones, aunque se consideran una única miniatura. En cuerpo a cuerpo, el Estegadón y la dotación pueden atacar con normalidad a cualquier miniatura en contacto peana con peana. Todos los impactos se resuelven utilizando la Resistencia, Heridas y tirada de salvación del 
Estegadón. Usa la HP de la dotación para resolver los ataques de disparo. Su Potencia de unidad es de 10 con un bonificador de +1 por cada Eslizón adicional.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="0644-5eba-a24d-bdac" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
        <infoLink id="c417-7c4a-e308-4615" name="Piel escamosa (3+)" hidden="false" targetId="f3fe-4c6e-197e-832f" type="rule"/>
