                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El personaje obtiene la regla especial Resistencia mágica (2). Además, todas las unidades enemigas en contacto peana con peana con Netrak obtendrán un penalizador de -1 a su Liderazgo.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="8c97-7d13-e253-d6a0" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
