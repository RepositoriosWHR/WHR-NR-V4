    <selectionEntry id="72c0-343e-ffd0-1934" name="[R] - Comehombres de Golgfag" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5b6b-394b-428e-52e3" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8238-4917-f880-bbf6" type="max"/>
      </constraints>
      <rules>
        <rule id="df2e-71b0-9945-4e10" name="El Comehombres" hidden="false">
          <description>Si Golgfag mata a un personaje enemigo en un desafío de las categorías Infantería, Caballería o Bestia, todas las unidades enemigas participando en el mismo combate quedarán Apabulladas hasta el final del turno.</description>
        </rule>
        <rule id="0450-6924-b23a-1dea" name="Como vienen, se van" hidden="false">
          <description>Al inicio de la batalla, antes del despliegue, tira 2D6 y multiplica el resultado por 10: puedes elegir inmediatamente para Golgfag esa cantidad de puntos en objetos mágicos para la batalla y/o un estandarte mágico de hasta 50 puntos para Skaff. Puedes elegir los objetos mágicos que desees del reglamento de Warhammer Reforged y/o del libro de ejército de Ogros o Mercenarios, pudiendo elegir si lo deseas (y te alcanzan los puntos) más de 3 objetos mágicos, o más de una reliquia. Sin embargo, no podrás elegir más de un objeto mágico de cada categoría (Arma mágica, Armadura mágica, Objeto hechizado y Talismán; Golgfag no puede elegir estandartes mágicos ni artefactos arcanos).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="c62c-456e-a8b7-32e3" name="Infantería monstruosa" hidden="false" targetId="4958-70de-0b69-9825" type="rule"/>
        <infoLink id="232a-03a9-9fc1-ce3f" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
        <infoLink id="7e10-435a-e2eb-fa75" name="Carga devastadora" hidden="false" targetId="dbe6-c910-7f37-aeac" type="rule"/>
        <infoLink id="8aed-5a1e-ae21-7ffa" name="Vanguardia" hidden="false" targetId="1bd0-0982-01a3-ed62" type="rule"/>
        <infoLink id="0348-99c6-fa21-f2cd" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Golgfag)"/>
          </modifiers>
        </infoLink>
        <infoLink id="6582-e057-7737-855f" name="Inmune a la psicología" hidden="false" targetId="73ad-8cdb-f1ad-010f" type="rule"/>
        <infoLink id="5e2c-b3a1-affa-b1bc" name="Mercenario" hidden="false" targetId="f693-0c5c-49bd-91e7" type="rule"/>
