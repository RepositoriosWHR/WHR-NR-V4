          <profiles>
            <profile id="3b9c-3ac0-c8ca-001e" name="Maza tronante" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Sólo humanos. Arma de mano. Los ataques realizados con este arma se resuelven con un bonificador de +1 Fuerza y la regla especial Ataque de rayos.</characteristic>
