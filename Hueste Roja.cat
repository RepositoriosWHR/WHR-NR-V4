          <profiles>
            <profile id="9148-6055-801e-3350" name="Pendones de sangre caliente" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Solo Infantería. La unidad obtendrá la regla especial Furia asesina y no la podrá perder como resultado de perder un combate. Sin embargo, no podrá aplicar la regla especial Sangre fría mientras conserve este estandarte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6b43-ab1b-8b84-1c83" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
          </infoLinks>
