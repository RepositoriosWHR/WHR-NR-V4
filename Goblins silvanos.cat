                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Proporcionan a Gorblum una tirada de salvación especial de 5+ y Resistencia mágica (1). Además, todos los enemigos que ataquen a Gorblum en combate cuerpo a cuerpo tendrán un penalizador de -1 en sus tiradas para impactar.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="40ea-83de-e295-243a" name="Resistencia mágica (1)" hidden="false" targetId="eae7-760e-1a1e-47d7" type="rule"/>
