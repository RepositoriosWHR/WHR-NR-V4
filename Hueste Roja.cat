                <characteristic name="TSE" typeId="576172645361766523232344415441232323"/>
                <characteristic name="Tipo" typeId="5479706523232344415441232323">Infantería monstruosa</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="0222-4fad-945a-2f56" name="Kroxigores" hidden="false">
              <description>La unidad puede incluir hasta 3 Kroxigores equipados con Arma a dos manos a un coste de 52 puntos cada uno. Los Kroxigores se colocan en la segunda fila y pueden atacar a través de una fila de eslizones con todos sus ataques; sin embargo, los Kroxigores podrán ser atacados por el enemigo como si estuvieran en primera fila. Las unidades de Guerreros eslizón podrán utilizar el liderazgo de los Kroxigores.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="2a7c-3071-791e-e317" name="Infantería monstruosa" hidden="false" targetId="4958-70de-0b69-9825" type="rule"/>
            <infoLink id="24ac-af25-3420-6eef" name="Piel escamosa (4+)" hidden="false" targetId="478f-4519-03d3-5004" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Kroxigores)"/>
              </modifiers>
            </infoLink>
            <infoLink id="731b-625f-1716-b7ba" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule">
