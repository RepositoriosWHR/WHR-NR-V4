          </constraints>
          <selectionEntries>
            <selectionEntry id="295f-72b9-a78b-476d" name="Daga Ceremonial del Sacrificio" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dce1-dd02-e9bb-95bb" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f1f9-13fb-70e6-c2de" type="min"/>
              </constraints>
              <profiles>
                <profile id="5b0b-06b6-c990-cee7" name="Daga Ceremonial del Sacrificio" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Tiene la regla especial Poder de penetración. Los ataques realizados con esta arma tendrán un bonificador de +1 en sus tiradas para impactar y para herir. Por cada herida causada con esta arma en combate cuerpo a cuerpo, generará un dado de energía o dispersión para la siguiente fase de magia que sólo Xiuhcoatl podrá utilizar. </characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="83db-c774-447c-a264" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
                <infoLink id="4649-5f3c-e404-e90e" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
              </infoLinks>
