            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="391b-7959-0347-a688" type="max"/>
          </constraints>
          <profiles>
            <profile id="ec4c-7a15-bedc-03a9" name="Raíces estranguladoras" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Cualquier enemigo que ataque a este espíritu del bosque perderá todos los bonos de Iniciativa por cargar. Además, cualquier miniatura enemiga en contacto peana con peana con el personaje al inicio de cualquier fase de combate cuerpo a cuerpo sufre un impacto automático de Fuerza 3 con la regla especial Poder de penetración.</characteristic>
              </characteristics>
