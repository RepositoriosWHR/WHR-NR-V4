    <selectionEntry id="76c7-0538-c2ec-0699" name="Insectos de la jungla" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="increment" field="10bb-4758-3e4c-6dc4" value="1.0">
          <repeats>
            <repeat field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="614d-bf3c-8921-4b1d" repeats="1" roundUp="false"/>
          </repeats>
