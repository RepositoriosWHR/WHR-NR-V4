    <selectionEntry id="505c-1c96-aa36-797c" name="[E] - Kolmillonegro" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true"/>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c217-4eac-054e-9b88" type="max"/>
      </constraints>
      <rules>
        <rule id="c30f-983f-299f-f417" name="Magia de Kolmillonegro" hidden="false">
          <description>Kolmillonegro es un hechicero de nivel 4 que utiliza hechizos del Saber de Magia Oscura.</description>
        </rule>
        <rule id="d3f9-c1f7-7197-fd11" name="Henchido de poder" hidden="false">
          <description>Kolmillonegro no tiene la regla especial Kanalización verde de otros chamanes orcos. Además, Kolmillonegro tiene un bonificador de +2 a todas sus tiradas para Canalizar.</description>
        </rule>
        <rule id="3039-36ca-cd30-b30f" name="Kolmillonegro zi ke zurra bien" hidden="false">
          <description>Kolmillonegro tiene la regla especial ¡Ni un paso atrás!, que afecta a todas las unidades de orcos a 18” o menos de Kolmillonegro.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="ed75-26ca-392e-a41e" name="Loz mejorez" hidden="false" targetId="2adc-ff6a-d16d-e5e3" type="rule"/>
        <infoLink id="dc30-08ca-3fdd-f67e" name="Inmune a la psicología" hidden="false" targetId="73ad-8cdb-f1ad-010f" type="rule"/>
        <infoLink id="0b84-5f04-2e9a-8b0b" name="Ni un paso atrás" hidden="false" targetId="f76e-5a01-1c6b-ef76" type="rule"/>
        <infoLink id="9a69-52d2-3786-ba6d" name="Piel escamosa (6+)" hidden="false" targetId="1d04-d136-a7a6-eb68" type="rule"/>
