            <profile id="e117-c357-1517-7880" name="Estandarte sagrado de Slaanesh" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Sólo miniaturas con la Marca de Slaanesh. El portador y su unidad duplican su Iniciativa. </characteristic>
              </characteristics>
