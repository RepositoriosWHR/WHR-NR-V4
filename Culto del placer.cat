            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="4d99-dc86-281e-51e7" type="max"/>
          </constraints>
          <profiles>
            <profile id="4c32-36da-377f-5727" name="Indiferencia sádica" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">El demonio y cualquier unidad a la que se una obtienen la regla especial Indesmoralizables. Esto sustituye su regla habitual de Inestabilidad.</characteristic>
