          <selectionEntries>
            <selectionEntry id="88f7-237e-6be3-d58a" name="Culebrina" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="031e-c706-fcfe-22ce" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bd22-609c-1307-57ab" type="min"/>
              </constraints>
              <rules>
                <rule id="9569-b345-bd2c-1fb0" name="Culebrina" hidden="false">
                  <description>La Culebrina dispara como un Cañón, con la diferencia de que puede estimar un total de 0-8 dados (más el dado de artillería), tiene Fuerza 7 y sus disparos se resuelven con la regla especial Heridas múltiples (1D3). La Culebrina usa la tabla de problemas del Cañón. </description>
                </rule>
