    <selectionEntry id="f7bd-05c2-5e9a-f67b" name="[E] - Xiuhcoatl, Profeta de Sotek" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4dba-a9e2-78da-98e7" type="max"/>
      </constraints>
      <rules>
        <rule id="8ea4-4848-8312-84c7" name="Magia de Xiuhcoatl" hidden="false">
          <description>Xiuhcoatl es un hechicero de nivel 3 que toma sus hechizos del Saber de la Vida.</description>
        </rule>
        <rule id="9ed3-3c8e-27ef-c31c" name="Guardián de Quetza" hidden="false">
          <description>Xiucoatl es inmune a los efectos de la regla del saber del Saber de Nurgle. Además, si incluyes a Xiuhcoatl en tu lista de ejército, puedes desplegarlo junto a una unidad de Eslizones pertenecientes al Desove sagrado de Sotek; esa unidad será inmune a los efectos de la regla del saber de Plaga Skaven. Adicionalmente, si Xiucoatl es el general del ejército, Otorgará este beneficio a 1D3 unidades adicionales de Eslizones (de cualquier tipo).</description>
        </rule>
        <rule id="cedb-24a4-549b-34db" name="Archienemigo Xiuhcoatl, profeta de Sotek" hidden="false">
          <description>Si tu ejército incluye a Xiuhcoatl y el ejército enemigo incluye al Vidente Gris Thanquol, obtendrás 100 puntos de victoria adicionales si lo eliminas. Sin embargo, si los Skaven logran eliminar a Xiuhcoatl, el enemigo obtendrá 100 puntos de victoria adicionales.</description>
        </rule>
        <rule id="c330-d7ed-4722-b343" name="La Tutela del Señor Tlaco" hidden="false">
          <description>Xiuhcoatl tiene laregla especial Resistencia a la magia (2) y una tirada de salvación especial de 5+.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="7d8e-b7d2-66ca-1ba0" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="b027-aaf9-b0d0-55c9" name="Cresta roja" hidden="false" targetId="122b-22c5-2a3b-9892" type="rule"/>
        <infoLink id="1709-0fd3-c6cb-eb53" name="Sangre fría" hidden="false" targetId="fae6-f2eb-1a70-1084" type="rule"/>
        <infoLink id="ecc0-ab64-b6d1-3654" name="Cruzar (Elementos acuáticos)" hidden="false" targetId="3043-3cbd-459e-ab48" type="rule"/>
        <infoLink id="9a01-7c93-ef1b-80ad" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
        <infoLink id="4d95-5444-de9a-6ac6" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
        <infoLink id="0834-a691-badb-263c" name="Archienemigo" hidden="false" targetId="837a-4a9a-7d71-e8fe" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Vidente Gris Thanquol)"/>
          </modifiers>
        </infoLink>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="84e0-e699-192d-cfff" name="Comandantes" hidden="false" targetId="4c6f72647323232344415441232323" primary="true"/>
