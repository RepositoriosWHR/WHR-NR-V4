    <selectionEntry id="34b7-bb80-d794-561a" name="[E] - Coeddil, el Astuto" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d410-6ef8-b18e-89cb" type="max"/>
      </constraints>
      <rules>
        <rule id="f7d6-0409-dd10-5dcf" name="Magia de Coeddil, el Astuto" hidden="false">
          <description>Coeddil, el Astuto es un hechicero de nivel de magia 3 que puede escoger sus hechizos de entre el Saber de las Bestias o el Saber de las Sombras.</description>
        </rule>
        <rule id="02c6-a6c4-5838-bcb5" name="Furia del Bosque Ancestral" hidden="false">
          <description>Todas las unidades unidad de Espíritus del bosque de tu ejército a 12” o menos de Coeddil obtendrán la regla especial Odio (¡todos los enemigos!) hasta el final de ese turno de jugador.</description>
        </rule>
        <rule id="4afe-fe9d-ed93-d6e8" name="Venganza de las Raíces" hidden="false">
          <description>Las tiradas para impactar en combate cuerpo contra Coeddil aplicarán un penalizador de -1. Además, por cada resultado natural de 1 que obtengan los enemigos en sus tiradas para impactar sufrirán un impacto automático de F4.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="5dc1-e268-1b8f-659e" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
