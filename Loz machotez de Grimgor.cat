          <profiles>
            <profile id="677a-fa66-a3d2-2fc1" name="Zúper-rebanadora del gran waaaagh!" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadora. Al atacar con este arma el portador obtiene un bonificador de +1 a sus atributos de Fuerza y Ataques igual al modificador por filas de la unidad en la que esté incluido.</characteristic>
