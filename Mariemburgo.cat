    <selectionEntryGroup id="96c3-512f-d978-7c6c" name="Armaduras mágicas. Ogras. Reliquias" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4631-6d03-1e0d-999d" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6914-d0b5-4d0f-9031" name="Armadura de las Fauces" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="eb8e-4983-16d6-b0a7" name="Armadura de las Fauces" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura pesada. El portador obtiene la regla especial Regeneración (4+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e0b8-ff4d-c10d-d39b" name="Regeneración (4+)" hidden="false" targetId="6605-7689-3444-dccd" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="6b4f-becc-e8d7-5625" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="02c1-bf30-51df-f5e9" name="Puño Codicioso" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="ec00-856e-ec96-a6a7" name="Puño Codicioso" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Puño ogro. El portador obtiene una tirada de salvación especial de 5+. Si el portador salva una o más heridas causadas por un Arma mágica con esta salvación especial, el Arma mágica quedará destruida y pasará a considerarse un arma mundana de su mismo tipo. Un hechicero herido por el Puño codicioso debe tirar 1D6 al final de la fase de combate cuerpo a cuerpo en la que fue herido: si obtiene un resultado superior, perderá inmediatamente un nivel de magia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="85fd-bd2d-b008-da16" name="Puño de Hierro" hidden="false">
              <description>Al inicio de cada combate la unidad decidirá si los usa como escudo o como una maza ogra como arma de mano adicional. Si se utiliza como escudo puede usarse Parada.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="2489-5139-f920-b0c8" name="Parada" hidden="false" targetId="9d92-3851-6695-cf71" type="rule"/>
            <infoLink id="309b-eabb-5726-f3c8" name="Puño de hierro" hidden="false" targetId="de57-9e6a-9339-f60f" type="profile"/>
          </infoLinks>
          <entryLinks>
