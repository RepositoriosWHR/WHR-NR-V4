                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura del caos. La armadura perdida de Hotek otorga una tirada de Salvación por armadura de 3+. Todas las tiradas exitosas para herir contra Netrak deberán repetirse.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
