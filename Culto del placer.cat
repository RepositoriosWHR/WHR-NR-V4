        <selectionEntry id="fbea-afcb-2246-cada" name="Armadura Ungida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ac1b-dfb2-ebd4-ee36" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3d2b-e6b8-8c29-8191" type="max"/>
          </constraints>
          <profiles>
            <profile id="8888-0983-1df2-b758" name="Armadura Ungida" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura del Caos. Proporciona a su portador un bonificador de +1 a su tirada de salvación por armadura, y una tirada de salvación especial de 4+.</characteristic>
              </characteristics>
