      <rules>
        <rule id="9589-7314-2bcc-677d" name="Magia Zizzik" hidden="false">
          <description>Zizzik es un hechicero de nivel 4 que conoce todos los hechizos del Pequeño Waaagh! (Zizzik es un chamán goblin silvano).</description>
        </rule>
        <rule id="2ff2-a21c-9373-0440" name="Devoción aráknida" hidden="false">
          <description>Zizzik y todas las unidades amigas a 18” o menos de él obtienen la regla especial Resistencia mágica (2).</description>
        </rule>
      </rules>
