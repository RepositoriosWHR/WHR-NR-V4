        <selectionEntry id="78fb-56c2-859d-b0d8" name="Desbrozadora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ef68-9ccc-b71e-ff18" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="800c-7ef4-3a13-a058" type="max"/>
          </constraints>
          <profiles>
            <profile id="1ace-187c-d839-9ad0" name="Desbrozadora" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Sólo humanos. Arma de mano. Los ataques realizados con esta arma se resuelven con la regla especial Poder de penetración. Además, siempre que la portadora cause una o más heridas a una miniatura durante una misma fase de combate, tira 1D6; con un resultado de 4+, la miniatura herida sufrirá un penalizador de -1 a su tirada de salvación por armadura por el resto de la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="dffe-0715-c12a-d669" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cce3-053f-4942-7e48" name="Maza tronante" hidden="false" collective="false" import="true" type="upgrade">
