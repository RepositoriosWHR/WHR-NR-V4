    <profile id="67d7-ecd7-e79b-b6a2" name="Armadura de gromril" hidden="false" typeId="41726d6f757223232344415441232323" typeName="Armadura">
      <characteristics>
        <characteristic name="Salvación" typeId="536176696e67205468726f77206d6f64696669657223232344415441232323">4+</characteristic>
        <characteristic name="Reglas especiales" typeId="5370656369616c2052756c657323232344415441232323">Otorga una tirada de salvación por armadura de 4+. Además, estas armaduras son tan resistentes que su portador será inmune al efecto de la regla especial Poder de penetración.</characteristic>
