            <selectionEntry id="e579-0870-48de-de10" name="Matareyes" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5e5b-a122-f118-0f71" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0111-719b-dcd5-c5cd" type="min"/>
              </constraints>
              <profiles>
                <profile id="696c-c0bd-192d-dde1" name="Matareyes" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los impactos causados por Matarreyes no permiten tirada de salvación por armadura. Al inicio de cualquier fase de combate cuerpo a cuerpo, Archaón puede liberar el poder del demonio en el interior de la espada: a partir de entonces, duplica el número de Ataques que realiza, pero todos los resultados de 1 en sus tiradas para impactar se resolverán contra el propio Archaón o uno de sus Espadas del Caos (a tu elección).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="a16d-4083-5113-ca87" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
              </infoLinks>
