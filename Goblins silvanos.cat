        <selectionEntry id="a7b3-bbed-a67c-7005" name="Equipo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="018b-5e91-69a2-0b32" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a126-e756-8df1-6a62" type="min"/>
          </constraints>
          <selectionEntries>
