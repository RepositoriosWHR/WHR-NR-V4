      </constraints>
      <selectionEntries>
        <selectionEntry id="8d74-5d34-7ab1-1869" name="Rapidez de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4cbe-9d07-ac51-4b08" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b335-f62b-f6c6-f72c" type="max"/>
          </constraints>
          <profiles>
            <profile id="f1bf-9e53-1fb3-2405" name="Rapidez de Slaanesh" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje duplica su atributo de Iniciativa, hasta un máximo de 10.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ba9e-0d0a-a9c9-e463" name="Almizcle soporífero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5097-6788-cf31-b457" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="437b-876e-69c6-4339" type="max"/>
          </constraints>
          <profiles>
            <profile id="9ec1-ba28-e46c-2052" name="Almizcle soporífero" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Todas las miniaturas enemigas en contacto peana con peana con el personaje verán su Habilidad de armas e Iniciativa reducidas a la mitad (redondeando fracciones hacia arriba).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="63f8-0255-5cc4-2f5d" name="Mirada de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a712-5dc5-ea9b-d384" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="80b1-d460-1fa5-07b5" type="max"/>
          </constraints>
          <profiles>
            <profile id="ba6a-bc0c-6047-ca54" name="Mirada de Slaanesh" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Al inicio de cada ronda de combate cuerpo a cuerpo, elige una miniatura enemiga en contacto peana con peana con el personaje; tendrá -1 Ataque en esa ronda de cuerpo a cuerpo (con un mínimo de 1 Ataque).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="bd79-2e57-a9af-44e2" name="Fascinación de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fca4-8c11-bc8c-5e1f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="19bf-a39c-d2ca-22fa" type="max"/>
          </constraints>
          <profiles>
            <profile id="2558-8ec2-f378-e065" name="Fascinación de Slaanesh" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Todos los ataques cuerpo a cuerpo contra el personaje tendrán un penalizador de -1 en su tirada para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="44db-3a90-867e-0c34" name="Don de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a26-5303-bacd-ad33" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d4d2-6160-5f9d-de06" type="max"/>
          </constraints>
          <profiles>
            <profile id="eb55-eddb-f70e-6cbe" name="Don de Slaanesh" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje puede realizar dos ataques adicionales en combate cuerpo a cuerpo, que se resolverán con su valor de Fuerza. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="df1a-68c2-ad6f-bbe7" name="Reflejos sobrenaturales" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="796a-a136-9b25-5cd1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0146-e2a8-4bb3-e25b" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f26-71d5-fd3e-34df" name="Reflejos sobrenaturales" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene la regla especial Esquivar (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d857-9ed0-4a7e-6bf9" name="Esquivar (5+)" hidden="false" targetId="053b-3b96-b53b-6944" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1b08-e9ef-a0e5-42eb" name="Recompensas del Caos. Tzeentch" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="roster" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="911d-9f31-0bbf-5c9f" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f1c6-85b4-93e6-fd25" name="Fortuna de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2c22-a877-27e1-a41e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="96af-1232-b315-160d" type="max"/>
          </constraints>
          <profiles>
            <profile id="d3bf-78d3-9168-2e86" name="Fortuna de Tzeentch" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Una vez por turno de jugador, el Paladín puede repetir una tirada de 1D6. Puede ser una tirada para impactar, herir, salvación (por armadura o especial) o un chequeo de atributo (excepto de Liderazgo).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a952-0d20-d04e-1a65" name="Voluntad de Tzeench" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e4d-d9dd-ec67-ec88" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a6e0-a261-c456-788f" type="max"/>
          </constraints>
          <profiles>
            <profile id="2993-f44c-f416-daa1" name="Voluntad de Tzeench" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje genera un dado de Energía adicional en cada fase de magia propia, que puede ser utilizado por cualquier personaje con la Marca de Tzeentch.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f522-fa2c-7069-7123" name="Ojo de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f7e4-86c2-1608-71ff" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dc08-2927-9499-d8d1" type="max"/>
          </constraints>
          <profiles>
            <profile id="da90-e2fd-1fa8-9a54" name="Ojo de Tzeentch" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje podrá repetir todas sus tiradas fallidas para impactar, tanto en combate cuerpo a cuerpo como con proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3a1c-39fa-2957-c3dd" name="Aura mágica de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2096-df11-f80b-2803" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3f58-760c-9bb4-2bcd" type="max"/>
          </constraints>
          <profiles>
            <profile id="f3c0-3a92-e545-2e5f" name="Aura mágica de Tzeentch" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Sólo miniaturas con la Marca de Tzeentch. El personaje obtiene una tirada de salvación especial de 6+ y la regla especial Resistencia mágica (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a144-4981-e547-6015" name="Resistencia mágica (1)" hidden="false" targetId="eae7-760e-1a1e-47d7" type="rule"/>
          </infoLinks>
          <costs>
