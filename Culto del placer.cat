          <profiles>
            <profile id="61ea-8043-43ca-4073" name="Alabarda drenadora" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Alabarda. Sus impactos se resuelven con la regla especial Poder de penetración. Al final de cada ronda de combate cuerpo a cuerpo en la que el personaje haya causado una o más heridas con este arma, puede recuperar una herida que hubiese sufrido previamente durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bb0a-4918-95c0-c1b3" name="Alabarda" hidden="false" targetId="8dd0-8d9d-2436-cbf1" type="profile"/>
            <infoLink id="4ebb-16dc-97a3-bb22" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
