          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a2c5-1fec-9f54-e49d" name="Coordinación felina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="0e39-3321-97e4-e1d6" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="a4c5-ca43-e3af-d945" type="max"/>
          </constraints>
          <profiles>
            <profile id="c996-0125-d7ec-007f" name="Coordinación felina" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje obtiene un bonificador de +1 a su Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ce16-0f22-1dd6-6a16" name="Capitán veterano" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a2b9-97ef-140c-d157" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="a3ee-39be-2c88-6ba1" type="max"/>
          </constraints>
          <profiles>
            <profile id="e96a-d40b-95df-af83" name="Capitán veterano" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje será Inmune a pánico. Además, el personaje cuenta como si fuese una unidad de Piqueros o Infantería ligera a la hora de incluir una unidad de Infantería pesada en tu ejército.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3e40-0620-ced5-5345" name="Inmune al pánico" hidden="false" targetId="06f4-bd6a-c34d-baed" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="33be-f2e0-d50d-b2ac" name="Viejo Lobo de Mar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d296-ce59-c9e5-8cf5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="d389-e464-b5f8-ff91" type="max"/>
          </constraints>
          <profiles>
            <profile id="0e21-b2bc-8b9c-887b" name="Viejo Lobo de Mar" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El guerrero obtiene la regla especial Odio (¡todos los enemigos!).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a87d-db92-e003-3e47" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="897e-ae93-66c9-db3d" name="Pasado pirata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="c859-b73a-162e-3052" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="7e4d-95b6-8be2-1b16" type="max"/>
          </constraints>
          <profiles>
            <profile id="7cf3-7c29-93b9-5ccc" name="Pasado pirata" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje no puede incluirse dentro de unidades con la regla especial Ley y orden, dichas unidades tampoco podrán utilizar el liderazgo de una miniatura con este renombre. El guerrero obtiene la regla especial Inmune a Miedo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="313f-b164-aa34-b334" name="Inmune al miedo" hidden="false" targetId="9dea-6e2e-9d06-f5f7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="-10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="37fe-21ca-4c41-428a" name="Bendecido por Handrich" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="2f7f-78bc-a724-5032" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="173b-d4a4-686f-20fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="16c1-9e83-ea42-7dc5" name="Bendecido por Handrich" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje y la Unidad en la que se encuentre obtendrán la regla Tirada de salvación especial 6+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5f56-fc8b-e3c3-4986" name="Renombres. General" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="2edb-bd73-96cd-842c" name="Detestable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e002-2d01-402b-ef1c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="1dae-6d44-0c8b-506c" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a2e-0a3f-0e2d-2e8b" name="Detestable" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje ve reducido el radio de la regla Presencia inspiradora a 6”. Las unidades de su ejército no deberán chequear pánico si es retirado como baja. Ten en cuenta que el coste es negativo (es decir, hace al personaje más barato)</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="-15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9e82-7d26-fa7c-3e86" name="Estratega" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6123-a6d7-5660-a117" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="4ff9-2adf-86e0-eef0" type="max"/>
          </constraints>
          <profiles>
            <profile id="35d2-e45e-6169-42bf" name="Estratega" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje y la unidad en la que forma parte puede realizar un chequeo de Liderazgo cuando declara &quot;Aguantar&quot; una carga (no aguantar y disparar). Si supera el chequeo, podrá reorganizarse gratuitamente. No puede utilizar esta habilidad si está trabado en combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="baa2-cad2-0d45-9057" name="Respetado en Marienburgo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="12b4-37ee-9ff0-8345" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="d92a-c937-fe7a-a330" type="max"/>
          </constraints>
          <profiles>
            <profile id="1f3b-2cda-79ab-07fc" name="Respetado en Marienburgo" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Sólo general del ejército. Todas las unidades del ejército de Marienburgo podrán beneficiarse de la regla Presencia Inspirador del general independientemente de si tienen la regla Mercenario o no la tienen. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ae17-932c-bcbf-4b4f" name="Renombres. Comodoro" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="81f6-dcaa-cbce-1321" name="Viejo perro de la guerra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1135-403d-0a6d-8200" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="8854-1080-79be-615c" type="max"/>
          </constraints>
          <profiles>
            <profile id="9857-ce0f-e34c-858a" name="Viejo perro de la guerra" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Comodoro. El personaje y la unidad en la que se encuentre obtienen la regla especial Tozudez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e9de-a8a6-4d45-ce73" name="Respetado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1d40-5988-510a-f8a5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="e512-a900-709c-69d5" type="max"/>
          </constraints>
          <profiles>
            <profile id="b1ca-c4ae-9d7e-71ee" name="Respetado" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Comodoro. Un sólo uso, puede utilizarse al inicio de cualquier fase. Todas las unidades aliadas situadas a 12” o menos que se encontrasen huyendo se reagruparán automáticamente. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="53bb-ca24-8fcc-3bec" name="Renombres. No general" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="f3fd-4cc3-7902-28b7" name="Contrabandista" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="fb5d-f499-8442-4f0a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="996c-e5f5-dda2-fc11" type="max"/>
          </constraints>
          <profiles>
            <profile id="be36-eec1-d3fc-1b30" name="Contrabandista" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Otorga al personaje y a la unidad junto a la que sen incluya la regla especial Explorador. Solamente las unidades de tipo Infantería con potencia de unidad 15 o inferior pueden beneficiarse de esta regla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3ea0-f1e4-43cf-03da" name="Exploradores" hidden="false" targetId="462e-27b4-5c07-747d" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8dcb-98f8-57a3-f8a8" name="Reservado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d9cd-c0e9-de9f-7347" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="347a-4429-048a-bdaa" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a96-b1ac-e1f9-ded5" name="Reservado" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje no puede otorgar su Liderazgo a ninguna unidad, teniendo que chequear con el L de la propia unidad en caso de que fuera más bajo que el del personaje. El personaje obtiene +1 Ataque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3e47-6a0b-867e-67cc" name="Devoto de Manann" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1141-e458-d3b4-901a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="a0cd-ca6a-ebb4-99c9" type="max"/>
          </constraints>
          <profiles>
            <profile id="3c2f-43ab-01d4-b4b1" name="Devoto de Manann" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El personaje obtiene la regla especial Bendición de Manann.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1fc5-3182-6f90-e9a8" name="Bendición de Manann" hidden="false" targetId="2976-37cb-1828-985e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5db5-a009-c5d8-b82e" name="Renombres. Caballo de guerra con barda" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="5af1-980e-9d7e-00c2" name="Antiguo caballero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1a79-3077-e321-4454" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="94a2-1482-6e66-89f8" type="max"/>
          </constraints>
          <profiles>
            <profile id="5b91-0639-5dfc-8cc6" name="Antiguo caballero" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Puedes elegir una unidad de Caballería pesada como opción de Unidad básica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0b46-ea44-c5be-0a2e" name="Armas mágicas. Mariemburgo. Ballesta" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3ac9-3798-927e-1c1d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2f45-2500-61d3-40ae" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1ee7-cfb4-10de-7f6f" name="Ensartaenemigos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="611d-efd6-de5a-4fd4" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="745c-3bd9-5297-d7ec" type="max"/>
          </constraints>
          <profiles>
            <profile id="2854-1dfe-dbed-30e6" name="Ensartaenemigos" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Ballesta. Los impactos de Ensartaenemigos se resuelven con F6 y la regla especial Heridas múltiples (1D3). Además, las heridas causadas por esta arma no permiten tiradas de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="de04-aa57-f6b7-48f0" name="Ballesta" hidden="false" targetId="7d35-d565-a8bb-fdc6" type="profile"/>
            <infoLink id="bb79-49e0-004a-de62" name="Arma de mano adicional" hidden="false" targetId="45d0-c304-d4fd-5b8f" type="profile"/>
            <infoLink id="383b-d309-ed0c-621c" name="Heridas múltiples (1D3)" hidden="false" targetId="efc4-703c-5d20-0686" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f403-d0bd-7c7f-a1ce" name="Armaduras mágicas. Mariemburgo. Armadura ligera" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f1a5-7f73-b22e-e53c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0cf-19ca-79eb-a689" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fffe-b8cc-c867-827e" name="Armadura de Dragón Marino" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6e50-62ca-c4c7-517c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7b0c-b468-e82b-c521" type="max"/>
          </constraints>
          <profiles>
            <profile id="86fb-8b8b-4fba-3cac" name="Armadura de Dragón Marino" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura ligera. Proporciona a su portador la regla especial Piel escamosa (5+). Además el portador obtendrá la regla Cruzar (todos los tipos de terreno excepto Edificios e Intransitables).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f1a1-5861-112b-9e79" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
            <infoLink id="9145-6c3c-6e96-ad0d" name="Armadura ligera" hidden="false" targetId="44f2-32d5-23eb-62f5" type="profile"/>
            <infoLink id="de6b-37a8-f63c-1096" name="Cruzar" hidden="false" targetId="7ea4-f7e1-7e21-9266" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(todos los tipos de terreno excepto Edificios e Intransitables)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4d67-b2ec-883e-82d0" name="Armaduras mágicas. Ogras" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e803-3050-fe11-b70c" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9b37-af4a-5b33-1374" name="Armadura de Mastodonte" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="f132-df77-ee1e-1aba" name="Armadura de Mastodonte" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura pesada. Al inicio de cada uno de tus turnos, el personaje recupera una de las heridas que hubiese sufrido con anterioridad durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f350-9f89-785d-b986" name="Armadura pesada" hidden="false" targetId="1ee5-2441-2c69-5965" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5a58-6a48-c163-b375" name="Grancráneo" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="d594-bb94-37d3-4809" name="Grancráneo" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Protegetripas. Cualquier hechicero que designe como objetivo de uno de sus hechizos a la unidad en la que esté el portador obtendrá una Disfunción mágica con cualquier resultado de dobles en su tirada de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="75d0-cd43-5b1b-271d" name="Protegetripas" hidden="false" targetId="2131-d9ec-edb5-8015" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5122-1311-6003-63fd" name="Protegetripas de las Grandes Fauces" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="e14c-b1ea-8558-9287" name="Protegetripas de las Grandes Fauces" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Protegetripas. El portador causa Terror. Cada vez que el portador acabe con un enemigo en un Desafío, puede restaurar una de las heridas perdidas previamente durante la batalla. Si no había sufrido heridas, obtiene permanentemente +1 Herida en su perfil de atributos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5a6b-0d8e-6dd8-3ac4" name="Terror" hidden="false" targetId="ca57-1f1f-8bc0-d9ab" type="rule"/>
            <infoLink id="9128-4271-2ac7-a80d" name="Protegetripas" hidden="false" targetId="2131-d9ec-edb5-8015" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f06a-9d0a-4af5-1056" name="Tripa de toro" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="4db4-955c-9cf1-a211" name="Tripa de toro" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Protegetripas. El portador y la unidad en la que se encuentre duplican su Potencia de unidad en el turno en el que realizan exitosamente una carga. Además, todos los impactos por carga que cause el portador tendrán la regla especial Poder de penetración.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1a25-9258-84de-2259" name="Protegetripas" hidden="false" targetId="2131-d9ec-edb5-8015" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dba8-5e35-f706-0d0a" name="Pellejo de colmillos de trueno" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="07dc-3813-c45b-3449" name="Pellejo de colmillos de trueno" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura ligera. Otorga a su portador las reglas especiales Piel escamosa (5+) y Aura de frío. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2f4b-59a0-dd84-7820" name="Aura de frio" hidden="false" targetId="a75b-8c16-3718-ea3c" type="rule"/>
            <infoLink id="ed7a-7620-3867-9864" name="Armadura ligera" hidden="false" targetId="44f2-32d5-23eb-62f5" type="profile"/>
            <infoLink id="b811-9c77-d34f-4e62" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7e3d-44f5-e483-aff3" name="Armas mágicas. Ogras" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="08b0-86ba-1d07-761d" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4ba5-251d-463a-ad2e" name="Cuchillas de la matanza" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="ddea-9c7a-b3b7-d6e9" name="Cuchillas de la matanza" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Mazas ogras emparejadas. Triplica el valor de Iniciativa del portador en combate cuerpo a cuerpo. Los ataques con este arma se resuelven con la regla especial Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ac21-a4c0-9225-d7d3" name="Mazas ogras emparejadas" hidden="false" targetId="fe84-062d-97aa-b294" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="13e0-d6d2-587c-0c8a" name="Maza Ablandacarnes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="901d-d3b2-35d4-6ce9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c78f-1e50-2330-f842" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb6d-3c30-11f2-854e" name="Maza Ablandacarnes" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma a dos manos. Sus impactos se resuelven con la regla especial Heridas múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="85ab-36cf-1a0a-f0d8" name="Heridas múltiples (1D3)" hidden="false" targetId="efc4-703c-5d20-0686" type="rule"/>
            <infoLink id="2fff-9283-e657-8f16" name="Arma a dos manos" hidden="false" targetId="b737-28ed-1002-5531" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7845-819c-2844-0992" name="Parteescudos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c8dc-1e74-4812-1c7f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4d13-5c07-9148-a0d5" type="max"/>
          </constraints>
          <profiles>
            <profile id="bbc5-6819-c5e1-817c" name="Parteescudos" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma a dos manos. Efectúa la tirada para impactar con este arma usando la Iniciativa del objetivo en lugar de su Habilidad de armas. Las miniaturas sin Iniciativa serán impactadas automáticamente y sufrirán 1D6 heridas por cada impacto en lugar de sólo una. Los impactos con este arma se resuelven con +1 a la Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="15da-8afc-2a4b-52b8" name="Arma a dos manos" hidden="false" targetId="b737-28ed-1002-5531" type="profile"/>
            <infoLink id="b8d6-78e6-13e5-3730" name="Arma a dos manos" hidden="false" targetId="b737-28ed-1002-5531" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="19a4-c968-349f-d35a" name="Descuajacabezas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2747-7d5a-56f7-f166" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cce2-1b12-fad6-8ecf" type="max"/>
          </constraints>
          <profiles>
            <profile id="4c45-bec3-e598-6c76" name="Descuajacabezas" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Maza ogra. Los ataques con este arma tienen la regla especial Golpe letal. Además, proporciona un bonificador de +1 a la tirada de salvación por armadura del portador, tal es la la protección que otorga el guantelete.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0252-8deb-31c3-d65e" name="Golpe letal" hidden="false" targetId="9f1c-d301-bd0e-af81" type="rule"/>
            <infoLink id="d042-05d1-e4f3-2ab9" name="Maza ogra" hidden="false" targetId="8414-1dd1-372a-bc70" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="cc93-f014-1820-9262" name="Estandartes Mágicos. Ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="37ff-ba15-dccf-b525" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ad99-1a50-f044-8eac" name="Pellejodragón" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="5d9f-df06-e031-3afc" name="Pellejodragón" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad pueden repetir todos los resultados de 1 en sus tiradas para impactar, herir y salvaciones en cualquier turno en el que realicen exitosamente una carga. Además, una vez por batalla, durante cada fase de magia el portador puede desatar un vendaval helado sobre una unidad enemiga en contacto peana con peana con este. La unidad sufre inmediatamente 1D6 impactos de Fuerza 2 sin tirada de salvación por armadura y verá su atributo de Iniciativa reducido a la mitad (redondeando hacia arriba) hasta el final del turno en curso. Esto no afecta a unidades con la regla especial Aura de frío.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3500-f648-38f5-ed3f" name="Estandarte de Trapos" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="07f9-6780-b2ba-a508" name="Estandarte de Trapos" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtienen la regla especial Sangre fría.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ff26-782b-7d80-2b8c" name="Sangre fría" hidden="false" targetId="fae6-f2eb-1a70-1084" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d4da-811f-b114-9a7e" name="Tótem de los caníbales" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="c5cc-ff36-f7c6-f679" name="Tótem de los caníbales" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtienen las reglas especiales Ansia de sangre y Furia asesina y no la perderán aunque pierdan un combate (sin embargo, la perderán si pierden este estandarte).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e281-a83c-1017-11c8" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
            <infoLink id="5c98-747e-b352-2cd5" name="Ansia de sangre" hidden="false" targetId="2a68-a009-1a7a-c667" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ce76-238d-0894-c6fc" name="Estandarte de los Toros" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="8b2d-616a-ce44-2833" name="Estandarte de los Toros" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad podrán repetir sus tiradas para herir fallidas causadas por los Impactos por carga generados por su regla especial Arremetida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="19c4-44d5-5300-291c" name="Estandarte de las competiciones de las cuchipandas" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="d8fd-e9ed-bb1a-26cb" name="Estandarte de las competiciones de las cuchipandas" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Los impactos que obtienen un resultado natural de 6 en la tirada para herir del portador y su unidad en combate se resolverán con un penalizador de -2 adicional a la tirada de salvación por armadura del oponente.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c8f0-c267-b51b-597e" name="Estandarte del Bocaenllamas" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="e570-3fe1-f6b3-9c5a" name="Estandarte del Bocaenllamas" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtienen la regla especial Ataques flamígeros. Además, al inicio de cada fase de combate cuerpo a cuerpo, elige una unidad enemiga en contacto peana con peana con el portador: dicha unidad sufrirá 1D6 impactos de Fuerza 3 distribuidos como proyectiles con la regla especial Ataques solo flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c059-7a5f-b808-37c9" name="Ataques flamígeros" hidden="false" targetId="6985-722e-1ce4-b838" type="rule"/>
            <infoLink id="f513-b61c-fe13-4322" name="Ataques solo flamígeros" hidden="false" targetId="5587-433b-16c0-79d1" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0fd8-55e5-399a-7c71" name="Objetos Hechizados. Ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f2d6-1318-6fca-0173" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1acc-cfe6-6faf-929e" name="Estatuilla de Bramhir" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="429a-2448-2cf7-1b71" name="Estatuilla de Bramhir" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Proporciona a su portador una tirada de salvación especial de 4+ contra todas las heridas causadas por miniaturas del Caos, enanos del Caos o skaven (eso incluye las heridas causadas por hechizos o máquinas de guerra).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4bef-d7f8-20e0-39de" name="Puño glotón" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="6894-dc75-fe59-b3ef" name="Puño glotón" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador obtiene un bonificador de +1 a su tirada de salvación por armadura y la regla especial Orgullo marcial.
Cuando esté luchando en un Desafío, el portador obtiene un ataque adicional por cada objeto mágico que porte el oponente.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ce91-6775-49e8-f724" name="Orgullo marcial" hidden="false" targetId="2707-4d2a-ddbd-e301" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b741-78b9-b9e5-529c" name="Marca del demonio" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="992c-23f4-2380-03d7" name="Marca del demonio" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador causa Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ebf6-40fe-25b9-00e3" name="Terror" hidden="false" targetId="ca57-1f1f-8bc0-d9ab" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ef59-d7aa-809a-b907" name="Corona de laurel" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="e03f-7a07-dd91-9225" name="Corona de laurel" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y su unidad podrán repetir sus chequeos fallidos de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="63a4-5d59-c933-6c0f" name="Barril de licor de lagarto del trueno" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="3ca6-086e-4ff2-d740" name="Barril de licor de lagarto del trueno" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y la unidad en la que se encuentre obtienen las reglas especiales Regeneración (6+), Inmune a psicología e Inflamable.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4bc9-dae3-6a27-5126" name="Inmune a la psicología" hidden="false" targetId="73ad-8cdb-f1ad-010f" type="rule"/>
            <infoLink id="678b-1530-80b4-d081" name="Inflamable" hidden="false" targetId="93e4-15ce-63a5-ad92" type="rule"/>
            <infoLink id="8c50-caa1-6ec2-3fb3" name="Regeneración (6+)" hidden="false" targetId="4aee-7485-a141-cd20" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c11e-bd92-9eb4-6c79" name="Trozo de hielo encantado" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="9a99-6101-1cf8-2367" name="Trozo de hielo encantado" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Otorga a su portador la regla especial Aura de frío.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
