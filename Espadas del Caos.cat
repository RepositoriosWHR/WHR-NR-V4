                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Archaón tiene la regla especial ¡Ni un paso atrás!, que afecta a todas las unidades del Caos a 18” o menos de él.</characteristic>
