          <profiles>
            <profile id="45e0-bdde-b815-9b73" name="Destructor de magia" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Un sólo uso. Puedes utilizar el Destructor de magia cuando el oponente lance un hechizo en vez de realizar un intento de dispersión. El hechizo es automáticamente dispersado. Además, tira 1D6: si obtienes un resultado de 4+, el hechizo resulta destruido y el hechicero no podrá emplearlo más durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cfb1-ab48-dc0e-af47" name="Poderío salvaje" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5452-c2b6-93e2-57a1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bf6b-bb52-aff5-0666" type="max"/>
          </constraints>
          <profiles>
            <profile id="ade2-257d-cb37-00f6" name="Poderío salvaje" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene las reglas especiales Odio (¡todos los enemigos!) y Carga devastadora, y no perderá su Furia asesina aunque sea derrotado en combate. </characteristic>
