    <profile id="2131-d9ec-edb5-8015" name="Protegetripas" hidden="false" typeId="41726d6f757223232344415441232323" typeName="Armadura">
      <characteristics>
        <characteristic name="Salvación" typeId="536176696e67205468726f77206d6f64696669657223232344415441232323">6+</characteristic>
        <characteristic name="Reglas especiales" typeId="5370656369616c2052756c657323232344415441232323">El Protegetripas proporciona un bonificador de +1 a la tirada de salvación por armadura de su portador, o una tirada de salvación por armadura de 6+ si no disponía de ella. Puede combinarse con otras armaduras de la forma habitual.</characteristic>
      </characteristics>
    </profile>
    <profile id="e8b3-0de8-78c8-b6b3" name="Tatuajes talismánicos" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
