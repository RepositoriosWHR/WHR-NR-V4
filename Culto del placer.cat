        <selectionEntry id="d5ae-4e86-427a-f1e7" name="Ladrón de esencia vital" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2e7d-4e53-2c4d-e520" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="5bd4-c315-d73e-4b4f" type="max"/>
          </constraints>
          <profiles>
            <profile id="db41-61fe-cea7-fd66" name="Ladrón de esencia vital" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">Cada vez que el demonio causa una baja en combate cuerpo a cuerpo, tira 1D6: por cada resultado de 4+, el demonio puede restaurar una de las heridas que hubiese sufrido previamente durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="95ca-171b-a0d5-c03d" name="Fusta de la vejación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a63d-cb37-fa62-5d16" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="c21d-97e1-a135-af92" type="max"/>
          </constraints>
          <profiles>
            <profile id="ea54-e955-8b4e-f7fa" name="Fusta de la vejación" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">Los ataques del demonio en combate negarán las tiradas de salvación por armadura del enemigo. Además, los impactos que obtengan un 6 natural en la tirada para herir obtendrán la regla especial Heridas Múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="d2ae-cab5-966d-2893" name="Arma demonio" hidden="false" collective="false" import="true" targetId="5250-fd95-da34-9955" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
