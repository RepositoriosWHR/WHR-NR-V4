          <profiles>
            <profile id="c1ed-1d15-4841-df34" name="Cadenas de Slaanesh" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo miniaturas con la Marca de Slaanesh. En combate cuerpo a cuerpo, el portador realiza 1D6 ataques adicionales que se resuelven con Iniciativa 10, utilizando los valores de Habilidad de Armas y Fuerza del portador (no se beneficiarán del efecto de ningún arma mundana o mágica del portador, aunque sí de las Recompensas del Caos que pudiera tener).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="54ed-e3ce-dc1d-9be7" name="Colgante de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="87c9-fcc0-9257-b4ea" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="368f-d474-04a5-e8f8" type="max"/>
          </constraints>
          <profiles>
            <profile id="1223-de33-2fba-ac77" name="Colgante de Slaanesh" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo miniaturas con la Marca de Slaanesh. Por cada herida que sufra el portador, su atributo de Ataques aumenta en un punto (hasta un máximo de 10). </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
