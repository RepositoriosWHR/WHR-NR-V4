      <rules>
        <rule id="abae-9578-5362-41af" name="Incordiar" hidden="false">
          <description>Cualquier unidad enemiga en contacto con esta unidad sufrirá un impacto de Fuerza 2 sin posibilidad de tirada de salvación por armadura por cada resultado natural de 1 que obtuviese en sus tiradas para impactar. </description>
        </rule>
        <rule id="b6a0-7834-fac0-a8a6" name="Magia errática" hidden="false">
          <description>Los hechiceros enemigos a 8” o menos de una unidad de Duendes del bosque deberán repetir el resultado más elevado de los obtenidos en sus tiradas de lanzamiento de hechizo.</description>
        </rule>
      </rules>
