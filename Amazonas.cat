    <selectionEntry id="42f1-463c-ce44-68ae" name="Catalizador de la Ira Ancestral" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="d1ae-bbef-f282-ae50" value="2.0">
