    <selectionEntry id="d739-d61e-1662-1fbd" name="Araña aracnarock" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="6a85-c693-85e1-a783" name="Araña aracnarock" hidden="false" typeId="4d6f64656c23232344415441232323" typeName="Modelo">
          <characteristics>
            <characteristic name="M" typeId="4d23232344415441232323">7</characteristic>
