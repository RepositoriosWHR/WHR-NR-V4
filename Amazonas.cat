    <selectionEntry id="e839-a49e-48e4-90ca" name="[P] - Espíritus antepasados" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="increment" field="1907-2e76-42bd-e179" value="1.0">
          <repeats>
