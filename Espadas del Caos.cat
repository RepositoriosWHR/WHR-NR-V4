              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene un ataque adicional que se resolverá con su Fuerza básica y las reglas especiales Ataques envenenados y Heridas múltiples (2). </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b36a-9b0b-6e37-1796" name="Heridas múltiples (2)" hidden="false" targetId="be26-0d4a-0493-6c52" type="rule"/>
            <infoLink id="ff07-f12b-7158-06dd" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
