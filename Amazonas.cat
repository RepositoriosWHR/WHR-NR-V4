    <selectionEntry id="9447-22a9-947d-a0d0" name="[E] - Penthesilea, la marca de la serpiente" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="1fcf-7bc5-f4b9-ba51" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="20db-25c8-4a41-c8ff" type="max"/>
      </constraints>
      <rules>
        <rule id="1447-e6da-d741-f482" name="Desafiante" hidden="false">
          <description>Penthesilea realiza un total de 6 Ataques (debe realizar como mínimo un ataque con una de sus armas) y tiene las reglas especiales Orgullo marcial y Odio (¡todos los enemigos!). Además, puede realizar Parada con sus dos armas.</description>
        </rule>
        <rule id="39b6-5ac0-f840-60f2" name="Reconocida" hidden="false">
          <description>Phentesilea puede unirse a cualquier unidad de Amazonas de Infantería, 
pese a no tener las reglas Aislacionista o Culto a Koka-Kalim.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="91fc-db1a-8081-25a0" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="349e-a0a0-66c3-84fd" name="Cruzar (bosques)" hidden="false" targetId="9d01-387d-269d-5a44" type="rule"/>
        <infoLink id="c299-7675-d872-e9c9" name="Inmortales" hidden="false" targetId="04fe-41ff-c4a1-ca09" type="rule"/>
        <infoLink id="5a1e-2f8d-2bb0-53b5" name="Orgullo marcial" hidden="false" targetId="2707-4d2a-ddbd-e301" type="rule"/>
        <infoLink id="3157-434b-3f69-6795" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
        <infoLink id="dc43-1416-b64d-1536" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Contra maldiciones)"/>
          </modifiers>
        </infoLink>
        <infoLink id="e1db-71aa-f6d9-b414" name="Inmune al miedo" hidden="false" targetId="9dea-6e2e-9d06-f5f7" type="rule"/>
        <infoLink id="6801-4f72-3a2a-5076" name="Carga devastadora" hidden="false" targetId="dbe6-c910-7f37-aeac" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="b02d-53ee-cb29-38e1" name="Personajes" hidden="false" targetId="e839-bd6b-7e36-e758" primary="false"/>
