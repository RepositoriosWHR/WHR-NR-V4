      <rules>
        <rule id="f113-ec1c-dfc4-f9c9" name="Magia Gran matriarca de Rigg" hidden="false">
          <description>Nivel de magia 3. Puede aumentarse a 4 por +55 puntos. Puede elegir sus hechizos del saber de los Cielos, Luz, Muerte, Bestias o Vida.</description>
        </rule>
