              <profiles>
                <profile id="0c8c-f038-9754-e64b" name="Manifestación de Rigg" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">Obtiene un nivel de magia y conocerá un hechizo adicional del saber del cual toma sus hechizos. Además, todas las unidades de humanos de tu ejército a 12” o menos de ella podrán repetir sus chequeos de Liderazgo fallidos.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
