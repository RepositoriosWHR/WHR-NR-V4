              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Otorga a su portador una tirada de salvación especial de 5+, la cual pasa a ser una tirada de salvación especial de 4+ contra los ataques de F5 y una tirada de salvación especial de 3+ contra los ataques de F6 o superior.</characteristic>
              </characteristics>
            </profile>
