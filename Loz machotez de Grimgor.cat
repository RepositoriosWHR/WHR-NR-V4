        <selectionEntry id="a8af-b5c1-e3ae-1c7a" name="General del ejército" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3539-0bc2-ff33-a71a" type="max"/>
