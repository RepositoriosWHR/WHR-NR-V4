    <selectionEntryGroup id="0f87-63e2-5d4c-5844" name="Armas mágicas. Goblins silvanos. Arco corto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8b24-99d4-db2c-4ffd" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8ba7-dee5-9b80-ca77" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5f3a-01cc-6fd9-ae9d" name="Arko loko de Wuzzit" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f558-7fba-94a1-bf60" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d996-6370-f6b5-f6f0" type="max"/>
          </constraints>
          <profiles>
            <profile id="2267-a732-4cdd-b3ac" name="Arko loko de Wuzzit" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arco corto. Tiene la regla especial Disparos múltiples (X), donde X es el valor de Ataques del perfil del portador. Además, cada vez que dispares con este arco, tira 1D6 para determinar la Fuerza de sus disparos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
