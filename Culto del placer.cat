    <selectionEntryGroup id="9d7c-3e7c-5a7e-0410" name="Regalos demoníacos menores de Slaanesh. Heraldo de Slaanesh" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54ef-732b-fc16-ec20" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bebe-448c-1941-ee0d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6a7e-cd22-856c-bf23" name="Gran foco de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="13e0-ec63-8f3e-ddd4" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="8f97-9d29-59cd-e64e" type="max"/>
          </constraints>
          <profiles>
            <profile id="21fe-b677-60a3-935b" name="Gran foco de Slaanesh" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">Sólo Heraldos de Slaanesh. Si el Heraldo dispone de un Foco demoníaco, su efecto se aplicará a todas las unidades con la regla especial Demonio (Slaanesh) a 12” o menos del Heraldo de Slaanesh.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d803-b722-4746-463f" name="Focos de Slaanesh" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2c84-be4c-a4f7-2b48" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9d67-d87c-4373-810b" name="Foco mayor de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5791-b58a-99cc-f96c" type="max"/>
          </constraints>
          <rules>
            <rule id="46a0-f4eb-9396-ee9a" name="Foco mayor de Slaanesh" hidden="false">
              <description>Todos los enemigos tendrán un penalizador de -1 en sus tiradas para impactar contra el demonio (tanto en disparo como en combate cuerpo a cuerpo).</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="484b-e66d-ae39-4ebf" name="Foco menor de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="22bc-b335-735e-c7c1" type="max"/>
          </constraints>
          <rules>
            <rule id="fc54-d087-7d4e-3d77" name="Foco menor de Slaanesh" hidden="false">
              <description>El demonio obtiene +1 Ataque. </description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
