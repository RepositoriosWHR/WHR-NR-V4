          <profiles>
            <profile id="08fe-c7c1-dbdb-4f14" name="Gran maza de los titanes" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Objeto legendario. Arma a dos manos. Los impactos causados por este arma se resuelven con Fuerza 10, la regla especial Heridas múltiples (1D6) y no permiten tirada de salvación por Esquivar.</characteristic>
              </characteristics>
            </profile>
