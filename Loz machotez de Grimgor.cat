          <profiles>
            <profile id="572f-6e32-54cb-a673" name="Alanzabarda" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadora a dos manos. Proporciona a su portador +1F y +1A, además de las reglas especiales Carga devastadora y Ataque rápido. Adicionalmente, proporciona a su portador una bonificación de +1 en su tirada de salvación por armadura, que se aumenta a +2 contra los ataques en cuerpo a cuerpo que procedan de su frontal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9e74-d1e5-14e6-171d" name="Rebanadora a dos manos" hidden="false" targetId="045b-d3b9-e43a-5ee6" type="profile"/>
