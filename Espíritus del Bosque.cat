                <profile id="0db0-df6e-3be2-3332" name="Orbe del vigor" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="7e0d-4aa5-85cf-f713">Cuando el portador pierda su última herida, tira 1D6: con un resultado de 1, no ocurrirá nada especial. Con un resultado de 2-5, el Taumaturgo zoat se levantará con una Herida restante y con un resultado de 6 se levantará con 1D3 Heridas restablecidas; en todo, caso el poder del orbe se consumirá. Mientras tanto, otorgará a su portador las reglas especiales Regeneración (+4) y Resistencia mágica (2).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="92c2-1180-8b09-f9c8" name="Regeneración (4+)" hidden="false" targetId="6605-7689-3444-dccd" type="rule"/>
                <infoLink id="aaaf-33c3-0897-f152" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="50.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="3f4d-d4e8-0534-e8bd" name="Taumaturgo zoat anciano" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9b94-ff7c-72e1-3614" type="max"/>
              </constraints>
              <rules>
                <rule id="10ca-19e0-1992-1d31" name="Taumaturgo zoat anciano" hidden="false">
                  <description>Un Taumaturgo zoat anciano cuenta con una Herida adicional en su perfil de atributos y tiene la regla especial Señor del conocimiento (Vida).</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="45.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
