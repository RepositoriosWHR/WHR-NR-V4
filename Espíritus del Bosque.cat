            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ca9b-90a9-2141-cd0c" type="max"/>
          </constraints>
          <profiles>
            <profile id="ecff-45b5-a8dc-3c71" name="Tamaño descomunal" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El perosaje obtiene +1 Herida en su perfil de atributos y un penalizador de -1 a su Iniciativa.</characteristic>
              </characteristics>
            </profile>
