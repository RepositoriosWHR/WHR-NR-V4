      </constraints>
      <selectionEntries>
        <selectionEntry id="9288-f469-b1ed-7219" name="Penacho de Plumas Coatl" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1fc0-8aeb-e708-cbf3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ce16-4b7c-0d92-4280" type="max"/>
          </constraints>
          <profiles>
            <profile id="f3a2-08cf-9c9b-3d52" name="Penacho de Plumas Coatl" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Sólo Gran Matriarca de Rigg. Proporciona a su portadora la regla especial Resistencia mágica (2) y una tirada de salvación especial de 4+. Adicionalmente, conocerá el hechizo “Disipación de magia” del saber de Alta Magia. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="b5e6-c6d6-d95d-2bc8" name="Disipación de magia (Dificultad 7+)" hidden="false">
              <description>Es un hechizo con un alcance de 24” que puede lanzarse sobre una unidad amiga (en cuyo caso se tratará de un hechizo de Potenciación) o una unidad enemiga (en cuyo caso se tratará de un hechizo de Maldición). Todos los hechizos que Permanecen un turno y Permanecen en efecto lanzados por el enemigo sobre la unidad cesarán su efecto y serán dispersados.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="ab12-55d6-480b-2b1d" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="044b-3577-2f4e-d4d1" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
