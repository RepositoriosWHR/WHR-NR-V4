            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7fa7-1e93-e33d-e0e4" type="max"/>
          </constraints>
          <profiles>
            <profile id="a1d6-1fba-da05-4223" name="Bebedor de sangre" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Por cada herida causada a un oponente que no tenga la regla especial No muerto o Demonio por el personaje en combate tira 1D6; con un resultado de 5+, recuperará una de las heridas perdidas con anterioridad durante la batalla. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="08dd-0420-5ce4-c1a4" name="Piel de bronce" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac9f-9ab4-1d77-b3ba" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="35e6-5f01-df35-50f4" type="max"/>
          </constraints>
          <profiles>
            <profile id="90bf-c11f-dfe3-419d" name="Piel de bronce" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene la regla especial Piel escamosa (4+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
