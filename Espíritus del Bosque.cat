    <selectionEntry id="814a-2e2e-1b18-1941" name="[Ex] - Taumaturgo zoat" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a7c9-be80-08a2-aff3" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="046a-1c36-705e-1c0e" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="058e-0d1c-3bd1-093c" type="max"/>
      </constraints>
      <rules>
        <rule id="6a19-0d60-01e8-b089" name="Magia Taumaturgo zoat" hidden="false">
          <description>Nivel 3 que puede aumentarse a nivel 4 por +55 puntos y toma sus hechizos del Saber de la Vida.</description>
        </rule>
        <rule id="9876-4338-d478-0b98" name="Asceta" hidden="false">
          <description>El Taumaturgo zoat no puede ser el General del ejército. Sin embargo, tiene la regla especial Presencia inspiradora, que afecta a las unidades de Guerreros zoat a 12” o menos de él.</description>
        </rule>
        <rule id="f506-21c8-fd93-0b3d" name="Protector del bosque" hidden="false">
          <description>Siempre que un Taumaturgo zoat se encuentre dentro de un Bosque, obtendrá un bonificador de +2 a lanzar sus hechizos del Saber de la Vida. Además, los disparos realizados contra un Taumaturgo zoat obtendrán un penalizador de -1 en sus tiradas para impactar siempre que se encuentre a 6” o menos de un Bosque.</description>
        </rule>
        <rule id="7725-f814-50a2-d203" name="Señor del conocimiento (Vida)" hidden="false">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="814a-2e2e-1b18-1941" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3f4d-d4e8-0534-e8bd" type="equalTo"/>
              </conditions>
            </modifier>
          </modifiers>
        </rule>
      </rules>
