          <modifiers>
            <modifier type="append" field="name" value="(Marca de Khorne/Demonio [Khorne])"/>
          </modifiers>
        </infoLink>
        <infoLink id="2240-e4bd-de98-517a" name="Ojo de los dioses" hidden="false" targetId="904a-b5e9-77cb-e22a" type="rule"/>
