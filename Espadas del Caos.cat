              </constraints>
              <rules>
                <rule id="b71e-26a2-29a3-c9c8" name="Marca de Khorne. Elegidos del Khorne en Juggernaut" hidden="false">
                  <description>Tanto los Elegidos de Khorne como los Juggernauts de Khorne portan la Marca de Khorne, por la que obtienen las reglas especiales Furia asesina (sólo los jinetes), Odio (¡todos los enemigos!, solo las monturas) y Resistencia mágica (2). Además, no perderán su Furia asesina aunque sean derrotados en combate.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="5013-36bb-14f4-2f72" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Solo jinetes)"/>
                  </modifiers>
                </infoLink>
                <infoLink id="95c5-872e-6ccd-736a" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
              </infoLinks>
            </entryLink>
          </entryLinks>
        </selectionEntryGroup>
      </selectionEntryGroups>
