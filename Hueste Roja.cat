                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="3b38-f0f6-fd9a-4150" name="Báculo de Serpiente de Oro" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef10-850c-961d-5041" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="98c8-9df4-7db4-c38c" type="min"/>
              </constraints>
              <profiles>
                <profile id="c717-b1e4-b01f-1cd3" name="Báculo de Serpiente de Oro" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Permite a Xiuhcoatl conocer dos hechizos adicionales (para un total de cinco). Además, se trata de un objeto portahechizos con nivel de energía 3 que contiene un hechizo de proyectil mágico con un alcance de 24” y que causa 1D3 impactos de F7 con la regla especial Ataques solo flamígeros. Adicionalmente, aumenta en +1 el valor de Iniciativa de Xiuhcoatl y de la unidad que lo acompañe.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
          <entryLinks>
