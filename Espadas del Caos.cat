        <selectionEntry id="bacc-f290-0fd9-cef5" name="Hechicería del Caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="03b9-ae56-23d4-8d3d" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ad22-556f-6e94-9f2c" type="max"/>
          </constraints>
          <profiles>
            <profile id="7408-8bee-b2de-df19" name="Hechicería del Caos" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">No puede ser elegida por personajes con nivel de magia o con la Marca de Khorne. El personaje obtiene la clave hechicero y pasa a ser un hechicero de nivel 1 que puede elegir sus hechizos de entre los Saberes del Fuego, la Muerte, Magia Oscura o el Saber de su Dios del Caos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="ac84-addf-fccb-a7a0" name="Nivel 1" hidden="false" collective="false" import="true" targetId="6930-ec9b-4df6-24c5" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7423-88ec-3d81-c891" name="Sudor fangoso" hidden="false" collective="false" import="true" type="upgrade">
