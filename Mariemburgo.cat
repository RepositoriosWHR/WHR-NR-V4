                <selectionEntry id="9aae-09cb-0403-826f" name="Espada rúnica de Skarloc" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b37a-3087-814c-88da" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="982a-6279-2d40-d03d" type="min"/>
                  </constraints>
                  <profiles>
                    <profile id="1277-2a20-6c72-505a" name="Espada rúnica de Skarloc" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los ataques efectuados por Skarloc obtendrán un bonificador de +1 a sus tiradas para impactar y se resolverán con +1 Fuerza. Los ataques enemigos dirigidos contra Skarloc en combate cuerpo a cuerpo deberán aplicar un penalizador de -1 en sus tiradas para impactar. Además, le permite a Skarloc realizar Parada por su regla Destreza marcial pese a estar equipado con Arma de mano.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="a366-7921-6e7c-5fec" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
