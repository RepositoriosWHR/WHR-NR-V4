                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="f96d-0145-f9aa-ab7a">Si acaba con un personaje u oficial enemigo en un desafío, podrá restaurar inmediatamente una herida que hubiese sufrido previamente durante la batalla, y la unidad en la que estuviese incluido dicho oficial o personaje quedará Apabullada hasta el final de la fase de combate en curso</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
