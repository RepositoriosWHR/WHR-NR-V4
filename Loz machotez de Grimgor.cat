            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="64a4-7395-6689-707b" type="max"/>
          </constraints>
          <profiles>
            <profile id="80bd-cba6-afd8-2612" name="Mandíbula de Hierro del Kaudillo Imbaz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador obtiene un ataque adicional en combate cuerpo a cuerpo que se resolverá con la Fuerza del portador de este objeto y tiene la regla especial Golpe letal. </characteristic>
              </characteristics>
            </profile>
