        </selectionEntry>
        <selectionEntry id="fded-b173-3dad-64e0" name="Bendición de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2811-32ea-db40-5992" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4896-5c4b-2865-d91f" type="max"/>
          </constraints>
          <profiles>
            <profile id="8ff8-363d-3f26-5a5d" name="Bendición de Slaanesh" hidden="false" typeId="9846-934f-6342-2762" typeName="Senda">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">El personaje obtiene la regla especial aura demoníaca (5+). Sin embargo, se verá afectado por los hechizos y habilidades que afecten a Demonios o que lo hagan de forma aumentada. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
