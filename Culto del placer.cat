          <profiles>
            <profile id="c5ff-14ea-a468-6873" name="Marcado por el Caos" hidden="false" typeId="4a21-6ede-290c-54cb" typeName="Recompensa del Caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ac18-bd08-5794-1799">Al inicio de la batalla, tras el despliegue, efectúa una tirada de 2D6 en la tabla de Ojo de los Dioses y aplica el resultado al personaje durante toda la batalla: si obtienes un resultado de 2, considera que has obtenido un 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
