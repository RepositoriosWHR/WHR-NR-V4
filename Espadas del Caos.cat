              </modifiers>
              <rules>
                <rule id="223e-94b6-41cf-02d5" name="Marca de Tzeentch. Elegidos del Caos en corcel demoníaco" hidden="false">
                  <description>Obtienen la regla especial Ataques flamígeros y una tirada de salvación especial de 5+ (o +2 si ya disponían de ella).</description>
                </rule>
              </rules>
              <infoLinks>
