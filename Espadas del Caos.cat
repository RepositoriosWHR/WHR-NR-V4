          <entryLinks>
            <entryLink id="4168-c8d5-1bb2-4343" name="Marca del Caos absoluto. Unidades" hidden="false" collective="false" import="true" targetId="24b7-05f6-36ce-099c" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5a7e-a4cd-7411-af8b" type="max"/>
              </constraints>
              <rules>
                <rule id="275f-bfa4-594f-575b" name="Marca del Caos absoluto. Altar de guerra de los Espadas del Caos" hidden="false">
                  <description>Obtiene la regla especial Piel escamosa (6+). Además, al inicio de la batalla, antes del despliegue, efectía una tirada en la tabla del Ojo de los dioses y aplica el resultado al Altar de la guerra del Caos durante la batalla (considera los resultados de 2 como 3).</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="02e5-88fd-75c0-67d5" name="Piel escamosa (6+)" hidden="false" targetId="1d04-d136-a7a6-eb68" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="20.0"/>
              </costs>
            </entryLink>
            <entryLink id="bf8a-5969-af25-ec46" name="Marca de Khorne. Unidades" hidden="false" collective="false" import="true" targetId="0cf1-1763-4dd8-caba" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7ddd-1807-ed2d-32b1" type="max"/>
              </constraints>
              <rules>
                <rule id="8a86-a7a3-d762-46d2" name="Marca de Khorne. Altar de guerra de los Espadas del Caos" hidden="false">
                  <description>Obtiene las reglas especiales Furia asesina (sólo los tripulantes) y Resistencia mágica (1). Nunca perderá su Furia asesina.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="55cc-bf2f-eb27-78a7" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Tripulantes)"/>
                  </modifiers>
                </infoLink>
                <infoLink id="63c3-c2db-620c-72cc" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="25.0"/>
              </costs>
            </entryLink>
            <entryLink id="59f6-713c-d0e3-18f2" name="Marca de Nurgle. Unidades" hidden="false" collective="false" import="true" targetId="0adb-14f6-3d62-89cf" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e39-056d-ecbf-7f67" type="max"/>
              </constraints>
              <rules>
                <rule id="a91f-4cb5-871e-a687" name="Marca de Nurgle. Altar de guerra de los Espadas del Caos" hidden="false">
                  <description>Los enemigos tienen un penalizador de -1 para impactarles con proyectiles. Los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas. Además, obtienen las reglas especiales Ataques envenenados e Inmune a veneno.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="6fe0-92c6-daee-80d6" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="22fc-b46b-858e-6861" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="25.0"/>
              </costs>
            </entryLink>
