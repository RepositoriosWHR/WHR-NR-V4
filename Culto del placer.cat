              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">Tras desplegar, pero antes de determinar quién empieza a jugar, puedes redesplegar una de tus unidades.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
