    <selectionEntry id="b5bf-9ee5-d41d-5dff" name="Sacerdote de Manann" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="2a1d-55b1-51f7-c1ab" name="Plegarias Sacerdote de Manann" hidden="false">
          <description>Un Sacerdote de Manann conoce todas las plegarias de Manann y puede lanzar una de ellas por fase de magia propia con Nivel de energía 3.</description>
        </rule>
        <rule id="e087-b0e8-2959-f6ae" name="Fiel a Manann" hidden="false">
          <description>Si el Sacerdote de Manann se une a una unidad con la regla Bendición de Manann, todas las miniaturas de la unidad obtendrán la regla especial Sangre fría.</description>
        </rule>
      </rules>
      <infoLinks>
