          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="25a9-2b12-8510-5a83" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f89f-9db2-d188-5522" type="max"/>
          </constraints>
          <profiles>
            <profile id="2759-59b1-05cf-3417" name="Colgante de Slaanesh" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo miniaturas con la Marca de Slaanesh. Por cada herida que sufra el portador, su atributo de Ataques aumenta en un punto (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
