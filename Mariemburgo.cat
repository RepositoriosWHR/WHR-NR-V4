      <selectionEntries>
        <selectionEntry id="3adf-85ba-b109-8180" name="Corneta del pagador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7576-9bff-ca38-314e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c215-f185-bf1e-e01a" type="max"/>
          </constraints>
          <profiles>
            <profile id="32e0-8163-5c71-48ea" name="Corneta del pagador" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo Pagador. En la fase de movimientos, al inicio de la subfase resto de movimientos, selecciona una única unidad de infantería a 6” o menos del portador y que no se encuentre en combate cuerpo a cuerpo ni haya cargado ese turno. Esta unidad, podrá reformarse superando automáticamente el chequeo incluso si no tuviese músico. Después, podrá mover, marchar o disparar como si no se hubiera Reformado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="ada2-77f0-11d8-b339" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="79e0-d745-4c5b-fba9" name="Objetos hechizados. Mariemburgo. Pagador" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="90eb-894f-6eea-979d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1854-5c73-0a74-12f8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2c8f-834f-63d9-56df" name="Cofre del soborno" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="78ae-d0b9-ced6-233b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9ab6-8289-94c4-c40e" type="max"/>
          </constraints>
          <profiles>
            <profile id="108f-5593-df21-d7c1" name="Cofre del soborno" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo pagador. Un solo uso. Al principio del turno del oponente, elige una unidad enemiga a 12’’ o menos del portador. La unidad no podrá declarar una carga a la unidad del portador del cofre. No tiene ningún efecto contra miniaturas Inmunes a Psicología.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
