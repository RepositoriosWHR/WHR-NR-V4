                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arko de huezo. Los disparos efectuados con este arco tienen la regla especial Heridas múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
