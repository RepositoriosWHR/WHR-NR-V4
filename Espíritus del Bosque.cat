          </constraints>
          <profiles>
            <profile id="5119-e445-853e-f646" name="Los molestos geniecillos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Mientras esté en un Desafío, las tiradas para impactar en combate cuerpo a cuerpo exitosas contra el personaje deberán repetirse y aplicarán un -1 a la Habilidad de armas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7b76-c4ca-8063-f7b9" name="Protección de las hadas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
