              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma bruja. El portador puede repetir sus tiradas para herir en cuerpo a cuerpo.</characteristic>
              </characteristics>
            </profile>
