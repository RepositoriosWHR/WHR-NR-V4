        <selectionEntry id="58c1-7fbb-abf3-f773" name="Escudo devorador de hechizos de Khorne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="bc98-d4fe-c23f-b397" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="327d-c825-a13d-6e09" type="max"/>
          </constraints>
