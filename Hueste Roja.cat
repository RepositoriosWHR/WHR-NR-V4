      <selectionEntries>
        <selectionEntry id="67c9-5adf-c290-4faf" name="Pendones de sangre caliente" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7a15-32c4-3760-5a7f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cfdf-f089-3d6c-f8ac" type="max"/>
