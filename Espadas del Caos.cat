        <selectionEntryGroup id="8271-c280-1300-0385" name="Marca del caos" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8bbe-065c-e353-25d8" type="max"/>
