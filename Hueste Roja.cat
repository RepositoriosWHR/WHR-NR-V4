        <infoLink id="f9b4-8d12-23b2-c72f" name="Impactos por carga (1D6+1)" hidden="false" targetId="78cb-a25e-39e5-1f51" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Estegadon anciano)"/>
          </modifiers>
        </infoLink>
        <infoLink id="9b7c-fbbe-307b-9372" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule"/>
        <infoLink id="b55d-651c-ef11-d7e8" name="Disparo rápido" hidden="false" targetId="e198-cb4f-6dfc-1dcc" type="rule"/>
