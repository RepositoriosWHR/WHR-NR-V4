        <selectionEntryGroup id="cf91-4c4f-732f-3902" name="Marca del Caos" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="36b9-02cc-01a6-0f84" type="max"/>
          </constraints>
          <entryLinks>
            <entryLink id="8bc7-1a55-be82-d994" name="Marca del Caos absoluto. Unidades" hidden="false" collective="false" import="true" targetId="24b7-05f6-36ce-099c" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="6.0">
                  <repeats>
                    <repeat field="selections" scope="4a60-7c1b-2d90-5206" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b28f-acb1-3bc9-8804" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="9e0a-7a4e-9742-e91f" name="Marca del Caos absoluto. Elegidos del Caos en corcel demoníaco" hidden="false">
                  <description>Al inicio de la batalla, antes del despliegue, efectúa una tirada en la tabla del Ojo de los dioses y aplica el resultado a toda la unidad (Solo jinetes) durante la batalla; considera los resultados de 2 como 3. Además, podrán repetir sus tiradas de Ojo de los dioses.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="b1be-8983-4c83-fdaa" name="Ojo de los dioses" hidden="false" targetId="0799-cc58-3276-4a94" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Solo jinetes)"/>
                  </modifiers>
                </infoLink>
              </infoLinks>
            </entryLink>
            <entryLink id="113d-ab4d-83b5-603e" name="Marca de Khorne. Unidades" hidden="false" collective="false" import="true" targetId="0cf1-1763-4dd8-caba" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="7.0">
                  <repeats>
                    <repeat field="selections" scope="4a60-7c1b-2d90-5206" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b28f-acb1-3bc9-8804" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="9f72-fc09-d043-8e4c" name="Marca de Khorne. Elegidos del Caos en corcel demoníaco" hidden="false">
                  <description>Obtienen las reglas especiales Furia asesina (sólo los jinetes), Odio (sólo las monturas) y Resistencia mágica (2). Además, no perderán su Furia asesina aunque sean derrotados en combate.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="57ab-9a03-69fc-d733" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Solo jinetes)"/>
                  </modifiers>
                </infoLink>
                <infoLink id="5817-f6db-bc24-9f3a" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
                <infoLink id="fe45-9a3e-84f1-ae22" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Corcel demoníaco)"/>
                  </modifiers>
                </infoLink>
              </infoLinks>
            </entryLink>
            <entryLink id="2b4d-beca-0c8f-03b0" name="Marca de Nurgle. Unidades" hidden="false" collective="false" import="true" targetId="0adb-14f6-3d62-89cf" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="7.0">
                  <repeats>
                    <repeat field="selections" scope="4a60-7c1b-2d90-5206" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b28f-acb1-3bc9-8804" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <rules>
                <rule id="6ff6-d794-6708-0e69" name="Marca de Nurgle. Elegidos del Caos en corcel demoníaco" hidden="false">
                  <description>Obtienen las reglas especiales Ataques envenenados e Inmune a veneno. Los enemigos tienen un penalizador de -1 para impactarles con proyectiles. Los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="9441-5537-e253-0d62" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="1064-d875-d3b6-3c66" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
            </entryLink>
            <entryLink id="f233-842c-d3e9-9d88" name="Marca de Slaanesh. Unidades" hidden="false" collective="false" import="true" targetId="58e3-d5f0-974c-c37b" type="selectionEntry">
              <modifiers>
                <modifier type="increment" field="points" value="7.0">
                  <repeats>
                    <repeat field="selections" scope="4a60-7c1b-2d90-5206" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b28f-acb1-3bc9-8804" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <infoLinks>
                <infoLink id="a3d7-031c-f4d9-0a57" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
