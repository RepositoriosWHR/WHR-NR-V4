              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Al luchar con este arma el portador obtiene +1 a su Habilidad de Armas y +1 Ataque. Los impactos con este arma se resuelven con +1 a su Fuerza.</characteristic>
              </characteristics>
