      <rules>
        <rule id="9901-3f46-f679-1d49" name="Luchar sucio" hidden="false">
          <description>El Capitán se beneficia de la regla especial Parada al luchar con Dos armas de mano. Adicionalmente, en cualquier combate en el que participe, puede realizar un único ataque extra a Iniciativa 0 contra una miniatura en contacto peana con peana. Este ataque tiene la regla especial Golpe letal.</description>
        </rule>
        <rule id="e73d-57bb-dd81-0b01" name="Duro de matar" hidden="false">
          <description>Van Der Kraal tiene la regla especial Esquivar (5+) y es inmune a Golpe letal.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="6b6b-94dc-7b99-1b7f" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
