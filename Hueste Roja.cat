        <selectionEntry id="8944-7376-a6c5-b51e" name="Marca sagrada de los ancestrales" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="10e1-ca30-1d12-c850" type="max"/>
          </constraints>
          <profiles>
            <profile id="0270-530a-7f7e-6f26" name="Marca sagrada de los ancestrales" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas que portan la Marca sagrada de los ancestrales obtienen una tirada de salvación especial de 5+ y la regla especial Resistencia mágica (1). Al inicio de la batalla, tira 1D3: ese será el número de tiradas que el personaje podrá repetir durante la partida. Esas tiradas puede ser tiradas para impactar, tiradas para herir, tiradas de salvación (armadura y especial), chequeos de atributo, dados de Energía o Dispersión y/o Regeneración. Hasta un personaje que no sea personaje especial puede portar la Marca sagrada de los ancestrales, hasta dos en una Gran batalla y hasta tres en una Batalla gigantesca; esto no limita la inclusión de personajes especiales con esta marca.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6352-9073-8c1f-75fe" name="Resistencia a la magia (1)" hidden="false" targetId="eae7-760e-1a1e-47d7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
