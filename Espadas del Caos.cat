      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0916-0337-b1bf-c53f" type="max"/>
      </constraints>
      <rules>
        <rule id="d448-3ee2-ad42-1c82" name="Los Espadas del Caos" hidden="false">
          <description>La unidad de Elegidos del Caos o de Elegidos en corcel demoníaco si Archaón va montado debe equiparse con las marcas de Khorne, Slaanesh, Nurgle y Tzeentch, obteniendo los beneficios de todas ellas; además, tendrá un bonificador de +1 a su atributo de Iniciativa. La unidad no puede incluir Paladín elegido, aunque deberá incluir obligatoriamente Portaestandarte y Músico. Archaón debe unirse a esa unidad y no podrá abandonarla, y ningún otro personaje podrá unirse a esa unidad.</description>
        </rule>
        <rule id="ee39-7951-aa24-7689" name="Señor del Fin de los Tiempos" hidden="false">
          <description>La regla especial Presencia inspiradora de Archaón tiene un alcance de 18” en lugar de las 12” habituales.</description>
        </rule>
      </rules>
      <infoLinks>
