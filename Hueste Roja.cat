        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="731e-a752-70bf-a301" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="eb56-65d8-06e6-4bf1" name="Pendones de la parálisis venenosa" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="0287-bc7a-f40b-3e93" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="918b-6a4a-565c-ea22" type="max"/>
          </constraints>
          <profiles>
            <profile id="70ea-0a21-d174-777b" name="Pendones de la parálisis venenosa" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtiene la regla especial Ataques envenenados. Si ya tenían esa regla especial, sus ataques envenenados tendrán éxito con resultados de 5+ (en lugar de 6+ como es habitual).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="18d7-9a5b-cf1a-4526" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1555-cf8e-0aa0-2c53" name="Estandarte de Piel de Skaven" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="96dd-b87a-9044-4bed" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="103e-1667-12ef-94dc" type="max"/>
          </constraints>
          <profiles>
            <profile id="b1ad-1598-92cb-11a7" name="Estandarte de piel de Skaven" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Las miniaturas de la unidad se beneficiarán de la Regla Especial Odio (Skaven) y los Skaven Odiarán a las miniaturas que formen parte de la unidad que lo porta. La unidad causará Miedo a las miniaturas del ejercito Skaven. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="5003-6856-08b0-8f49" name="Odio (Skaven)" hidden="false"/>
          </rules>
          <infoLinks>
            <infoLink id="84be-79e1-05aa-5222" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule"/>
            <infoLink id="0a14-f621-cfbd-6d00" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="663b-938f-fa92-9408" name="Estandarte del Sol de Chotek" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5ed4-6578-f2de-294b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="43ec-ce0f-80e9-5721" type="max"/>
          </constraints>
          <profiles>
            <profile id="c323-872c-b501-f36a" name="Estandarte del Sol de Chotek" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Todos los disparos enemigos dirigidos contra la unidad en la que se encuentre este estandarte deberán aplicar un penalizador de -1 a sus tiradas para impactar. La unidad no podrá ser afectada por hechizos del Saber de las Sombras, ya fuesen lanzados por aliados o por el enemigo.   </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="99f2-fd74-389d-92c7" name="Blasones de Sotek" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e7ab-245d-da70-9aba" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="645b-dd55-3e8f-8c61" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b00-5322-b05b-52e2" name="Blasones de Sotek" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Todas las miniaturas de la unidad con la regla especial Cresta roja podrán repetir sus triadas fallidas para herir en los turnos en que hayan realizado una carga exitosa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
