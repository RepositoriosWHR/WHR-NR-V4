      <rules>
        <rule id="e9e0-ca7c-0c15-c10d" name="Vómito de troll" hidden="false">
          <description>En vez de atacar en combate cuerpo a cuerpo, un Troll puede causar un impacto automático de Fuerza 5 sin tirada de salvación por armadura a una miniatura enemiga en contacto peana con peana.</description>
        </rule>
        <rule id="93f1-47ee-20f8-2dc5" name="Troll montado" hidden="false">
          <description>Un personaje montado en un Troll amaeztrado suma +3 a su Potencia de unidad y tiene tamaño Muy grande.</description>
        </rule>
        <rule id="115a-fde8-e479-dcc2" name="Piel viscosa" hidden="false">
          <description>Los enemigos tienen un penalizador de -1 para impactarlo en combate cuerpo a cuerpo.</description>
        </rule>
      </rules>
