    <selectionEntry id="2cff-b900-21d9-6d22" name="Engendros monstruoso del Caos" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="48ab-9b88-1ee1-7b7c" value="2.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="170b-06ad-215f-f891" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="48ab-9b88-1ee1-7b7c" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3673-aaa8-d1d9-e6c2" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="48ab-9b88-1ee1-7b7c" type="max"/>
      </constraints>
      <rules>
        <rule id="6467-dd3e-ce63-66be" name="Vástago del Caos" hidden="false">
          <description>Determina al inicio de la batalla (antes del despliegue) los atributos de HA, F, R, H e I del Engendro monstruoso del Caos. Además, tira una vez en la siguiente tabla para determinar los efectos adicionales de las mutaciones del Engendro monstruoso del Caos:
1D6 Vástago del Caos
1 Ataques envenenados
2 Piel escamosa (4+)
3 Arma de aliento de Fuerza 1D6 
4 Resistencia mágica (3)
5 Golpe letal
6 Regeneración (4+)</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="fce9-37bd-74fb-29fa" name="Hostigadores" hidden="false" targetId="999c-d422-6c91-46dd" type="rule"/>
        <infoLink id="896b-267c-a181-4de5" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
        <infoLink id="5dc4-34d7-bff6-73f8" name="Monstruo" hidden="false" targetId="0518-1c98-54e1-371d" type="rule"/>
        <infoLink id="f507-dd04-1329-ea5e" name="Aura demoníaca (5+)" hidden="false" targetId="e5ed-5149-3d72-6aa4" type="rule"/>
        <infoLink id="5cea-239f-bbec-ec4b" name="Movimiento aleatorio (3D6)" hidden="false" targetId="a87e-08dc-36ec-ff50" type="rule"/>
        <infoLink id="0ddf-7659-f352-d207" name="Ataques aleatorios" hidden="false" targetId="f4cc-528c-a54e-8e28" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(2D6+2)"/>
          </modifiers>
        </infoLink>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="5eef-e03f-ed5c-67e9" name="New CategoryLink" hidden="false" targetId="5261726523232344415441232323" primary="true"/>
      </categoryLinks>
