          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ff44-c4c2-ebc8-4a72" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="95ad-e23c-fa9f-dcea" type="max"/>
          </constraints>
          <profiles>
            <profile id="c5b6-ca02-bbcd-b441" name="Ataque de raíces" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Se trata de un ataque de proyectiles con alcance 12” de Fuerza 5 y las reglas especiales Disparo rápido y Disparos múltiples (1D6).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7f67-e8a6-3803-cb51" name="Miríada de ramas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7423-33af-8293-bb53" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cb1e-3f68-2044-db07" type="max"/>
          </constraints>
          <profiles>
            <profile id="d6af-6c1c-a753-4262" name="Miríada de ramas" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje obtiene la regla especial Impactos por carga (1D6).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
