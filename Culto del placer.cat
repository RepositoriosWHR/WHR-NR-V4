        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a7c9-be80-08a2-aff3" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f8aa-49cf-0cc5-2419" type="max"/>
      </constraints>
      <rules>
        <rule id="335a-7560-1b5c-52c8" name="Fantasmas" hidden="false">
          <description> Tan sólo pueden unirse a los Maelithii personajes que sean también 
etéreos. </description>
        </rule>
        <rule id="8a93-5f3e-6be4-66de" name="Toque vampírico" hidden="false">
          <description>Cada vez que uno de los ataques de un Maelithi causa heridas a un oponente (que no tenga la regla especial No muerto o Demonio) en combate cuerpo a cuerpo, tira 1D6 por cada herida causada: con cada resultado de 5+, una de las miniaturas de la unidad podrá sanar una de las heridas sufridas con anterioridad durante la batalla (esto puede devolver al campo de batalla a los Maelithii retirados como baja).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9cb1-cb14-254e-a1d6" name="Etéreo" hidden="false" targetId="34c4-9e60-1a62-eda5" type="rule"/>
        <infoLink id="8d42-5a2e-20e8-476b" name="Hostigadores" hidden="false" targetId="999c-d422-6c91-46dd" type="rule"/>
