    <selectionEntryGroup id="d59d-080d-b5b9-4903" name="Objetos hechizados. Pigmeos. Curandero Pigmeo Consagrado de Brobat" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2e37-51f9-6d02-1a7d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9ecd-07c1-d556-249d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dd2b-c01f-6a47-3180" name="Fetiches de sanación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ff52-21ba-5dd3-f433" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="28b0-e9df-5921-f24b" type="max"/>
          </constraints>
          <profiles>
            <profile id="ab4f-f805-461b-26d6" name="Fetiches de sanación" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo Curandero Pigmeo con la regla especial Bendito de Beesbok. Al comienzo de la batalla, tras el despliegue, designa un personaje de Infantería de tu lista de ejército a 24” o menos del curandero y que no sea el propio curandero. La miniatura elegida no será retirada del campo de batalla cuando su atributo de Heridas quede reducido a cero, sino que permanecerá en el campo de batalla con una única Herida y el poder de los fetiches se consumirá.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="baff-6ec5-a889-1ce7" name="Fetiches de posesión" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5ebd-117e-309a-49b6" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b962-6eeb-0f1f-ac55" type="max"/>
          </constraints>
          <profiles>
            <profile id="7658-27d2-bb9b-e12c" name="Fetiches de posesión" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo Curandero Pigmeo con la regla especial Consagrado de Brobat. Al comienzo de la batalla, tras el despliegue, designa un personaje enemigo en el campo de batalla. Al inicio de cada fase de magia propia, el curandero podrá realizar un impacto automático de su Fuerza básica sobre el fetiche fuera de la secuencia de turno, siendo la miniatura designada quien reciba la herida (tira para herir contra la Resistencia de la miniatura designada); estos impactos se resuelven con la regla especial Poder de penetración. Cualquier miniatura que sufra una herida a consecuencia de estos impactos obtendrá un penalizador de -1 a su HA hasta el final del turno. Si la miniatura elegida es retirada del campo de batalla por cualquier motivo el poder de los fetiches se agotará.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
