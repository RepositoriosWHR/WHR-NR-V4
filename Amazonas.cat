              <profiles>
                <profile id="2549-8a09-714b-1f2a" name="Cetro del sol poniente" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Se trata de un Objeto portahechizos de nivel de energía 1D6. Contiene un hechizo de proyectil mágico que causa un número de impactos total al resultado obtenido en la tirada para determinar su nivel de energía; los impactos causados por este hechizo se resuelven con F5 y la regla especial Ataques solo flamígeros, y las heridas causadas no permiten tiradas de salvación por armadura.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="87e3-e154-7d3f-d5db" name="Azemandu, Corazón de la oscuridad" hidden="false" collective="false" import="true" type="upgrade">
