    </selectionEntryGroup>
    <selectionEntryGroup id="eef6-f355-c4de-4138" name="Recompensas del Caos. Nurgle" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="roster" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6446-ff64-c2fa-85c1" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="23f5-0659-1a77-503e" name="Tamaño descomunal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9d2d-cbdc-f02a-cb0c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5477-620c-91f0-a267" type="max"/>
          </constraints>
          <profiles>
            <profile id="2c66-aff6-08c4-1c3a" name="Tamaño descomunal" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene +1 a su Resistencia, pero también un -1 a su Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="86ea-319e-872b-96ac" name="Vigor de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2b0d-5111-26c2-feca" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="87f9-4eb5-1f05-dd1c" type="max"/>
          </constraints>
          <profiles>
            <profile id="7ad5-a28e-8512-6fa3" name="Vigor de Nurgle" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene +1 Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2c45-f1f3-8e03-3b8c" name="Putrefacción de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e3b4-ec29-240b-5d4e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fd00-863c-9f9d-3812" type="max"/>
          </constraints>
          <profiles>
            <profile id="200d-71cc-7289-954d" name="Putrefacción de Nurgle" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Al inicio de cada ronda de combate cuerpo a cuerpo, todas las miniaturas (amigas y enemigas) que no tengan la Marca de Nurgle (o sean Demonios de Nurgle o skaven del Clan Pestilens) en contacto con el personaje sufrirán una herida sin tirada de salvación con armadura con un resultado de 6 en 1D6 (tira por cada miniatura en contacto).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c47c-3da8-3071-a813" name="Vómito de corrupción" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="352b-27c0-576e-1c6d" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2b33-4134-9ac4-86c3" type="max"/>
          </constraints>
          <profiles>
            <profile id="a514-7c9b-d8b7-522a" name="Vómito de corrupción" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene un Arma de aliento de Fuerza 3 que no permite tirada de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="78de-96a5-ca20-2255" name="Arma de aliento" hidden="false" targetId="3438-0c27-972c-d418" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(F3, sin salvación por armadura)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="de02-685c-6679-6f68" name="Vitalidad de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="988a-222c-c7f6-a347" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="cb07-9e7d-815d-e91d" type="max"/>
          </constraints>
          <profiles>
            <profile id="b1dd-7bc6-1887-2d83" name="Vitalidad de Nurgle" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Al inicio de cada uno de tus turnos, el personaje recupera una de las heridas que hubiese sufrido previamente durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9d62-984a-8624-2835" name="Carcasa decadente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3b3a-c85d-cd23-51ae" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="53e8-4fb8-541a-3fca" type="max"/>
          </constraints>
          <profiles>
            <profile id="b9b3-877e-77b3-977c" name="Carcasa decadente" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene las reglas especiales Inmune a veneno y Ataques envenenados; los resultados de 5 natural al impactar se considerarán Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fa35-312c-8e4b-f941" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
            <infoLink id="bba4-d7eb-f028-773f" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="58ef-b091-fc9c-4b5d" name="Recompensas del Caos. Slaanesh" hidden="false" collective="false" import="true">
