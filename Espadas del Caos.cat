            <profile id="fd75-c36d-6da0-631f" name="Sanguijuela arcana" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">Por cada herida causada en combate cuerpo a cuerpo por el personaje tira 1D6; con un resultado de 5+, podrás añadir un dado de Energía o Dispersión durante la próxima fase de magia (según corresponda).</characteristic>
              </characteristics>
            </profile>
          </profiles>
