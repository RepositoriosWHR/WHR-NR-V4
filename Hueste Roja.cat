      <rules>
        <rule id="d216-52cf-cb67-526b" name="Guardián del sustento" hidden="false">
          <modifiers>
            <modifier type="append" field="name" value="(Kupa&apos;Ti)"/>
          </modifiers>
          <description>Kupa&apos;Ti tiene la regla especial Furia asesina. Al inicio de la batalla, tras el despliegue, puedes seleccionar una unidad de Guerreros eslizón de tu ejército; las miniaturas con la clave eslizón de la unidad obtendrán la regla especial Furia asesina (ten en cuenta que este efecto sólo se aplica sobre los Guerreros eslizón de la unidad y no sobre otros personajes que pudieran haber sido desplegados en ella).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9d8a-9dd0-3e4f-65c7" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
