    <selectionEntry id="b476-339f-86e8-06af" name="[R] - Gargolas voladoras de Barda Von Mickelstein" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8254-16bf-c001-1803" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9f2a-a3b2-b33a-f476" type="max"/>
      </constraints>
      <rules>
        <rule id="edab-e597-5d50-4ea9" name="Magia Barda Von Mickelstein" hidden="false">
          <description>Barda es un hechicero de nivel 1 que elige sus hechizos del Saber de Magia Oscura.</description>
        </rule>
        <rule id="53c0-fb3a-41ed-82c1" name="Desalmado" hidden="false">
          <description>Barda es un ser vivo, por lo que no está sujeto a las reglas para Demonios. Sin embargo, Barda tiene la regla especial Aura demoníaca (5+) y es Indesmoralizable mientras quede al menos una gárgola en la unidad. Si su unidad es destruida en resolución por la regla Inestable, Barda deberá realizar inmediatamente un chequeo de desmoralización, aplicando los mismos penalizadores que su unidad en ese combate y huirá con normalidad si lo falla.</description>
        </rule>
        <rule id="055b-e733-ddc4-9373" name="Lanza &quot;montada&quot;" hidden="false">
          <description>Aplican las reglas de Lanza para tropas montadas pese a ser Infantería.  </description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="2645-3642-69be-90b7" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="caa1-2541-491c-a621" name="Volar" hidden="false" targetId="670e-1a23-b1e1-6e6f" type="rule"/>
        <infoLink id="ba67-59ae-5466-0df2" name="Demonio" hidden="false" targetId="fc5c-7e1e-498d-ffb4" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(sólo gárgolas)"/>
          </modifiers>
        </infoLink>
        <infoLink id="43cd-3f5f-8506-15cd" name="Piel escamosa (4+)" hidden="false" targetId="478f-4519-03d3-5004" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(sólo gárgolas)"/>
          </modifiers>
        </infoLink>
        <infoLink id="e9ba-4598-a947-5533" name="Hostigadores" hidden="false" targetId="999c-d422-6c91-46dd" type="rule"/>
        <infoLink id="8828-e9ab-5aa4-3466" name="Mercenario" hidden="false" targetId="f693-0c5c-49bd-91e7" type="rule"/>
        <infoLink id="36e4-37d0-90f5-26c0" name="Regimientos de renombre" hidden="false" targetId="a07a-2bc2-efde-20d3" type="rule"/>
