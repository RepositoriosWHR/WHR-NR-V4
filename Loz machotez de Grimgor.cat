          <profiles>
            <profile id="c293-37d9-f222-e2c5" name="Kazko de loz taponez" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Yelmo. Proporciona a su portador una tirada de salvación especial de 4+, y será inmune al efecto de la regla especial Poder de penetración. Sin embargo, todos los Enanos obtendrán Odio contra el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1f40-1301-0761-0f1f" name="Yelmo" hidden="false" targetId="9607-7f57-879f-5c42" type="profile"/>
