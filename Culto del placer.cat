              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. El portador siempre herirá con un resultado de 4+, sin importar la Resistencia del objetivo, a menos que su tirada para herir fuese mejor que 4+.</characteristic>
              </characteristics>
            </profile>
