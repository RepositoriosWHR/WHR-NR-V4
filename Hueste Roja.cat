        </selectionEntry>
        <selectionEntry id="889a-5857-de37-6124" name="Desove sagrado de Caxuatn" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b10e-6792-5854-5117" type="max"/>
          </constraints>
          <profiles>
            <profile id="c298-39a7-0716-e658" name="Desove sagrado de Caxuatn" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove, que solo poseen los eslizones de las unidades de Dilofodones, Razordones y Salamandras, pueden colocarse en la segunda fila, tras las Bestias monstruosas de su unidad, y atacar a través de ellas con sus Lanzas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1846-d5d4-6dfa-ae4a" name="Desove sagrado de Conalxa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cc25-9c07-cff9-03fb" type="max"/>
          </constraints>
          <profiles>
            <profile id="8676-9fc6-9c79-bc43" name="Desove sagrado de Conalxa" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove obtienen las reglas especiales Caballería rápida y Explorador. Además, los disparos dirigidos hacia ellas reciben un penalizador de -1 para impactar.</characteristic>
              </characteristics>
