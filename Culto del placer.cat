          <profiles>
            <profile id="ce41-d456-d6e1-7360" name="Pinzas descomunales" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">El demonio obtiene un bonificador de +1 a su Fuerza en sus ataques en combate cuerpo a cuerpo y un bonificador de +1 en sus tiradas para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="93e6-7465-00f0-331f" name="Visiones lascivas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2feb-1a17-457a-9179" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="2293-9c5a-6a95-320b" type="max"/>
          </constraints>
          <profiles>
            <profile id="8536-451b-3f89-f820" name="Visiones lascivas" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">Al inicio de cada fase de combate, elige una miniatura dentro de un radio de 6” del demonio. La miniatura deberá superar un chequeo de Liderazgo tirando 3D6 y descartando el resultado menor o verá sus atributos de Habilidad de Armas, Ataques e Iniciativa a la mitad hasta el final de esa fase.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f955-13b9-652f-02eb" name="Brazos adicionales" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="cefb-add0-3b34-f083" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="9f04-2082-9732-5718" type="max"/>
          </constraints>
          <profiles>
