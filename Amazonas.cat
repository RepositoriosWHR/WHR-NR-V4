    <selectionEntry id="ca6e-9b40-7128-dfbc" name="[P] - Curandero Pigmeo" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6102-17ba-3db8-3a88" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="append" field="name" value="Consagrado de Brobat">
          <conditions>
            <condition field="selections" scope="ca6e-9b40-7128-dfbc" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="c24f-2da9-cc3a-f6c9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="append" field="name" value="Bendito de Beesbok">
          <conditions>
            <condition field="selections" scope="ca6e-9b40-7128-dfbc" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="b767-7b4c-404d-99f4" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="2.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="82d9-b616-f73a-1891" type="max"/>
      </constraints>
      <rules>
        <rule id="bd9c-d398-c617-bc0b" name="Magia Curandero pigmeo" hidden="false">
          <description>Nivel de magia 1. Puede aumentarse a 2 por +30 puntos. Debe elegir sus hechizos el Saber de la Vida o el Saber de la Muerte.</description>
        </rule>
        <rule id="482f-f3c4-4d35-3d11" name="Gemelos antagónicos" hidden="false">
          <description>Si incluyes dos Curanderos Pigmeos deberán conocer distintos saberes de la magia. Un Curandero pigmeo que tome sus hechizos del Saber de la Muerte obtiene la regla especial Consagrado de Brobat, y el que obtenga sus hechizos del Saber de la Vida obtiene la regla especial Bendito de Beesbok.</description>
        </rule>
      </rules>
      <infoLinks>
