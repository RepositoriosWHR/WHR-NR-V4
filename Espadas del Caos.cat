        <selectionEntry id="7ff2-0b68-fdbf-0762" name="Marca del Caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a24f-9879-6c46-ba5f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2814-7c64-ae79-5cbd" type="min"/>
          </constraints>
          <rules>
            <rule id="9004-f677-eb98-77f3" name="Marca del Caos. Kordel Shorgaar" hidden="false">
              <description>Kordel tiene las Marcas de Khorne, Slaanesh, Nurgle y Tzeentch, que le proporcionan las reglas especiales Resistencia mágica (2), Furia asesina (nunca pierde su Furia asesina), Indesmoralizable, Sangre fría, Poder de penetración, Ataques envenenados, Inmune a veneno y Ataques flamígeros; además, tiene un bonificador de +2 a su tirada de salvación especial, los enemigos tienen un penalizador de -1 para impactarle con proyectiles y los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas. Kordel puede unirse a cualquier unidad de Elegidos con cualquier Marca (pese a ser Indesmoralizable; si se une a una unidad que no tenga la Marca de Slaanesh, la unidad obtendrán la regla especial Indesmoralizables).</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="ef14-b4be-2d7e-a930" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Nunca la pierde)"/>
              </modifiers>
            </infoLink>
            <infoLink id="3fe7-504f-5097-504b" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
            <infoLink id="49e8-6b1d-2e34-e219" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="d28a-b30a-9386-a3fa" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
            <infoLink id="6ca1-d55c-c45f-836c" name="Sangre fría" hidden="false" targetId="fae6-f2eb-1a70-1084" type="rule"/>
            <infoLink id="b08f-a197-cd88-a230" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
            <infoLink id="047a-ac03-9657-6f8c" name="Ataques flamígeros" hidden="false" targetId="6985-722e-1ce4-b838" type="rule"/>
            <infoLink id="8511-b00b-2586-2fc0" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="5f0f-eba9-bd0d-3fa1" name="Marca de Khorne. Personajes" hidden="false" collective="false" import="true" targetId="eb2e-e161-ff39-cbf6" type="selectionEntry">
