              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">El portador causa Miedo. Además, cualquier miniatura que realice uno o más ataques en combate cuerpo a cuerpo contra el portador deberá superar antes un chequeo de Liderazgo: si lo falla, perderá uno de sus ataques (hasta un mínimo de 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="52ef-aa16-e15c-1d58" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
