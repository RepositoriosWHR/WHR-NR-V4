    <selectionEntry id="28e3-9425-a2e8-8c94" name="[R] - Jinetes de lobo hobgoblin de Oglah Khan" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="41fd-3b64-bb89-95cb" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="aeb6-30e3-ba22-c667" type="max"/>
      </constraints>
      <rules>
        <rule id="41fa-dad9-37a7-4784" name="Tiradores expertos" hidden="false">
          <description>Los arcos cortos de Oglah Khan y sus jinetes tienen un alcance de 24” en lugar de las 18” habituales. Además, pueden repetir los resultados de 1 en sus tiradas para impactar con proyectiles.</description>
        </rule>
        <rule id="ae4d-ae9a-79ea-2306" name="Jinetes de las estepas" hidden="false">
          <description>Tienen las reglas especiales Vanguardia y Caballería rápida, y pueden hacer uso de ella pese a su elevada tirada de salvación por armadura.</description>
        </rule>
      </rules>
      <infoLinks>
