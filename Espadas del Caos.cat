          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5ab3-8405-362b-a763" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d74d-1446-b2c6-0c43" type="max"/>
          </constraints>
          <profiles>
            <profile id="6514-75fa-ea61-7f34" name="Garras afiladas" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene +1 a su Fuerza y la regla especial Poder de penetración en sus ataques en combate cuerpo a cuerpo; las garras cuentan como Armas emparejadas (lo que le proporciona también +1 Ataque) pero el personaje no puede llevar armas ni escudos de ningún tipo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2f96-6f8c-0d27-e14d" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
            <infoLink id="c8f3-a4ad-ecce-d1fa" name="Arma emparejadas" hidden="false" targetId="45d0-c304-d4fd-5b8f" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a92f-1cf5-f0b9-b830" name="Mordisco venenoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d675-2257-edc0-a2f3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ded4-358a-5fac-427e" type="max"/>
