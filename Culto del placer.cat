          </constraints>
          <profiles>
            <profile id="e5c4-93c3-aeb7-312d" name="Desprecio acérrimo" hidden="false" typeId="9846-934f-6342-2762" typeName="Senda">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">El personaje obtiene la regla especial Odio (¡todos los enemigos!).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a37a-62ca-0717-1a59" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
