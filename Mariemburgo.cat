            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="71eb-814e-6a9a-56e8" type="max"/>
          </constraints>
          <profiles>
            <profile id="b22c-8e54-08eb-1947" name="Talismán de la tormenta" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Cada miniatura que obtenga un resultado de 1 en el dado en sus tiradas para impactar contra el portador en combate cuerpo a cuerpo sufrirá un impacto de F5.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e0eb-a60e-663f-32ac" name="Moneda de la suerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="096e-3259-a008-03ad" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="520f-8f58-5c5c-3253" type="max"/>
          </constraints>
          <profiles>
            <profile id="66f1-6839-f064-6a79" name="Moneda de la suerte" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">El portador podrá repetir los resultados de 1 natural en las tiradas de salvación por armadura que efectúe.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6427-700a-cf68-5a3a" name="Zafiro de la montaña" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4ed7-16d2-1b4a-2dda" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0991-2414-bca6-87c2" type="max"/>
          </constraints>
          <profiles>
            <profile id="08f6-c462-e1cd-2727" name="Zafiro de la montaña" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">El portador tiene la regla Resistencia a la magia (2). Además, tendrá una tirada de salvación especial de 2+ contra la primera herida que fuese a sufrir durante la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3f90-dcd3-fdac-f3d1" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
