            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c193-db34-2110-39ab" type="max"/>
          </constraints>
          <profiles>
            <profile id="b783-d8d4-e008-7869" name="Protección de las hadas" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">La tirada de salvación de Aura demoníaca de este personaje se convierte en una tirada de salvación especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8bbf-c785-6d0e-66dd" name="El atolondramiento de los diablillos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="57f3-b2e6-f603-7dab" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7400-9124-2e32-93f1" type="max"/>
          </constraints>
          <profiles>
            <profile id="f0fa-ec1e-dccc-f64e" name="El atolondramiento de los diablillos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Objeto portahechizos de nivel 3. Es un hechizo de Maldición con un alcance de 18” y Permanece un turno. Por la duración del hechizo, la unidad objetivo obtiene la regla especial Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c776-a0eb-3681-ca94" name="Nido de geniecillos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4cb4-3170-05fe-beca" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b011-dad3-32b5-ba73" type="max"/>
          </constraints>
          <profiles>
            <profile id="a1eb-d348-43f8-3182" name="Nido de geniecillos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Las tiradas para impactar en combate cuerpo a cuerpo exitosas contra el espíritu del bosque deberán repetirse.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1bd4-6bc2-bddb-2fd0" name="Brotes ancestrales de Savia joven" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="8b38-8b4a-b46e-880c" name="Brote del Árbol de los Susurros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1a40-c509-6bff-b79d" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="fedb-b534-69f1-7e72" type="max"/>
          </constraints>
          <profiles>
            <profile id="1658-bfd5-3e1c-b8ab" name="Brote del Árbol de los Susurros" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Las unidades que reciban una carga de una unidad en la que se encuentre este estandarte solamente podrán elegir Mantener la posición como reacción a una carga (si fallan su chequeo de Miedo, en vez de huir, durante esa fase de combate sólo impactarán con resultados naturales de 6).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5dea-13dd-08bd-8edc" name="Brote del Olmo Guardián" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="608b-7c3e-1f2b-6851" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7ba6-1f48-1241-d748" type="max"/>
          </constraints>
          <profiles>
            <profile id="fbb8-f7a5-55d3-debf" name="Brote del Olmo Guardián" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Los ataques de proyectiles sin la regla especial Ataques mágicos tienen un penalizador de -1 en sus tiradas para herir contra las miniaturas de esta unidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="432d-d1d8-7ffe-8148" name="Brote del Sauce Flexible" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6c73-dbce-0c5f-072b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="721a-ca89-c802-8971" type="max"/>
          </constraints>
          <profiles>
            <profile id="db2e-1ee2-16f6-3a03" name="Brote del Sauce Flexible" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">La unidad gana la Regla especial Espíritus astutos. Si ya tienen esta regla ganan la regla especial Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2e9d-763e-dde3-d31c" name="Espíritus astutos" hidden="false" targetId="4950-cdc7-e9dd-d694" type="rule"/>
            <infoLink id="e9d9-5de4-e951-bba9" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Si ya son espiritus astutos)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6b7a-1249-cffc-b7cd" name="Brote del Brezo Espinoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4a8b-f709-dc8c-dfcf" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="daf5-c2a8-1f47-5d91" type="max"/>
          </constraints>
          <profiles>
            <profile id="2f8d-0a8a-456e-92dd" name="Brote del Brezo Espinoso" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Las unidades enemigas que declaren una carga contra esta unidad sufren un penalizador de 1D3” a su distancia de carga y se considera que cargan a través de Terreno Difícil.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a50b-fc08-ec76-3dfc" name="Vástago del Roble Furioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ac90-2564-8620-0bb0" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e707-87b7-fc5a-877b" type="max"/>
          </constraints>
          <profiles>
            <profile id="c013-c9af-bdb2-7d5c" name="Vástago del Roble Furioso" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Las miniaturas de unidad que lo porten obtendrán la regla especial Furia asesina y si ya disponían de esta regla no perderán su Furia asesina aunque sea derrotada en combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a759-f6b4-cc06-1389" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0ced-09d5-6dfe-3a25" name="Vástago de Madera de Bruja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="fdee-d467-3122-494e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8f53-23de-2bd6-1284" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a8b-b6de-2f9b-07a0" name="Vástago de Madera de Bruja" hidden="false" typeId="8b02-3ef3-2ac5-04a7" typeName="Brote ancestral">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="edd7-1c9a-1536-6195">Otorga a la unidad Resistencia mágica (2)</characteristic>
