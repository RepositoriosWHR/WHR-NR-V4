            <profile id="3383-5a1e-03ec-cd55" name="Filoz Zazkaelfoz" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Solo Orcos negros. Rebanadoras emparejadas. Al inicio de cada ronda de combate, elige una miniatura enemiga en contacto peana con peana con el portador: hasta el final del turno, el valor del atributo de Iniciativa del portador pasa a ser el valor del atributo de Iniciativa del enemigo elegido.</characteristic>
              </characteristics>
