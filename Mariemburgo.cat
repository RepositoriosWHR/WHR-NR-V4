    <selectionEntry id="18d0-f195-6aff-0e4d" name="[R] - Bucaneros de Van Klumf" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="68ea-5817-6848-061b" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ecfb-b5f7-3d51-1994" type="max"/>
      </constraints>
      <rules>
        <rule id="8fa8-1aae-d850-5af2" name="Bucaneros de por vida" hidden="false">
          <description>Los Bucaneros tienen la regla Cruzar (Obstáculos) y pueden repetir sus tiradas fallidas para impactar en el turno en el que realizaron la carga. Además, durante el turno en que cargan con éxito a una unidad que se encuentra tras cobertura, no sufren penalizadores al atacar. </description>
        </rule>
        <rule id="6d85-4749-5114-8fbb" name="Combate en mar" hidden="false">
          <description>Si los Bucaneros se encuentran en un elemento de escenografía acuático, los oponentes tendrán un penalizador de -1 al impactarles en cuerpo a cuerpo y los bucaneros obtendrán un bonificador de +1 a impactar en cuerpo a cuerpo. Este bono no puede usarse contra unidades con Cruzar (Elementos acuáticos).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="b002-4b5e-8d28-bf6d" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="a87d-665e-7617-614f" name="Mercenario" hidden="false" targetId="f693-0c5c-49bd-91e7" type="rule"/>
        <infoLink id="8b42-6f7b-78e8-226c" name="Vanguardia" hidden="false" targetId="1bd0-0982-01a3-ed62" type="rule"/>
        <infoLink id="a192-867f-d9eb-ed3e" name="Cruzar (obstáculos)" hidden="false" targetId="5dfd-3f02-cece-1e02" type="rule"/>
        <infoLink id="436d-2ca0-1ee2-cdb7" name="Regimientos de renombre" hidden="false" targetId="a07a-2bc2-efde-20d3" type="rule"/>
        <infoLink id="a83d-d2d9-17ce-5590" name="Lealtad" hidden="false" targetId="82f8-7857-d2a2-c2e1" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Marienburgo)"/>
          </modifiers>
        </infoLink>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="477a-8b10-207f-0fa8" name="New CategoryLink" hidden="false" targetId="5370656369616c23232344415441232323" primary="true"/>
      </categoryLinks>
