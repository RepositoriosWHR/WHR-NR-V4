            </selectionEntry>
            <selectionEntry id="d5c7-a684-559e-b835" name="Ramaje punzante" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6d8a-c5e0-1451-3590" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2143-a3c9-c934-b422" type="min"/>
              </constraints>
              <profiles>
                <profile id="6919-b376-6746-555f" name="Ramaje punzante" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Sus ataques en combate cuerpo a cuerpo se resuelven con la regla especial Poder de penetración.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="b910-a696-e602-1e0d" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="bf4e-4278-4bc3-e5ed" name="Metamorfosis" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7010-5d28-b8d3-9830" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8213-638c-c32c-5f83" type="min"/>
              </constraints>
              <profiles>
                <profile id="b643-f9dd-1457-f01c" name="Metamorfosis" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Al inicio de cada fase de combate, el personaje debe elegir una de las formas de árbol listadas a continuación. No puede usar la misma forma de árbol en dos fases de combate consecutivas. Los efectos durarán hasta el inicio de la siguiente fase de combate. Puedes elegir una única unidad de Dríades de tu ejército para que gane este rasgo de manera adicional por +3 puntos por miniatura. La unidad debe obtener la regla especial Hostigadores, pasa a considerarse Unidad especial y gana la capacidad de elegir una de las formas de árbol de la misma manera que el personaje. Tanto el personaje como la unidad deberán escoger la misma forma de árbol en cada fase de combate cuerpo a cuerpo. En este caso, el Espectro del bosque deberá unirse a esa unidad de Dríades y no podrá abandonarla. Ningún otro personaje podrá unirse a la unidad.

Forma de abedul: Obtiene +1 a sus Ataques.
Forma de roble Obtiene +1 a la Fuerza.
Forma de fresno Los ataques sin las reglas especiales Ataques mágicos y/o Ataques flamígeros tienen unpenalizador de -1 en sus tiradas para herir contra el espíritu del bosque. Adicionalmente, obtiene la regla especial Piel escamosa (5+) o +1 si ya tenía esta regla especial.
Forma de sauce Las miniaturas que dirijan uno o más ataques en combate cuerpo a cuerpo contra el espíritudel bosque sufrirán un penalizador de -1 a impactar y -1 a su Iniciativa.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="659d-b0ec-1226-67c5" name="Liquen del eterno rencor" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e84b-d601-b9eb-8472" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="38b6-5d98-fb0e-3604" type="min"/>
              </constraints>
              <profiles>
                <profile id="7d70-b8d4-606a-b5a8" name="Liquen del eterno rencor" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El espíritu del bosque y su unidad obtienen la regla especial Odio (Caos, Pielesverdes y Enanos).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="9656-0cf6-95b9-86a9" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
                  <modifiers>
                    <modifier type="append" field="name" value="(Caos, Pielesverdes y Enanos)"/>
                  </modifiers>
                </infoLink>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="points" value="0.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
