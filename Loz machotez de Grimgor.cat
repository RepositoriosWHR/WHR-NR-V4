            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="abfe-e2a5-7357-efd7" type="max"/>
          </constraints>
          <profiles>
            <profile id="5cc1-d7fc-8dbe-de6b" name="Los Kuernoz del Gran Kabeztro" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador obtiene la regla especial Impactos por carga (1D3).</characteristic>
