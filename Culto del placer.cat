    <selectionEntry id="b3da-043b-beb3-3485" name="[E] - Shyishet, la muerte alada" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="increment" field="15ef-af70-9363-0155" value="1.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="f103-3153-75a5-614c" type="atLeast"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="15ef-af70-9363-0155" type="max"/>
      </constraints>
      <rules>
        <rule id="8cd9-c6a9-652f-7382" name="Magia Shyishet, la muerte alada" hidden="false">
          <description>Shyishet es una hechicera de nivel 2 que siempre utiliza el Saber de la Muerte.</description>
        </rule>
        <rule id="159f-cf8a-1533-91b6" name="Embestida del Viento Amatista" hidden="false">
          <description>Shyishet tiene la regla especial Resistencia mágica (1). Además, sus ataques en combate cuerpo a cuerpo tienen la regla especial Heridas múltiples (2), excepto contra miniaturas con la regla especial Demonio o No muerto.</description>
        </rule>
        <rule id="f3db-2295-f47b-ff49" name="Marca del Caos" hidden="false">
          <description>Shyishet porta la Marca de Slaanesh, que le otorga las reglas especiales Inmune a psicología, Poder de penetración y Sangre fría.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="ec3d-5a9c-50d0-2a96" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
