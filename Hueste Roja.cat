      <selectionEntries>
        <selectionEntry id="ea36-0792-3cfb-fe48" name="Estandarte de la Furia reptante" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="c355-dc3c-7c9b-1111" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="21c6-ffbf-02d7-7800" type="max"/>
          </constraints>
          <profiles>
            <profile id="134e-35ec-1593-a7b5" name="Estandarte de la Furia reptante" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Solo personajes o unidades con la regla Cresta roja. El portador y las miniaturas de la unidad con la regla especial Cresta roja obtienen un bonificador de +1 Ataque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
