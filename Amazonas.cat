    <selectionEntry id="2695-cbaf-4ec7-0692" name="[E] - Madre Samantha" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="046a-1c36-705e-1c0e" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="2083-0134-3281-dcbc" value="1.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="f31c-57e7-e8d6-a6de" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="1fcf-7bc5-f4b9-ba51" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2083-0134-3281-dcbc" type="max"/>
      </constraints>
      <rules>
        <rule id="9736-a042-3333-c440" name="Magia Madre Samantha" hidden="false">
          <description>Es una hechicera de nivel 4 que toma sus hechizos del Saber de los Cielos y/o del Saber de la Vida.</description>
        </rule>
        <rule id="bcdf-b1bf-4f92-ed20" name="La amazona" hidden="false">
          <description>Madre Samantha conoce dos hechizos adicionales (para un total de seis) y tiene una tirada de salvación especial de 4+. Además, el poder de la regla especial Inmortal de Madre Samantha aumenta a Regeneración (4+) y Resistencia a la magia (2). Adicionalmente, todas las unidades de Amazonas amigas a 12” o menos de Samantha podrán repetir sus chequeos fallidos de desmoralización.</description>
        </rule>
        <rule id="58f5-eacd-5e3d-3f91" name="Símbolo de unión" hidden="false">
          <description>Si Madre Samantha es la general del ejército, hasta una unidad de Devotas de Koka-Kalim y hasta una unidad de Guerreras tribales podrán descontarse del porcentaje destinado a las Unidades Básicas (aunque seguirán siendo Unidad Especial). Adicionalmente, deberás incluir a las Guardianas Serpiente (ver más abajo); Madre Samantha deberá unirse a esa unidad, no podrá abandonarla y tampoco podrá contener otras personajes o personajes especiales.</description>
        </rule>
        <rule id="b580-0a72-15f8-f8ae" name="Plegarias a la serpiente Madre Samantha" hidden="false">
          <description>Madre Samantha es una Sacerdotisa serpiente que conoce todas las Plegarias a la Serpiente y puede lanzar hasta dos de ellas en cada fase de magia propia con nivel de energía 4.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="b3f2-12ed-3b58-7a5c" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="d8a1-7c27-9c3d-454c" name="Cruzar (bosques)" hidden="false" targetId="9d01-387d-269d-5a44" type="rule"/>
        <infoLink id="b06f-1b77-1c1e-6ba8" name="Esquivar (5+)" hidden="false" targetId="053b-3b96-b53b-6944" type="rule"/>
        <infoLink id="4fad-57d3-f93b-8817" name="Leyenda" hidden="false" targetId="d331-afa2-533e-c273" type="rule"/>
        <infoLink id="faf4-1041-f417-ffe8" name="Regeneración (4+)" hidden="false" targetId="6605-7689-3444-dccd" type="rule"/>
        <infoLink id="3256-e37d-ba59-1335" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
        <infoLink id="0622-02f7-2482-1cf9" name="Inmune al miedo" hidden="false" targetId="9dea-6e2e-9d06-f5f7" type="rule"/>
