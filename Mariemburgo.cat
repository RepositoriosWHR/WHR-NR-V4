    <selectionEntry id="6f5f-4442-3511-dbbf" name="[R] - Despojadores de las tierras Yermas" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="45e2-4898-05ad-ce97" type="max"/>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7b71-b6f4-1a19-dfc9" type="max"/>
      </constraints>
      <rules>
        <rule id="446e-f8d9-8fe8-e713" name="Despojadores de las tierras Yermas" hidden="false">
          <description>Ogloth y todos los carros que se incluyan formarán una única unidad.</description>
        </rule>
        <rule id="a2b7-795d-f050-bfde" name="Sádico" hidden="false">
          <description>El carruaje en el que estuviese montado Ogloth puede repetir la tirada de dado para determinar los impactos causados por la regla especial Impactos por carga.</description>
        </rule>
        <rule id="ab97-d965-60e4-96ec" name="Despreciables" hidden="false">
          <description>Una miniatura con esta regla no puede desplegarse a menos de 6” otras miniaturas sin ella. Las miniaturas con esta regla especial no causan Pánico a las unidades aliadas al huir o ser destruidas.  </description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="49a0-2767-68c3-c238" name="Carro" hidden="false" targetId="c761-ad12-6530-fab7" type="rule"/>
