          <profiles>
            <profile id="756f-80db-35a9-b1ef" name="Acólito Cultista del placer" hidden="false" typeId="9846-934f-6342-2762" typeName="Senda">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f401-b429-2452-4e30">Solo Príncipe Oscuro o Noble Oscuro. Gana la regla especial Poder de penetración. También obtiene la clave hechicero y nivel de magia 1 que siempre elige sus hechizos del Saber de Slaanesh.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9237-755b-3c1c-f6f3" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="3543-61f3-1156-518e" name="Nivel 1" hidden="false" collective="false" import="true" targetId="6930-ec9b-4df6-24c5" type="selectionEntry"/>
            <entryLink id="bd50-e0d5-07c0-9b59" name="Clave: Hechicero" hidden="false" collective="false" import="true" targetId="614d-bf3c-8921-4b1d" type="selectionEntry"/>
          </entryLinks>
