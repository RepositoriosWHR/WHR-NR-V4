            <profile id="c5c5-fe55-d874-322f" name="Emblema de Manann" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo personajes con Bendición de Manann. El portador y la unidad con la regla Bendición de Manann en la que se encuentre podrán repetir las tiradas para impactar durante los turnos que hayan realizado una carga exitosa.</characteristic>
              </characteristics>
            </profile>
