      <selectionEntries>
        <selectionEntry id="3187-ef03-3aa7-4525" name="Estandarte sagrado de Nurgle" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="3ee8-a718-f917-5ee5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6791-61cd-cdee-7ab9" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b08-7796-d04c-c8f0" name="Estandarte sagrado de Nurgle" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Sólo miniaturas con la Marca de Nurgle. El portador (y la unidad en la que se encuentre) realizarán sus ataques envenenados también con resultados de 5 en sus tiradas para herir; además, todos los impactos contra la unidad que no tengan la regla especial Ataques mágicos tendrán un penalizador de -1 en sus tiradas para herir contra la unidad (recuerda que un resultado de 6 en una tirada para herir siempre se considera un éxito). </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
