            <profile id="a328-2696-0903-751e" name="Hemónculo" hidden="false" typeId="4a21-6ede-290c-54cb" typeName="Recompensa del Caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ac18-bd08-5794-1799">Sólo hechiceros. Una vez por fase de magia, tras haber lanzado los dados para lanzar un hechizo, el hechicero puede declarar que utiliza al hemónculo para aumentar el valor de su tirada de lanzamiento en +1D3. Si lo hace, sufrirá Estupidez durante su siguiente turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cf53-7ebd-9efa-11be" name="Estupidez" hidden="false" targetId="eff6-2d64-db5e-d51e" type="rule"/>
