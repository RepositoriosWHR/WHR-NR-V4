          </constraints>
          <profiles>
            <profile id="51a5-3397-efba-b3c0" name="Rubí de Chaqua" hidden="false" typeId="2cee-fb80-f7af-6efc" typeName="Talismán mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Solo miniaturas con la regla especial Cresta Roja. Otorga a su portador la regla especial Piel escamosa (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="206b-f391-99ca-2eb8" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4732-1b03-9185-c897" name="Objetos hechizados. Hueste roja" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5acd-0ac1-526e-0b3f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="422c-8d15-87b4-6dd8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="81a5-ac8b-3443-8ec4" name="Cabeza maldita" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="b080-76f4-6a58-fdd3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5996-b613-bdbe-c0d0" type="max"/>
          </constraints>
          <profiles>
            <profile id="890b-7fa1-e76b-2ab9" name="Cabeza maldita" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. Sólo eslizones. Puede utilizarse al comienzo de cualquier fase de magia propia. Selecciona un personaje o monstruo enemigo a 18” o menos del portador; hasta el comienzo de tu siguiente fase de magia, todos los impactos que sufra la miniatura seleccionada obtendrán la regla especial Heridas múltiples (2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8a7d-f6c6-d9eb-5c42" name="Pájaro de Chotek" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="0694-dbfe-fb95-7786" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ed6e-3517-5db5-2933" type="max"/>
          </constraints>
          <profiles>
            <profile id="6f63-3939-4c49-fcfd" name="Pájaro de Chotek" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. Puede utilizarse al inicio de cualquier turno de los hombres lagarto. Hasta el inicio del siguiente turno de los hombres lagarto, todas las miniaturas (amigas y enemigas) con la regla especial Volar o Flotar en el campo de batalla no podrán hacer uso de dichas reglas. Además, todas las unidades (amigas y enemigas) que disparen tendrán un penalizador de -1 en su tirada para impactar durante dicho turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3d49-2f6e-c30c-2296" name="Colgante reluciente de Chotek" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8a67-2171-e0af-a0b5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="95c3-f0de-1c7d-162c" type="max"/>
          </constraints>
          <profiles>
            <profile id="6bec-8e97-8359-9cc8" name="Colgante reluciente de Chotek" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. Puede utilizarse al inicio de cualquier fase de combate cuerpo a cuerpo. Todos los enemigos en contacto peana con peana con el portador verán su Iniciativa reducida a cero hasta el final de la fase de combate cuerpo a cuerpo en curso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6c5e-67d1-3177-7518" name="Cuenco Sagrado de Vinatl" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="bd79-c36e-8524-6978" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b960-ce14-e344-1b35" type="max"/>
          </constraints>
          <profiles>
            <profile id="fa9c-dff6-8a09-4171" name="Cuenco Sagrado de Vinatl" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y cualquier unidad de Eslizones a la que se una obtendrán la regla especial Furia asesina (no afecta a los Kroxigores ni a las monturas).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0a6d-1e02-e246-11a5" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="429d-4a48-5bf8-920f" name="Tambor de guerra de Xahutec" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="37d9-4900-3760-82d9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="dee7-95fb-2626-7888" type="max"/>
          </constraints>
          <profiles>
            <profile id="b819-9eb6-b593-7d07" name="Tambor de guerra de Xahutec" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y la unidad en la que se encuentre superarán automáticamente todos los chequeos que deban realizar para marchar cuando tengan enemigos cerca. Adicionalmente, todas las unidades amigas que intenten reagruparse a 12” o menos del portador podrán sumar +1 a su atributo de Liderazgo para ese chequeo. El portador se considerará Músico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c67f-dc34-ed61-e167" name="Veneno de la ranita de luz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="70c3-a127-15f0-a81a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5ee4-dc5c-5e8b-74b0" type="max"/>
          </constraints>
          <profiles>
            <profile id="e9c6-0e35-a9e4-d61c" name="Veneno de la ranita de luz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador obtiene las reglas especiales Ataques envenenados y Ataques mágicos. Si ya disponía de la regla especial Ataques envenenados, estos surtirán efecto con un resultado de 5+ en lugar del 6+ habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="72cc-fd2c-6973-74d6" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="7466-e7aa-9194-2013" name="Ataques mágicos" hidden="false" targetId="7cc5-d3fc-a37a-3d4a" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="37c3-ad77-87e3-a585" name="Pendiente del Carnosaurio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a86e-6bc0-2941-d117" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ae84-217b-fac1-a6ea" type="max"/>
          </constraints>
          <profiles>
            <profile id="b2c8-1440-de97-198f" name="Pendiente del carnosaurio" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Si el portador sufre una o más heridas, obtendrá la regla especial Furia Asesina, y no la perderá aunque pierda el combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="610c-f334-3d16-a3b2" name="Embrujo del guerrero jaguar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="b4b9-2afa-f94a-17ac" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7c14-68ed-1253-a816" type="max"/>
          </constraints>
          <profiles>
            <profile id="02a3-2d4d-0e12-8dad" name="Embrujo del guerrero jaguar" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador pasa a tener Movimiento 9 y la regla especial Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9a09-f3d8-b01f-6afa" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7e2e-2c88-7a31-32cd" name="Objetos hechizados. Hueste roja. Cresta roja" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef12-28e1-c92e-c594" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e79e-d5c5-b3c5-41ca" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="54df-f5b9-7bb9-ee1b" name="Amuleto de la premonición" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="36a5-afba-10c1-0141" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5bdc-e39d-ad41-096d" type="max"/>
          </constraints>
          <profiles>
            <profile id="f287-e474-9164-0548" name="Amuleto de la premonición" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Solo Cresta roja. Al inicio de la batalla, tira 1D3: ése será el número de tiradas que el portador podrá repetir durante la partida. Esas tiradas pueden ser tiradas para impactar, tiradas para herir, tiradas de salvación (por armadura o especiales), chequeos de atributo o dados de energía o dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="53a1-f9ba-1326-1aa7" name="Artefactos arcanos. Reliquias. Hueste roja" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6255-64f5-4285-0f39" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ba92-ea56-b8e7-f96a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7feb-dba7-4185-594c" name="Manipulador de la fatalidad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="3fed-18b0-5d53-bee2" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="38e4-71ea-a137-9df8" type="max"/>
          </constraints>
          <profiles>
            <profile id="6508-1b50-7f0a-2210" name="Manipulador de la fatalidad" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Al inicio de cada fase de magia, tras la tirada para determinar los vientos de la magia y tiradas de canalización, puedes decidir aumentar o disminuir en uno la reserva de dados de ambos bandos para dicha fase. Además, siempre que un hechicero (amigo o enemigo) a 12” o menos del portador sufra una disfunción mágica, puedes aumentar o disminuir en 1 el resultado de la tirada en la tabla de disfunciones mágicas (cualquier resultado de la tirada en dicha tabla inferior a 2 se considera 2 y cualquier resultado superior a 12 se considera 12).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="364b-0492-6c75-1bf7" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="46b6-0703-466c-ca5a" name="Amuleto de Xapati" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="dada-827c-788b-0789" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ce2d-2228-8a2b-434e" type="max"/>
          </constraints>
          <profiles>
            <profile id="eb3d-b530-cc22-2352" name="Amuleto de Xapati" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Proporciona a su portador la regla especial Resistencia mágica (3). Si un hechizo es dispersado utilizando los dados proporcionados por el amuleto, el hechicero que lo lanzó deberá obtener un resultado igual o inferior a su nivel de magia en 1D6 o sufrirá una herida sin tirada de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="086b-8e12-cada-027a" name="Resistencia mágica (3)" hidden="false" targetId="c9ab-a12d-0ce9-430c" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="e2de-b2d6-5fa8-1270" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="92de-99d9-96f8-b3b3" name="Cubo de oscuridad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="34cb-a5e0-373a-9568" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="deb1-eb6f-2dea-3b6e" type="max"/>
          </constraints>
          <profiles>
            <profile id="bfb2-31f4-e0d3-a0ab" name="Cubo de oscuridad" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Un solo uso. Puedes utilizar el Cubo de oscuridad en el momento que uno de tus oponentes lanzase con éxito uno de sus hechizos. El hechizo será dispersado automáticamente (siempre y cuando no haya sido lanzado con Fuerza irresistible). Además, efectúa una tirada de 1D6: con un resultado de 4+, la fase de magia concluirá de inmediato.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="e747-cf91-3f82-e92d" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9945-b656-b388-527c" name="Artefactos arcanos. Reliquias. Hueste roja. Gran oráculo eslizón cresta roja" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cdfe-666c-2e4e-b36f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="96c5-7979-6300-9f37" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cbe3-7bb5-3127-fb42" name="Corona de iluminación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1b73-4ac0-56b2-749c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4914-7377-5abf-0940" type="max"/>
          </constraints>
          <profiles>
            <profile id="7808-a75a-a270-03b8" name="Corona de iluminación" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Sólo Gran oráculo eslizón Cresta roja. El portador conoce un hechizo adicional, obtiene un bonificador de +1 en sus tiradas de lanzamiento de hechizos y podrá tomar sus hechizos de uno de los ocho saberes básicos o de Alta Magia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="fcb5-44c2-20b6-d7ee" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2ead-fda9-b17e-b4c6" name="Artefactos arcanos. Hueste roja" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1024-2f80-ff79-73c1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4ff0-b7f9-e6bd-3cb0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d298-4eab-77c5-bf63" name="Diadema de poder" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8578-aab1-1685-9f2c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="65c3-47ff-4184-1848" type="max"/>
          </constraints>
          <profiles>
            <profile id="470c-ceda-e3cc-7fb6" name="Diadema de poder" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El portador obtiene Resistencia mágica (1). Al final de cada fase de magia puedes guardar hasta 2 de los dados no utilizados, que podrás utilizar en una fase de magia posterior (ya sea como dados de energía o de dispersión).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ed17-df81-11c1-f276" name="Resistencia mágica (1)" hidden="false" targetId="eae7-760e-1a1e-47d7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3feb-52b0-10e7-58da" name="Amuleto de la maldición de Tepok" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e847-b83a-b88c-55d4" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a35c-d216-bc81-da57" type="max"/>
          </constraints>
          <profiles>
            <profile id="3336-dd2b-c933-6a55" name="Amuleto de la maldición de Tepod" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Un solo uso. Puede utilizarse cuando un hechicero enemigo sufra una disfunción mágica, obligándole a repetir la tirada que obtuvo en esa tabla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
