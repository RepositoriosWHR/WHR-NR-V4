              <conditions>
                <condition field="selections" scope="69f0-c8ec-d7d1-eb54" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8fcf-6a59-f0de-c418" type="equalTo"/>
