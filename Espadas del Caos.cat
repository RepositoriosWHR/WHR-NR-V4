    <selectionEntry id="318c-a81a-ab22-37e6" name="Hechicero de los Espadas del Caos" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="73c0-2c4d-6065-ab54" name="Magia Hechicero de los espadas del Caos" hidden="false">
          <description>Es un hechicero de nivel 1. Puede convertirse en hechicero de nivel 2 por +30 puntos. Puede elegir sus hechizos de entre los Saberes de la Muerte, de los Cielos, del Fuego, de las Sombras, de Magia Oscura y/o del Saber de su Dios del Caos y puede elegir sus hechizos de dos o más de los saberes listados.</description>
        </rule>
      </rules>
      <infoLinks>
