              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">Sólo Cacique Pigmeo. Otorga un bonificador de +1 la tirada de salvación por armadura de su portador y causa Miedo. Además, proporciona una tirada de salvación especial de 5+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="23c3-546b-942f-a645" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
          </infoLinks>
