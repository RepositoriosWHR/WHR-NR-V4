              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Obtiene nivel de magia 1 en uno de los 8 saberes básicos (a tu elección) y la clave hechicero. El personaje pierde su Armadura ligera y no podrá equiparse con armaduras o escudos de ningún tipo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
