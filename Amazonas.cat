        <constraint field="selections" scope="parent" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1907-2e76-42bd-e179" type="max"/>
      </constraints>
      <rules>
        <rule id="19a4-f1c2-3be8-6eac" name="Devoradores de espíritus" hidden="false">
          <description>Siempre que una miniatura con la clave pigmeos sea retirado como baja de una unidad a 8” o menos de los Espíritus antepasados, tira 1D6: por cada resultado de 4+, los Espíritus antepasados recuperarán una herida sufrida previamente durante la batalla.</description>
        </rule>
        <rule id="5265-ed9f-44d8-5c39" name="Invocación chamánica" hidden="false">
          <description>Los Espíritus antepasados pueden marchar siempre que se encuentren al inicio del turno a 12” o menos del Curandero Pigmeo que permitió su inclusión.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="127c-2d62-736f-1bbc" name="Enjambre" hidden="false" targetId="d477-174e-9843-a1b7" type="rule"/>
