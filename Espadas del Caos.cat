        <selectionEntry id="f059-02a4-ba86-2a6d" name="Espada cambiante del Caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9543-710b-d8f8-1b6f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d8ed-821d-b99b-8d06" type="max"/>
          </constraints>
          <profiles>
            <profile id="8b7f-f53d-ad17-0c6d" name="Espada cambiante del Caos" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma bruja. Cada vez que el portador vaya a atacar con este arma elige una de las siguientes reglas especiales: Golpe letal, Poder de penetración, Ataques envenenados o Ataques flamígeros; hasta el final de esa ronda de combate, los ataques del portador se resuelven con la regla especial elegida. No puede elegirse la misma regla especial en dos fases de combate consecutivas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="90ea-e473-6300-fe78" name="Arma bruja" hidden="false" targetId="fd26-9925-9781-20ad" type="profile"/>
            <infoLink id="a66a-cdb9-e792-a582" name="Golpe letal" hidden="false" targetId="9f1c-d301-bd0e-af81" type="rule"/>
