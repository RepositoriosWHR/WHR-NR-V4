              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arko de huezo. Siempre hiere con un resultado de 2+, sin importar la Resistencia del objetivo: además, tiene la regla especial Poder de penetración.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
