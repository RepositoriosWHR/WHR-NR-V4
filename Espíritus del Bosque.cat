          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d90f-265c-64d4-823f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="bfc7-7d9f-3834-d131" type="max"/>
          </constraints>
          <profiles>
            <profile id="7bc4-85b7-423f-8e3d" name="Manada de trasgos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Todas las unidades enemigas a 12” o menos del personaje tendrán un penalizador de -1 a su Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7cff-b179-0b6a-7291" name="Pastor de árboles" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="cfd3-57f5-e7cb-1016" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e126-6fba-d5db-7122" type="max"/>
          </constraints>
          <profiles>
            <profile id="0732-5b4a-5391-7d9c" name="Pastor de árboles" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje obtiene la regla especial ¡Ni un paso atrás!, que afecta a todas las unidades amigas a 18” (esto ya tiene en cuenta la regla especial Objetivo grande).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="60a0-3497-41d2-2591" name="Receptáculo de energía arcana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="c407-2f0d-3be1-d8a3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9760-f0b8-b07e-86d0" type="max"/>
          </constraints>
          <profiles>
            <profile id="18e2-7983-5e14-e247" name="Receptáculo de energía arcana" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Los hechiceros aliados a 12” o menos del personaje obtienen un bonificador de +1 a sus tiradas para lanzar hechizos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5e03-e4fd-8f32-22d0" name="Encarnación de la primavera" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f85b-2f75-88b1-eebd" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9166-e1de-dbd4-3736" type="max"/>
          </constraints>
          <profiles>
            <profile id="d144-5bc9-ef0d-d59f" name="Encarnación de la primavera" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El espíritu del bosque obtiene la regla especial Regeneración (5+) o +1 si ya tenía. Además, al inicio de cada uno de sus turnos, recupera una herida que hubiese sufrido con anterioridad durante la batalla. Incompatible con las otras tres encarnaciones de estaciones.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5e20-e80f-3730-ee31" name="Regeneración (5+)" hidden="false" targetId="515b-514f-7ee3-6cc3" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="0ca4-0bd1-f799-98c6" name="Encarnación estacional" hidden="false" collective="false" import="true" targetId="5514-02cf-e1cc-5c3f" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7cac-7b7b-1b77-138b" name="Encarnación del otoño" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="c6e7-2694-f4c0-e0af" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="496a-a294-742f-0ab1" type="max"/>
          </constraints>
          <profiles>
            <profile id="7d12-07ba-ae34-6163" name="Encarnación del otoño" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Las unidades enemigas en contacto peana con peana pierden las reglas especiales Furia asesina y Odio. Además, tendrán un penalizador de -1 para impactar en combate cuerpo a cuerpo contra el portador. Incompatible con las otras tres encarnaciones de estaciones.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3f08-6336-c012-10a6" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
            <infoLink id="4844-6e41-ffca-3917" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="0385-9c2b-be44-b6fd" name="Encarnación estacional" hidden="false" collective="false" import="true" targetId="5514-02cf-e1cc-5c3f" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6053-883f-4656-8cf5" name="Encarnación del verano" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2a91-b9ac-8293-421a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="48bb-de32-37ea-3f55" type="max"/>
          </constraints>
          <profiles>
            <profile id="bb19-6d8a-c9b7-e92c" name="Encarnación del verano" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El espíritu del bosque obtiene las reglas especiales Odio (¡todos los enemigos!), Furia asesina y Carga devastadora. Incompatible con las otras tres encarnaciones de estaciones.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6a77-ee9a-560a-f2fe" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
            <infoLink id="9936-45da-cbd4-928e" name="Furia asesina" hidden="false" targetId="145c-6914-de8b-e9cc" type="rule"/>
            <infoLink id="e484-e0dc-a1b9-af41" name="Carga devastadora" hidden="false" targetId="dbe6-c910-7f37-aeac" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="30ee-b74a-98b2-8b7e" name="Encarnación estacional" hidden="false" collective="false" import="true" targetId="5514-02cf-e1cc-5c3f" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0c25-d4c3-9a6e-6102" name="Rasgos, Duendes y Hadas Arcanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2165-f27d-3e6c-e663" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6d22-fa03-da53-24f3" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3373-a617-9883-9f14" name="Familiar faérico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1995-c9a0-d364-bfb1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="99bb-a153-aaa3-60cc" type="max"/>
          </constraints>
          <profiles>
            <profile id="c011-7120-4a4c-e86d" name="Familiar faérico" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Tras elegir los hechizos del personaje, haz una tirada de 1D6 y consulta la siguiente tabla:

1 Los cánticos del familiar son incomprensibles y confunden al mago. Durante su primer turno de juego, el personaje tendrá la regla especial Estupidez.
2 El personaje obtiene un hechizo adicional elegido al azar del Saber de las Sombras.
3 El personaje obtiene un hechizo adicional elegido al azar del Saber de la Vida.
4 El personaje obtiene un hechizo adicional elegido al azar del Saber de las Bestias.
5 El personaje Canaliza a 4+.
6 El personaje obtendrá un Dado de energía adicional en cada una de sus fases de magia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="53c1-2548-d779-cdbd" name="Racimo de fuegos fatuos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4e2a-bddc-2d15-1356" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9095-9544-1973-747d" type="max"/>
          </constraints>
          <profiles>
            <profile id="dca3-9ce8-4d06-3907" name="Racimo de fuegos fatuos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Al principio de cada fase de magia del oponente, quita un Dado de energía de la reserva de dados del oponente y añádelo a tu reserva de Dados de dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="190c-20d5-a048-33b5" name="El lamento de las Aldaboneras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="41d4-925d-544d-b084" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1ca3-f46d-db9a-a8cd" type="max"/>
          </constraints>
          <profiles>
            <profile id="ee11-60fa-094e-91a7" name="El lamento de las Aldaboneras" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Un solo uso. Se trata de un objeto portahechizos de nivel de energía 4 que contiene un hechizo de Daño directo que toma como objetivo a una miniatura enemiga a 18” del personaje. La miniatura sufrirá 1D3 heridas sin posibilidad de tirada de salvación por armadura ni posibilidad de regeneración a menos que supere un chequeo de Liderazgo utilizando tres dados y descartando el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fefe-1e7f-d32b-7a7b" name="Avatar de Ghyran" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="da20-cedc-93c5-8cca" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3185-3097-be78-7be9" type="max"/>
          </constraints>
          <profiles>
            <profile id="d6b2-812b-36d1-783c" name="Avatar de Ghyran" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Este espíritu del bosque obtiene la regla especial Señor del Conocimiento (Saber de la Vida). Además, obtiene la regla especial Regeneración (6+), o +1 a su tirada de Regeneración si ya disponía de ella.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5d1c-3f4b-d4b1-c865" name="Señor del conocimiento" hidden="false" targetId="38ca-408d-dbc3-4847" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Sabe de la Vida)"/>
              </modifiers>
            </infoLink>
            <infoLink id="ee4f-6dfc-27b2-1dc2" name="Regeneración (6+)" hidden="false" targetId="4aee-7485-a141-cd20" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d652-4808-5956-7977" name="Dominio de los Vientos de la Magia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8e65-3154-457a-3ed3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f7ed-e744-3a35-4cf1" type="max"/>
          </constraints>
          <profiles>
            <profile id="ac78-c90e-00af-8b9d" name="Dominio de los Vientos de la Magia" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje conoce un hechizo adicional y obtiene un bonificador de +1 en sus tiradas de Canalizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4303-3b13-7da5-5f22" name="Resentido con los intrusos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e8c9-c745-8c99-d9da" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="08c6-5f8b-fc5f-ca74" type="max"/>
          </constraints>
          <profiles>
            <profile id="8752-071e-df90-974e" name="Resentido con los intrusos" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Este espíritu del bosque obtiene la regla especial Señor del Conocimiento (Saber de las Sombras). Además, obtiene la regla especial Odio (elfos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="db20-9933-3071-2ffe" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Elfos)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="076c-4894-06cc-cc64" name="Bendición ancestral del bosque" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6a92-14ad-46d3-b487" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="361d-177b-567d-3900" type="max"/>
          </constraints>
          <profiles>
            <profile id="f105-7c67-ba09-1588" name="Bendición ancestral del bosque" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">El personaje obtiene la regla especial Resistencia mágica (2). Al final de cada fase de magia, el espíritu del bosque puede tomar uno de sus Dados de magia no utilizado y guardarlo. Durante cualquier fase de magia posterior, el hechicero puede extraerlo y usarlo. No puede guardar más de un Dado de magia a la vez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="11c6-86f9-c145-5c44" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c50d-2ecb-3d92-b3c1" name="Protección de los Uleishi" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="eef2-8669-b8bb-a0cb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7a4c-dc0d-5cda-ced8" type="max"/>
          </constraints>
          <profiles>
            <profile id="7b99-7a9a-0e91-8eba" name="Protección de los Uleishi" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Un sólo uso. Puedes declarar que lo usas cuando el oponente lance exitosamente un hechizo, pero antes de efectuar la tirada para dispersar. Dispersa automáticamente el hechizo (siempre que no haya sido lanzado con Fuerza irresistible).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="4167-a553-c1d2-3a27" name="Espíritu del bosque" hidden="false">
      <description>Las miniaturas con esta regla especial tienen las reglas especiales Demonio y Cruzar (Bosques).</description>
    </rule>
    <rule id="a9b7-3d7c-0d33-03e2" name="Magia de Athel Loren" hidden="false">
      <description>Todos los hechiceros del ejército obtienen un bonificador de +1 en sus tiradas para Canalizar si se encuentran a 12” o menos de uno o más Bosques o Elementos acuáticos. Además, los hechiceros que tengan la regla especial Espíritu del bosque verán reducida en 1 la dificultad para lanzar sus hechizos en dichas circunstancias.</description>
    </rule>
    <rule id="d02b-2ae2-7b16-9ae6" name="Ira de Kurnous" hidden="false">
      <description>Si al inicio de cualquier fase de movimiento, una unidad con esta regla especial se encuentra a distancia de carga de al menos una unidad enemiga y la carga es posible, obtendrá la regla Inmune a psicología durante ese turno y deberá declarar carga a la unidad enemiga visible más cercana. Si hay varias unidades enemigas dentro de la misma distancia y línea de visión, puedes elegir a cual de ellas cargar. Puedes realizar un chequeo de Liderazgo para evitar declarar la carga. Si no carga, podrá actuar con normalidad.</description>
    </rule>
    <rule id="6e25-7c55-ed59-ad53" name="Despertar del bosque" hidden="false">
      <description>Existen unidades en la lista de ejército que disponen de esta regla especial, que aparecerá en acompañada entre paréntesis de un elemento de escenografía clave. Por cada 1000 puntos o fracción, una de las unidades con esta regla especial puede elegir no desplegar al inicio de la batalla y en lugar de ello se mantendrá fuera de la mesa como Refuerzos. Pueden entrar al campo de batalla siguiendo las reglas habituales de Refuerzos con la excepción de que, en lugar de usar la regla general de desplegar los refuerzos desde los bordes de la mesa, lo harán desplegando desde el elemento de escenografía clave indicado entre paréntesis, siempre que ese elemento de escenografía se encuentre en el campo de batalla. También pueden decidir desplegar dentro del elemento de escenografía clave si caben completamente en su área. En este caso si hay una unidad enemiga dentro del elemento seleccionado, contarán como que han cargado a esa unidad enemiga. La carga se realizará contra el lado de la unidad enemiga en la que al completar la carga queden el máximo de miniaturas de la unidad que carga dentro del bosque. En caso de igualdad en uno o más lados la unidad que carga podrá elegir el lado contra el cual realizar la carga.</description>
    </rule>
    <rule id="e1cd-bfec-55ab-3c4d" name="El más longevo del bosque" hidden="false">
      <description>Al tener la regla especial Inmune a psicología, los Espíritus del bosque no sufren los efectos de la muerte del General con normalidad. En lugar de ello, al final de la fase en la que el General del ejército sea retirado como baja, tira 3D6 por cada unidad del ejército con la regla especial Espíritu del bosque (salvo los personajes individuales): la unidad sufrirá una herida automática sin tirada de salvación de ningún tipo (ni siquiera Esquiva ni Regeneración) por cada punto que la tirada supere su Liderazgo. Las unidades podrán utilizar el Liderazgo de un personaje unido a ellas y también se podrá utilizar el valor de Liderazgo de una miniatura amiga con Presencia inspiradora (como si fuese un chequeo, aunque no lo sea). El general de un ejército de Espíritus del bosque obtiene la regla especial Tozudez. </description>
    </rule>
    <rule id="881e-3a7e-eee3-241b" name="Cantos faéricos" hidden="false">
      <description>Las unidades de espíritus del bosque con esta regla especial siempre cuentan como si tuvieran un Músico.</description>
    </rule>
    <rule id="9b32-87c8-3fef-b888" name="Melodía embaucadora" hidden="false">
      <description>Las unidades enemigas en contacto con una o más unidades con esta regla especial obtendrán un penalizador de -1 a su Liderazgo.</description>
    </rule>
    <rule id="4950-cdc7-e9dd-d694" name="Espíritus astutos" hidden="false">
      <description>Las unidades con esta regla especial pueden declarar Huir a pesar de tener la regla especial Inmune a psicología, reagruparán automáticamente y podrán actuar normalmente en la sub-fase de Resto de movimientos de ese turno.</description>
    </rule>
    <rule id="e25f-13e6-f07b-14a1" name="Duendecillos alados de los bosques" hidden="false">
      <description>Las miniaturas con esta regla especial que estén usando la regla especial Volar o Flotar podrán entrar en un Bosque o mover por el interior de un Bosque con su movimiento por el aire.</description>
    </rule>
    <rule id="7d57-7972-57df-1984" name="Espíritu acuático" hidden="false">
      <description>Una unidad con esta regla especial a 6” de un elemento de escenografía acuático mejora su tirada de salvación por Aura demoníaca en +1. Tan sólo los personajes con esta regla especial podrán unirse a unidades con esta regla especial y viceversa</description>
    </rule>
    <rule id="2d59-5493-d30d-8bd6" name="La forma del agua" hidden="false">
      <description>Al principio de cada fase de combate cuerpo a cuerpo, la unidad de Náyades debe elegir una de las siguientes formas que adoptar hasta su siguiente fase de combate cuerpo a cuerpo. No puede adoptarse la misma forma en dos fases de combate consecutivas.
- Marea embravecida: Las miniaturas obtienen +1 a la Fuerza.
- Torrente desencadenado: Las miniaturas obtienen +1 a sus Ataques.
- Remolino en vórtice: Las miniaturas obtienen una tirada de salvación especial de 5+ (o +1 a su tirada de salvación especial si ya disponía de una).
- Manantial en calma: En combate, los ataques enemigos contra las miniaturas solamente impactarán obteniendo un resultado natural de 6 y aplicarán un penalizador de -1 en sus tiradas para herir.</description>
    </rule>
    <rule id="2b68-5574-fd47-5de3" name="Golpe demoledor" hidden="false">
      <description>Al inicio de la fase de combate, las miniaturas con esta regla especial pueden efectuar un único ataque especial en lugar de realizar sus ataques habituales. Este ataque especial se resuelve con Fuerza 10 y la regla especial Heridas múltiples (1D6).</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
    <profile id="1aca-73ad-06d9-6468" name="Disparo de los elfos" hidden="false" typeId="576561706f6e23232344415441232323" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="52616e676523232344415441232323">10&quot;</characteristic>
        <characteristic name="Fuerza" typeId="537472656e67746823232344415441232323">2</characteristic>
        <characteristic name="Reglas especiales" typeId="5370656369616c2052756c657323232344415441232323">Disparo rápido, Arrojadiza, Disparos múltiples (1D3), Ataques envenenados, Poder de penetración, Dardo letal: Los impactos que hieren automáticamente a causa de la regla especial Ataques envenenados aplicarán un penalizador adicional de -2 a la tirada de salvación por armadura. No afecta a miniaturas Inmunes a veneno.</characteristic>
      </characteristics>
    </profile>
    <profile id="4437-a108-2536-bd07" name="Venablos de espino" hidden="false" typeId="576561706f6e23232344415441232323" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="52616e676523232344415441232323">Combate</characteristic>
        <characteristic name="Fuerza" typeId="537472656e67746823232344415441232323">Usuario+2</characteristic>
        <characteristic name="Reglas especiales" typeId="5370656369616c2052756c657323232344415441232323">Disparo rápido, Arrojadiza, Disparos múltiples (1D3+1),
