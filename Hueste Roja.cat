          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b995-bef6-3547-e810" type="max"/>
          </constraints>
          <profiles>
            <profile id="3a0b-ffd8-1626-c4f7" name="Desove sagrado de Sotek" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Las miniaturas pertenecientes a este desove obtienen la regla especial Odio (¡todos los enemigos!).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="636d-dc2f-9983-99b3" name="Odio (todos los enemigos)" hidden="false" targetId="69e8-bae0-e71a-64f6" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
