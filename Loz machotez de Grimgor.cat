          </constraints>
          <profiles>
            <profile id="5c95-c1fc-8636-ac66" name="Mata´umanoz" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Rebanadora. Tiene la regla especial Poder de penetración. Si se utiliza para atacar a miniaturas con la clave humanos, el Mata&apos;umanoz hiere automáticamente (no es necesario efectuar la tirada para herir). </characteristic>
