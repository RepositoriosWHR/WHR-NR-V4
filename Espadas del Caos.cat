      </costs>
    </selectionEntry>
    <selectionEntry id="726c-57eb-4571-8351" name="[E]  - Melekh el Transmutador, Elegido de Tzeentch" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0e06-d553-8803-1eaa" type="max"/>
      </constraints>
      <rules>
        <rule id="b31d-ea84-9971-01a1" name="Magia de Melekh el Transmutador" hidden="false">
          <description>Melekh es un hechicero de nivel 4 que conoce todos los hechizos del Saber de Tzeentch.</description>
        </rule>
        <rule id="86d8-e51d-5cbc-6b3e" name="Hechicero guerrero" hidden="false">
          <description>Melekh puede lanzar hechizos con normalidad pese a llevar Escudo. </description>
        </rule>
        <rule id="f9a0-1d9c-1faa-eaef" name="Heraldo de la llamas" hidden="false">
          <description>Al inicio de cada fase de combate cuerpo a cuerpo, cada unidad enemiga en contacto con Melekh sufre 1D6+1 impactos de Fuerza 1D6+1 con las reglas especiales Ataques flamígeros y Poder de penetración. Las bajas causadas por este efecto cuentan para el resultado del combate. </description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="94e3-ede1-e958-69e5" name="Ojo de los dioses" hidden="false" targetId="0799-cc58-3276-4a94" type="rule"/>
        <infoLink id="69ef-feb8-01c5-afb5" name="Caballería" hidden="false" targetId="276f-0034-6534-f691" type="rule"/>
        <infoLink id="71b7-5169-e223-9c9f" name="Orgullo marcial" hidden="false" targetId="2707-4d2a-ddbd-e301" type="rule"/>
        <infoLink id="1ac6-3bf8-b876-2a22" name="Señor del conocimiento" hidden="false" targetId="38ca-408d-dbc3-4847" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(Tzeentch)"/>
          </modifiers>
        </infoLink>
        <infoLink id="cb6c-c036-9ad5-74ce" name="Inmune a la psicología" hidden="false" targetId="73ad-8cdb-f1ad-010f" type="rule"/>
        <infoLink id="251c-1a19-6e8c-100c" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule"/>
        <infoLink id="3865-645a-edf8-b87e" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
