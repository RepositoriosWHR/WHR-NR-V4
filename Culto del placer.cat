        </selectionEntry>
        <selectionEntry id="e41a-259e-d23f-5d35" name="Espada del Odio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="897c-d49d-6f78-1730" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="671d-7bb7-1f91-07ae" type="max"/>
          </constraints>
          <profiles>
            <profile id="5e8e-f521-aafe-7c59" name="Espada del Odio" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los impactos de la Espada del Odio hieren automáticamente con resultados de 5 o 6 en sus tiradas para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e5c9-9e7a-3ab3-6f36" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
