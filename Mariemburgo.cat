    <selectionEntry id="a5c9-b7bb-01d8-4f5c" name="[E] - Hilaria Om Klimt, Sacerdotisa de Manann" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e01b-aa63-8a17-da7d" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1cc2-d85e-9d93-60aa" type="max"/>
      </constraints>
      <rules>
        <rule id="adc6-400d-4372-a11c" name="Plegarias Hilaria Om Klimt" hidden="false">
          <description>Hilaria conoce todas las Plegarias de Manann y puede lanzar dos de ellas por fase de magia con nivel de energía 1D6+1.</description>
        </rule>
        <rule id="721d-aef1-7d33-0724" name="Favor divino" hidden="false">
          <description>Tiene las reglas especiales Esquivar (5+) y Resistencia mágica (2).</description>
        </rule>
        <rule id="0195-3f42-d8fd-cd35" name="Agitadora fanática" hidden="false">
          <description>Hilaria no puede incluirse en una unidad con la regla especial Ley y orden. Si se incluye en una unidad de tropa básica Hilaria y la unidad obtendrán la regla especial Sangre fría.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="b657-a62a-3c87-559c" name="Infantería" hidden="false" targetId="5b75-bd6b-d17a-6b7d" type="rule"/>
        <infoLink id="e15d-985b-1bd1-2cd5" name="Odio" hidden="false" targetId="a187-f92e-2178-84ff" type="rule">
          <modifiers>
            <modifier type="append" field="name" value="(No muertos, Demonios)"/>
          </modifiers>
        </infoLink>
        <infoLink id="a4e0-d2d6-a568-1507" name="Esquivar (5+)" hidden="false" targetId="053b-3b96-b53b-6944" type="rule"/>
        <infoLink id="42ad-5eac-7bc6-f0e4" name="Resistencia mágica (2)" hidden="false" targetId="9718-2e66-193f-7dd6" type="rule"/>
        <infoLink id="296c-3238-5326-6910" name="Sacerdote" hidden="false" targetId="1fc6-22eb-3dba-dae7" type="rule"/>
