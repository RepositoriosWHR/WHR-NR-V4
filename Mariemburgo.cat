  <sharedSelectionEntryGroups>
    <selectionEntryGroup id="283f-ba38-b1d5-92e8" name="Renombres. Equipado con pistola" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="4cc1-4e93-1a3b-9148" name="Jugador sucio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="bba7-32d9-d4f0-ca1b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="5475-74fe-1c00-2daa" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="e6fe-5305-b48d-012a" type="max"/>
          </constraints>
          <profiles>
            <profile id="5eff-e11f-5267-8916" name="Jugador sucio" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">Sólo personaje equipado con Pistola. Cuando el personaje sufre una herida en cuerpo a cuerpo, puede automáticamente realizar un ataque con su pistola (fuera de la secuencia habitual) contra la miniatura o unidad que le causó la herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="18d8-6f62-5e7f-cccc" name="Pistola (Disparo)" hidden="false" targetId="9c4d-f670-7b68-06b1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5b93-ee6b-5abd-b288" name="Renombres. Infantería" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="50cf-cb2f-449f-2ef8" name="Duelista" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f8c2-eadd-8711-1ea2" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="b46c-6de5-3b58-e7bb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="929d-4dc4-2580-744c" type="max"/>
          </constraints>
          <profiles>
            <profile id="c978-1882-5a5d-066a" name="Duelista" hidden="false" typeId="98cd-bd8b-f52a-6fd7" typeName="Renombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8c79-e536-addc-8a74">El guerrero no podrá equiparse con Escudo o armaduras que no sean Armadura ligera. Obtendrá las reglas especiales Esquivar (5+) y Orgullo marcial, y podrá repetir sus tiradas para impactar no superadas luchando en un desafío.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3ad4-1598-3f8b-7437" name="Esquivar (5+)" hidden="false" targetId="053b-3b96-b53b-6944" type="rule"/>
            <infoLink id="405e-835a-6e07-9da9" name="Orgullo marcial" hidden="false" targetId="2707-4d2a-ddbd-e301" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ab89-cc40-1ad9-c505" name="Objetos hechizados. Mariemburgo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f340-6fb4-163f-bd74" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="03e8-cfa0-f051-e971" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="45c1-0bd9-b7d4-49d8" name="Ojo de Manann" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7f2d-992e-7917-ac11" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="515c-f068-fe6f-4bcb" type="max"/>
          </constraints>
          <profiles>
            <profile id="15a5-1dc8-ca5a-7d10" name="Ojo de Manann" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y la unidad en la que se encuentre podrán repetir las tiradas de 1 que obtuviesen al impactar con sus armas de proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8f38-80e1-ebbb-fe85" name="Colgante del buen porvenir" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d2f9-0a20-6d69-0547" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9272-5773-71f8-24b3" type="max"/>
          </constraints>
          <profiles>
            <profile id="acd8-6994-178e-fa69" name="Colgante del buen porvenir" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Otorga al portador la regla especial Esquivar (6+). Además, podrá repetir todas las tiradas de chequeos de atributo (excepto Liderazgo) que debiese efectuar. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f416-c66c-c995-2f76" name="Esquivar (6+)" hidden="false" targetId="c905-72a4-c706-6a16" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4145-785e-973e-62c4" name="Manto de opulencia desmedida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="bac3-7d26-92f2-1260" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3f6b-388f-0ac4-98de" type="max"/>
          </constraints>
          <profiles>
            <profile id="f0d4-6199-ddbc-1426" name="Manto de opulencia desmedida" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Las miniaturas con la regla mercenario que quieran atacar al portador en combate cuerpo a cuerpo deberán superar primero un chequeo de liderazgo usando 3D6 y sumando los tres resultados. Si el chequeo falla no podrán atacarle durante esa fase de combate. Si el portador se ha unido a una unidad con la regla especial Mercenario, la unidad obtendrá la regla especial Tozudez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a237-e943-0242-1ed7" name="Tozudez" hidden="false" targetId="eeaa-5e56-bdf4-3ddb" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Con unidad de Mercenarios)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a480-12eb-dc3e-490a" name="Pergamino del Contrato vinculante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1ad3-8277-6997-ac24" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="db9b-05e9-572a-8c93" type="max"/>
          </constraints>
          <profiles>
            <profile id="fc37-8d64-ec06-2925" name="Pergamino del contrato vinculante" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Todas las unidades amigas mercenarias a 12” o menos del portador serán Inmunes a la psicología.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6e7a-fc33-715b-c85c" name="Inmune a la psicología" hidden="false" targetId="73ad-8cdb-f1ad-010f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4c81-d8e5-8898-b634" name="Mercancías de contrabando" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8eff-3e30-f925-00f6" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="102f-3208-5b54-c0fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="2864-e8bc-3cb5-58be" name="Mercancías de contrabando" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un personaje equipado con esta Llave podrá equiparse con un objeto mágico adicional (no reliquia) de hasta 40 puntos, que deberá ser un talismán o un objeto hechizado. El objeto deberá elegirse de la lista de objetos mágicos de uno de los siguientes ejércitos: Imperio, Bretonia, Kislev, Elfos Silvanos, Altos Elfos, Mercenarios, Estalia, Arabia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3426-4afd-fc33-506e" name="Bolsa de oro mágico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e28e-188b-ea4f-636e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c860-c5ef-9719-cc17" type="max"/>
          </constraints>
          <profiles>
            <profile id="7151-4b92-9569-129a" name="Bolsa de oro mágico" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un sólo uso. Pueden usarse para hacer que una unidad situada a 6” o menos del portador supere automáticamente un chequeo de Liderazgo fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="78c6-7cad-e4c1-e086" name="Armas mágicas. Reliquias. Mariemburgo. Alabarda" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8077-b6f1-dec1-3156" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f654-039b-e99d-f627" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ba12-1776-b89a-9f4e" name="Hoja Marina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1b92-815a-c3ac-2273" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4239-249f-7379-0d7e" type="max"/>
          </constraints>
          <profiles>
            <profile id="e616-8249-cb46-849e" name="Hoja marina" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Alabarda. Sus ataques se resuelven con la regla especial Impactos múltiples (1D3). Las heridas causadas con esta alabarda niegan la tirada de salvación por armadura. Además, una vez por batalla el arma puede usarse como objeto porta-hechizos de nivel de energía 4. El hechizo que puede lanzarse es el Rayo atronador de Urannon del saber de los Cielos en su versión no potenciada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1d46-5102-6a64-5f96" name="Impactos múltiples (1D3)" hidden="false" targetId="91a2-dd39-211c-fbdd" type="rule"/>
            <infoLink id="68e7-d17a-5f49-ef3e" name="Alabarda" hidden="false" targetId="8dd0-8d9d-2436-cbf1" type="profile"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="4511-850d-ace4-7fd0" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="75.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ac93-fd7b-8094-069d" name="Armaduras mágicas. Mariemburgo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8590-4901-7a4b-4c3f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e522-5dc4-c1b2-ee7a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f633-ccc8-dcf9-b163" name="Coraza de Monte Castello" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="72dc-9d89-516e-fcdd" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8d52-4460-4fa4-f896" type="max"/>
          </constraints>
          <profiles>
            <profile id="683f-a21a-003f-5623" name="Coraza de Monte Castello" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura pesada. Proporciona a su portador la regla especial Piel escamosa (4+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ec1f-d52a-0947-98ef" name="Piel escamosa (4+)" hidden="false" targetId="478f-4519-03d3-5004" type="rule"/>
            <infoLink id="ec21-eba4-241b-d9da" name="Armadura pesada" hidden="false" targetId="1ee5-2441-2c69-5965" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1322-893d-a8eb-63be" name="Escudo rúnico de los nueve mares" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="b1bf-e9b8-5d44-9b9d" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2627-8fda-a23a-5fc2" type="max"/>
          </constraints>
          <profiles>
            <profile id="3684-c3bd-3758-7f9d" name="Escudo rúnico de los nueve mares" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Escudo. El portador será inmune a los efectos de la regla especial Poder de penetración. Todos los ataques dirigidos contra el portador en combate cuerpo a cuerpo obtendrán un penalizador de -1 en sus tiradas para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9641-80a9-169a-4ab6" name="Escudo" hidden="false" targetId="c028-354e-9169-7463" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="42c6-853b-4237-c264" name="Artefactos arcanos. Mariemburgo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="21ae-3cb4-4d58-6710" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="774d-3168-fbd2-1c79" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="510e-cc5b-ab48-c133" name="Skwiknibble, Familiar Snotling" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="ebdf-c427-44be-3f13" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0a17-211f-350f-54fa" type="max"/>
          </constraints>
          <profiles>
            <profile id="126a-6fcb-e8ae-d1b4" name="Skwiknibble, familiar snotling" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Al inicio de cada fase de magia del oponente, puedes robar uno de sus dados de energía y añadirlo a tu reserva de dados de dispersión. Aunque puedes representarlo con una pequeña miniatura de snotling apropiada, no puede ser atacado, y deberá retirarse si el portador se retira como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9853-83b4-915d-24c7" name="Curso de Matheus Yadok" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4343-5bbf-619e-c4ab" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8d6b-3e25-6f44-7655" type="max"/>
          </constraints>
          <profiles>
            <profile id="f377-0c72-a099-1d7a" name="Curso de Matheus Yadok" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El hechicero conoce el hechizo El oro de los insensatos del Saber del Metal</characteristic>
              </characteristics>
            </profile>
            <profile id="d6ae-75fa-820e-bd7f" name="[4b] - Oro de los insensatos" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
              <characteristics>
                <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Maldición</characteristic>
                <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">9+</characteristic>
                <characteristic name="Rango" typeId="544c-fa75-b146-79c4">24&quot;</characteristic>
                <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Maldición que toma como objetivo a una unidad enemiga a 24” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, la unidad obtiene la regla especial Estupidez y deberá realizar sus chequeos de Estupidez tirando 3D6 y descartando el resultado menor.</characteristic>
              </characteristics>
            </profile>
            <profile id="c4d7-c3b6-767c-fd60" name="[R] - Imbuir el metal" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
              <characteristics>
                <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Los hechizos del Saber del Metal ven su dificultad de lanzamiento reducida en punto si toma como objetivo una o más unidades con una tirada de salvación por armadura de 4+ o mejor. Del mismo modo, si la unidad objetivo tiene una tirada de salvación por armadura de 2+ o mejor, reduce en 1 adicional la dificultad de lanzamiento del hechizo (es decir,la dificultad se reduce en 2 puntos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="bf68-366f-6154-65d7" name="Sextante de la premonición" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="be84-109c-1434-fbfb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0112-02ea-6459-762c" type="max"/>
          </constraints>
          <profiles>
            <profile id="fa0a-8886-9715-e225" name="Sextante de la premonición" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Otorga al hechicero un bonificador de +1 a la hora de lanzar hechizos. Además, una vez por batalla, podrás repetir una tirada a la hora de lanzar o dispersar un hechizo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="86ea-026d-1110-7e14" name="Estandartes mágicos. Mariemburgo. Sólo regla ley y orden" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8572-45f0-17b9-dad6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b0f-da0d-a156-7c1d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="70eb-2b85-f61c-983e" name="Pabellón de la Presta represalia" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="6559-6c39-0bad-b1b3" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0417-a3e8-6ce7-daff" type="max"/>
          </constraints>
          <profiles>
            <profile id="55f0-2e2d-30b3-5f19" name="Pabellón de la Presta represalia" page="" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Solo unidades con la regla Ley y Orden. Aumenta el movimiento de vanguardia a 10’’. La unidad obtiene la regla Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f099-b42e-4a9d-bd80" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule"/>
            <infoLink id="4a1e-c23b-a1bc-00cf" name="Vanguardia" hidden="false" targetId="1bd0-0982-01a3-ed62" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="90c2-8e7a-a4c3-59f2" name="Estandarte de Mariemburgo" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a4e3-a64a-79d4-3c49" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9537-875b-5efb-8a34" type="max"/>
          </constraints>
          <profiles>
            <profile id="f587-894d-1bab-6a56" name="Estandarte de Mariemburgo" page="" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Sólo unidades con la regla Ley y Orden. Todas las unidades situadas a 12” o menos del estandarte obtendrán un bonificador adicional de +1 al resultado de los combates en los que participen. Si en un combate hay varias unidades bajo el área de efecto del estandarte el bonificador solamente se contará una sola vez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1995-f96a-5ea7-956c" name="Armas mágicas. Mariemburgo. Arma de mano" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="181b-e902-65b1-50b4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="65ee-58f8-7bed-b2e5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1228-207b-5027-c8f5" name="Hoja traicionera" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="93e8-12ac-ac2d-8ce0" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="297a-a724-7922-3e02" type="max"/>
          </constraints>
          <profiles>
            <profile id="6d08-0260-8ef3-ce8a" name="Hoja traicionera" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los ataques en combate usando este arma obtienen la regla especial poder de penetración. Si el atacante esta situado al flanco o a la retaguardia del enemigo objetivo del ataque, los ataques efectuados por el atacante se resuelven con un bonificador de +1 a la fuerza y la regla especial heridas múltiples (2).  </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e98c-6010-b022-4c84" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
            <infoLink id="b80f-fd89-0641-f8ba" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
            <infoLink id="0b2d-23d8-2f3c-708d" name="Heridas múltiples (2)" hidden="false" targetId="be26-0d4a-0493-6c52" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Flanco o Retaguardia)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4da9-5bd1-befb-e88f" name="Espada de la tormenta" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="544e-0d97-faaf-465b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2807-5bc1-3dac-a507" type="max"/>
          </constraints>
          <profiles>
            <profile id="79bf-64de-25e2-0c05" name="Espada de la tormenta" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Otorga a su portador un bonificador de +1 a la Fuerza. Además, una vez por batalla puedes utilizar el poder contenido dentro de la espada. En la fase de disparo, designa una unidad enemiga a 12’’ o menos del portador. La unidad sufre 1D3 impactos de Fuerza 5 con la regla especial Ataque de rayos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="75a5-e2df-53de-13c6" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
            <infoLink id="3a3f-70bc-513c-83ee" name="Ataques de rayos" hidden="false" targetId="8628-6531-ed1d-f985" type="rule">
              <modifiers>
                <modifier type="set" field="name" value="(Poder contenido, una vez por batalla)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0b49-775e-9eb8-a208" name="Trachinus Draco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a888-a291-2617-0cdf" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="bc68-7540-ba69-2f7c" type="max"/>
          </constraints>
          <profiles>
            <profile id="c474-55b1-1714-5d7e" name="Trachinus Draco" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los ataques con este arma obtienen un bonificador de +1 en sus tiradas para impactar y se resuelven con la regla especial Poder de penetración. Las heridas causadas por esta arma no permiten tiradas de Regeneración.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e107-ddf5-aa70-35e6" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
            <infoLink id="0729-d12b-2619-fd0c" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ff16-7331-4a13-e3a5" name="Magia marina" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d659-9207-1954-5eca" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cd69-cc0f-c0b3-75cc" name="Domino de los elementos, parte 2" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="38af-1183-0809-32ea" type="max"/>
            <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e1c6-1914-3343-b0fc" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="9e86-8f60-281c-f80a" name="Domino de los elementos, parte 2" hidden="false" collective="false" import="true">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b7f4-cb9b-4a39-d106" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="df6d-8a57-05f2-b8b0" type="min"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="3546-1741-f8db-f1c1" name="Carne pétrea (Vida)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b0e-e621-8e7a-aa15" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9740-b544-56e3-8ea4" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="a44b-786a-093b-7648" name="[3º] - Carne pétrea (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">11+/18+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece en efecto</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo a una unidad amiga a 18” o menos del lanzador y Permanece en efecto. Mientras dure el hechizo, la unidad tendrá un bonificador de +1 a su atributo de Resistencia. Puede potenciarse para que aumente la Resistencia en +2 en lugar de +1 pero en ese caso también reducirá el Movimiento y la Iniciativa en -1 y la dificultad será de 18+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="3a2f-96ba-abc8-f3d9" name="[R] - Sanación (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Lanzador (6&quot;)</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Cada vez que un hechicero lance exitosamente un hechizo del Saber de la Vida y este no sea dispersado, el hechicero puede curar una herida a una miniatura amiga a 6” o menos de él que hubiese sufrido previamente durante la batalla.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="77b8-a604-e4fb-2498" name="Craneo ardiente (Fuego)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e57-1441-a4c2-f06b" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6bd8-1b41-77fc-6507" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="fad2-4e1b-c58d-5c0a" name="[3º] - Craneo ardiente (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Daño directo</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">8+/12+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Daño directo. Traza una línea recta de 18” desde el lanzador. Cualquier miniatura bajo esa línea sufrirá un impacto de Fuerza 4 con la regla especial Ataques flamígeros (determínalo como en el caso de los Cañones). Cualquier unidad que sufra al menos una baja como resultado de este hechizo deberá efectuar de inmediato un chequeo de Pánico. Puede potenciarse para aumentar su Fuerza a 5, en cuyo caso la dificultad será 12+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="6a0c-3e11-ab23-a01d" name="[R] - Dominio del fuego (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber del Fuego tiene las reglas especiales Ataques flamígeros e Inmune a fuego.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="7165-6a79-c034-0f3a" name="Espadas hechizadas de Aiban (Metal)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b873-1c9a-af0b-385d" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cfc8-02fa-14a8-54cc" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="4f25-1b75-d6be-9db4" name="[3º] - Espadas hechizadas de Aiban (Metal)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">7+/14+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">12&quot;/12&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo a una unidad amiga a 12” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, la unidad tendrá un bonificador de +1 en sus tiradas para impactar. Además, todos los impactos que causen tendrán las reglas especiales Ataques mágicos y Poder de penetración. Puede potenciarse para que afecte a todas las unidades amigas a 12” o menos del lanzador, en cuyo caso su dificultad será de 14+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="8e15-6572-cb06-62d1" name="[R] - Imbuir el metal (Metal)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Los hechizos del Saber del Metal ven su dificultad de lanzamiento reducida en punto si toma como objetivo una o más unidades con una tirada de salvación por armadura de 4+ o mejor. Del mismo modo, si la unidad objetivo tiene una tirada de salvación por armadura de 2+ o mejor, reduce en 1 adicional la dificultad de lanzamiento del hechizo (es decir,la dificultad se reduce en 2 puntos).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="337b-6151-1da0-18a2" name="Proyectiles llameantes (Fuego)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="14f6-0ee6-22bc-5b0a" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="154d-fc24-b1eb-edbf" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="0a70-8f77-f300-81cd" name="[3º] - Proyectiles llameantes (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Proyectil magico</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">12+/16+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Proyectil mágico con un alcance de 18”. Causa 1D6+1 impactos que hieren a 4+, tienen la regla especial Ataques flamígeros y no permiten tirada de salvación por armadura. Puede potenciarse para causar 2D6 impactos en lugar de 1D6+1, en cuyo caso la dificultad será de 16+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="d5fa-28b0-bbf1-87b7" name="[R] - Dominio del fuego (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber del Fuego tiene las reglas especiales Ataques flamígeros e Inmune a fuego.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6955-dd1b-2b10-e987" name="Hechiería básica" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7840-b90c-5012-b1d4" type="max"/>
            <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f7b5-7864-0bb4-7070" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="e6d8-7af0-809a-ffb5" name="Hechiería básica" hidden="false" collective="false" import="true">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5f33-b582-e738-1051" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d083-27f3-a0e8-2c95" type="min"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="816b-7da7-9f57-8397" name="Bola de Fuego (Fuego)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3691-3fb2-d45a-600c" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="cd72-e3ac-60cf-6100" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="fc9b-8fbf-9a95-f671" name="[1º] - Bola de Fuego (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Proyectil Magico</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">5+/9+/12+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">24&quot;/36&quot;/48&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Proyectil mágico con un alcance de 24”. Causa 1D6 impactos de Fuerza 4 con la regla especial Ataques sólo flamígeros. Puede potenciarse para aumentar el alcance a 36” y el número de impactos a 2D6, en cuyo caso la dificultad será de 9+, o para aumentar el alcance a 48” y el número de impactos a 3D6, en cuyo caso la dificultad será de 12+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="19ed-cc1d-26ff-3b99" name="[R] - Dominio del fuego (Fuego)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber del Fuego tiene las reglas especiales Ataques flamígeros e Inmune a fuego.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="daca-d6ff-fcbe-2ff9" name="Miasma mística de Melkoth (Sombras)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e398-54bb-7fa3-b161" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4cfe-e71c-8d76-7555" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="7ae4-4c4b-09a0-4263" name="[1º] - Miasma mística de Melkoth (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Maldición</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">8+/13+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">24&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Maldición que toma como objetivo a una unidad enemiga a 24” o menos del lanzador y Permanece un turno. Elige un atributo de entre los siguientes: HA, HP, I y M. Mientras dure el hechizo, la unidad verá reducido en 1D3 puntos dicho atributo. Puede potenciarse para que reduzca los cuatro atributos indicados en lugar de uno solo (tira un único D3 y reduce la cantidad indicada los cuatro atributos), en cuyo caso la dificultad será de 13+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="8a1b-7dc0-c029-d39f" name="[R] - Envuelto en sombras (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Los disparos dirigidos contra un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 para impactar. Los enemigos que ataquen en combate cuerpo a cuerpo a un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 a su HA al atacar al hechicero.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="0a34-8a5e-2737-6f0e" name="Portento de Phar (Cielos)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f610-f2b3-9e73-0f8a" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="284e-74aa-49d7-6acb" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="d004-ea6b-d67a-1f64" name="[1º] - Portento de Phar (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">6+/9+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">12&quot;/24&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo a una unidad amiga a 12” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, la unidad podrá repetir sus resultados de 1 para impactar y herir. Puede potenciarse el hechizo para aumentar el alcance hasta 24”, en cuyo caso la dificultad será de 9+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="edb3-4119-3a06-a117" name="[R] - Visión profética (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber de los Cielos puede repetir una tirada de dado una vez por batalla. Ha de ser una tirada concerniente al propio hechicero: una tirada para impactar, herir, salvaciones, chequeo de atributo, dado de Energía o Dispersión o una tirada en la tabla de Disfunciones mágicas. Además, el hechicero obtiene la regla especial Esquivar (6+).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="cf76-26c1-8c1e-fe71" name="Sangre de la Tierra (Vida)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6e9f-88aa-da6b-724f" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="371a-7383-3a1f-0e95" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="2e37-6ff7-7b1c-c37a" name="[1º] - Sangre de la Tierra (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">7+/15+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;/12&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo a una unidad amiga a 18” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, la unidad obtiene la regla especial Regeneración (5+). Puede potenciarse para que afecte a todas las unidades amigas a 12” o menos del lanzador, en cuyo caso la dificultad será de 15+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="a507-5746-1c2d-cef1" name="[R] - Sanación (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Lanzador (6&quot;)</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Cada vez que un hechicero lance exitosamente un hechizo del Saber de la Vida y este no sea dispersado, el hechicero puede curar una herida a una miniatura amiga a 6” o menos de él que hubiese sufrido previamente durante la batalla.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8572-bcd2-816f-8355" name="Dominio de los elementos, parte 1" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6df1-030e-0aec-12bc" type="max"/>
            <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1c02-2bfe-0694-04d5" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="745c-138c-9566-5cdf" name="Dominio de los elementos, parte 1" hidden="false" collective="false" import="true">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e699-3cd9-7660-5b19" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f61a-5f16-c981-767d" type="min"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="8658-e3dc-c8a3-ef05" name="Atrofia gris (Sombras)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f67f-fcf8-f11b-7d35" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="12b7-020b-c80b-cde6" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="d73a-2ca7-d3ae-4a8a" name="[2º] - Atrofia gris (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Maldición</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">10+/13+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;/36&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece en efecto</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Maldición que toma como objetivo a una unidad enemiga a 18” o menos del lanzador y Permanece en efecto. Tira 1D3: mientras dure el hechizo, esa será la cantidad que debes sustraer al atributo de Fuerza de la unidad. Puede potenciarse para aumentar el alcance hasta 36”, en cuyo caso la dificultad será de 13+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="0b3a-8964-1da5-2519" name="[R] - Envuelto en sombras (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Los disparos dirigidos contra un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 para impactar. Los enemigos que ataquen en combate cuerpo a cuerpo a un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 a su HA al atacar al hechicero.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="2b97-8df8-fdcc-fd51" name="Charco esmeralda (Vida)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0237-cb59-741b-2b5b" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="f8c4-11a8-60c6-743f" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="10fb-a440-521b-8f44" name="[2º] - Charco esmeralda (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">8+/15+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Lanzador</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo al propio hechicero. Retira del campo de batalla al lanzador y vuelve a colocarlo en cualquier punto del campo de batalla a 1” o más de cualquier miniatura enemiga o Edificio. Puedes unirlo a una unidad amiga. Si el lanzador tiene Potencia de unidad de 5+, la dificultad del hechizo será de 15+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="cdc8-f72d-e399-f8f2" name="[R] - Sanación (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Lanzador (6&quot;)</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Cada vez que un hechicero lance exitosamente un hechizo del Saber de la Vida y este no sea dispersado, el hechicero puede curar una herida a una miniatura amiga a 6” o menos de él que hubiese sufrido previamente durante la batalla.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="7747-74ca-258b-cb44" name="La niebla de Duthandor (Vida)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="011d-71b2-76bf-7db9" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b5dc-fa28-c394-7e69" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="8f5e-436a-c158-7851" name="[2º] - La niebla de Duthandor (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">10+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">12&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece en efecto</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo al propio lanzador y Permanece en efecto. Cualquier disparo que se realice contra cualquier unidad a 12” o menos del lanzador tendrá un penalizador de -2 para impactar, los efectos causados por plantillas de área considerarán cualquier resultado de impacto como si fuese de flecha, que se dispersará la mitad del resultado obtenido, los efectos de Tormenta de proyectiles deberán dividir a la mitad el número de impactos causados y los Cañones y Lanzallamas que deseen disparar al interior del área deberá antes superar un chequeo de Liderazgo; si no lo supera, podrá seleccionar otro objetivo del exterior del área.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="3ece-07bd-07b4-7f1e" name="[R] - Sanación (Vida)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Lanzador (6&quot;)</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Cada vez que un hechicero lance exitosamente un hechizo del Saber de la Vida y este no sea dispersado, el hechicero puede curar una herida a una miniatura amiga a 6” o menos de él que hubiese sufrido previamente durante la batalla.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="1aa4-54f7-3a26-e98c" name="Rayo Atronador de Urannon (Cielos)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="325f-fccc-0c06-bec4" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ab45-bc68-e7e4-d110" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="902a-7a2f-2b45-2813" name="[2º] - Rayo Atronador de Urannon (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Daño directo</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">11+/16+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">30&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Daño directo que toma como objetivo a una unidad enemiga a 30” o menos del lanzador. La unidad sufre 1D6 impactos de Fuerza 5 con la regla especial Ataque de rayos. Puede potenciarse para que cause 2D6 impactos, en cuyo caso la dificultad será de 16+.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="c044-913e-fbf0-732d" name="[R] - Visión profética (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber de los Cielos puede repetir una tirada de dado una vez por batalla. Ha de ser una tirada concerniente al propio hechicero: una tirada para impactar, herir, salvaciones, chequeo de atributo, dado de Energía o Dispersión o una tirada en la tabla de Disfunciones mágicas. Además, el hechicero obtiene la regla especial Esquivar (6+).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="5.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3d93-8800-c69b-d55c" name="Hechicería avanzada" hidden="true" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="false">
              <conditions>
                <condition field="selections" scope="ancestor" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6c16-bc8c-935d-a081" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9f33-0cfb-05eb-9ae0" type="max"/>
            <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c631-b9dc-0709-0402" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="55d5-d100-242f-8e8a" name="Hechicería avanzada" hidden="false" collective="false" import="true">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8f61-66e9-0fa7-f71f" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7ecb-fff8-a2ba-fa0b" type="min"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="e7b2-bda1-3b79-1b89" name="Luz cegadora de Amshu (Luz)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="672c-d46c-f3ec-0605" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="0a29-c849-7958-f8d8" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="f952-77a5-472c-ea5b" name="[4º] - Luz cegadora de Amshu (Luz)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Maldición</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">12+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">24&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Maldición que toma como objetivo a una unidad enemiga a 24” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, la unidad verá su Movimiento reducido a la mitad y su HA y HP a un valor de 1. Las Máquinas de guerra no pueden disparar bajo el efecto de este hechizo.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="6176-b1dc-dfc5-b9c5" name="[R] - Iluminación (Luz)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">12&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Inicio tu próxima fase de magia</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Cada vez que un hechicero lance exitosamente un hechizo del Saber de la Luz y este no sea dispersado, puedes elegir una unidad amiga a 12&quot; o menos del hechicero: dicha unidad obtiene la regla especial Inmune a psicología hasta el inicio de tu siguiente fase de magia.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="c8ce-eba5-baab-6c00" name="Maldición del viento de medianoche (Cielos)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a0e-8303-51f3-1495" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="b82f-6714-ad04-8b6b" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="2b2c-4ed1-017a-b8ca" name="[4º] - Maldición del viento de medianoche (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Maldición</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">7+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">Permanece un turno</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Maldición que toma como objetivo a una unidad enemiga a 18” o menos del lanzador y Permanece un turno. Mientras dure el hechizo, todos los resultados naturales de 6 que obtenga la unidad en sus tiradas para impactar, herir y salvaciones deberán repetirse.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="5bc6-ee3a-7833-b1b6" name="[R] - Visión profética (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber de los Cielos puede repetir una tirada de dado una vez por batalla. Ha de ser una tirada concerniente al propio hechicero: una tirada para impactar, herir, salvaciones, chequeo de atributo, dado de Energía o Dispersión o una tirada en la tabla de Disfunciones mágicas. Además, el hechicero obtiene la regla especial Esquivar (6+).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="9b11-c49a-17fa-1be3" name="Puente de sombras (Sombras)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f86d-be2e-148f-c0a2" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="acf8-b593-49e2-55e6" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="3fc8-2496-76dd-b4ed" name="[4º] - Puente de sombras (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Potenciación</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">15+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">18&quot;</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Potenciación que toma como objetivo a una unidad amiga a 18” o menos del lanzador. La unidad realiza inmediatamente un movimiento como si tuviera la regla especial Flotar (10). La unidad puede decidir realizar una carga con este movimiento.</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="b55f-7727-304b-ff91" name="[R] - Envuelto en sombras (Sombras)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Los disparos dirigidos contra un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 para impactar. Los enemigos que ataquen en combate cuerpo a cuerpo a un hechicero que conozca uno o más hechizos del Saber de las Sombras tendrán un penalizador de -1 a su HA al atacar al hechicero.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="f12d-ef19-f735-5b39" name="Tempestad de Cassandora (Cielos)" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c22-fa2a-81c2-70c7" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="db65-3756-d1c7-24bd" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="1f46-f5b1-df25-0820" name="[4º] - Tempestad de Cassandora (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">Daño directo</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">21+</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">Campo de batalla</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Se trata de un hechizo de Daño directo. Coloca la plantilla redonda grande en cualquier punto del campo de batalla y tira el dado de dispersión. Si obtienes un resultado de impacto, la plantilla permanece donde está; si no, desvíala 1D6” menos el nivel de magia del lanzador. Cualquier miniatura bajo la plantilla sufrirá un impacto de Fuerza 6. La miniatura bajo el agujero central de la plantilla sufrirá en vez de ello un impacto de Fuerza 10 con las regla especiales Ataque de rayos y Heridas múltiples (1D3).</characteristic>
                      </characteristics>
                    </profile>
                    <profile id="9ab8-fd31-6ce0-cee2" name="[R] - Visión profética (Cielos)" hidden="false" typeId="aa67-99ab-2618-c451" typeName="Hechizo">
                      <characteristics>
                        <characteristic name="Tipo" typeId="3b39-64e9-beb6-7abc">-</characteristic>
                        <characteristic name="Dificultad" typeId="e3cf-4d57-0b28-a094">-</characteristic>
                        <characteristic name="Rango" typeId="544c-fa75-b146-79c4">-</characteristic>
                        <characteristic name="Duración" typeId="bd4f-3a08-5f1c-a7c7">-</characteristic>
                        <characteristic name="Efecto" typeId="43ea-afef-1216-a118">Un hechicero que conozca uno o más hechizos del Saber de los Cielos puede repetir una tirada de dado una vez por batalla. Ha de ser una tirada concerniente al propio hechicero: una tirada para impactar, herir, salvaciones, chequeo de atributo, dado de Energía o Dispersión o una tirada en la tabla de Disfunciones mágicas. Además, el hechicero obtiene la regla especial Esquivar (6+).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="points" value="10.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="434e-b6ca-4adf-73c9" name="Casas de Mariemburgo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6cbd-4e34-4617-4bc2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="524a-5717-358e-2e5b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3e3d-d6f3-6f3c-0c8e" name="Casa Rtohemuur" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="aa14-02d4-ecce-66e8" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="e43b-8f4a-80f7-91d3" type="max"/>
          </constraints>
          <profiles>
            <profile id="1b3a-0d40-015b-de44" name="Casa Rtohemuur" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir Guardia de elfos de Rtohemuur como Unidad Singular. Si incluyes a los Guardias elfos de Rtohemuur, puedes incluir unidades de Maniquíes como Unidad Especial. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3f32-4afe-f6c4-da46" name="Casa Van de Kuypers" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9bc8-f13e-5102-0b30" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5859-cb74-7b49-654a" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a76-9974-94ca-26c3" name="Casa Van de Kuypers" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir la Milicia privada de Van Kuypers como Unidad Especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="314b-8e0b-59bf-b38c" name="Casa van Onderzoeker" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5ed9-bf36-0fbd-1cb1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="07e3-983b-1c61-ec6f" type="max"/>
          </constraints>
          <profiles>
            <profile id="b850-5299-f642-f3d4" name="Casa van Onderzoeker" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir una unidad de Caballeros exiliados como Unidad Especial. Además, el Tesorero o Pagador que permitió su inclusión obtiene la regla especial Ataque en cuña (sólo si va montado en Caballo de guerra). Adicionalmente, puedes incluir una unidad de Caballería Pesada como opción de Unidad Básica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="3ea7-c646-600e-1bba" name="Ataque en cuña (sólo si va montado en Caballo de guerra)" hidden="false">
              <description>Durante las fases de combate de aquellos turnos de jugador en los que efectuasen con éxito una carga, los jinetes de la segunda fila podrán atacar al enemigo de la manera descrita en la regla especial “luchar con filas adicionales”. Ten en cuenta que no es necesario colocar a las miniaturas en la unidad de ninguna forma específica para obtener esta habilidad.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1190-ee19-0545-2bce" name="Casa de Roelef" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f235-8975-ab15-c739" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="abc1-29bd-f302-0483" type="max"/>
          </constraints>
          <profiles>
            <profile id="4bce-4fcf-39eb-8716" name="Casa de Roelef" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir los Piqueros de Tobaro como Unidad Básica. Además, el alcance de la regla especial ¡Ni un paso atrás! que del Tesorero o Pagador que permitió su inclusión se aumenta hasta las 18’’. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="aef1-0cab-f79c-6227" name="Ni un paso atrás" hidden="false" targetId="f76e-5a01-1c6b-ef76" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(18&quot;)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9a9a-662b-a7bd-5a73" name="Casa van Haagen" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e09b-5fa2-441b-c5bc" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="91b3-6db6-3bfd-c5c0" type="max"/>
          </constraints>
          <profiles>
            <profile id="d4d1-b58b-0def-1097" name="Casa van Haagen" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir unidades de Contrabandistas de Van Haagen como Unidad Especial. Además, el Tesorero o Pagador que permitió su inclusión obtiene la regla especial Repliegue.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="5f1e-e236-4ebf-ee8c" name="Repliegue" hidden="false">
              <description>Obtienen la regla especial Veloz al realizar movimientos de Huida. Si son objetivo de una carga, pueden efectuar la reacción “Disparar y huir” del mismo modo que las unidades de Caballería rápida.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="926a-f248-b85b-d3c6" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Huida)"/>
              </modifiers>
            </infoLink>
            <infoLink id="edf7-8492-acf7-2339" name="Caballería rápida" hidden="false" targetId="0b7e-2a08-2b5a-51d7" type="rule">
              <modifiers>
                <modifier type="append" field="name" value="(Sólo Disparar y huir)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="54a8-611b-8306-97de" name="Casa van Scheldt" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="8ff4-714e-db60-70bc" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d7af-b9ce-6a9b-2a99" type="max"/>
          </constraints>
          <profiles>
            <profile id="8ddc-723c-1353-f199" name="Casa van Scheldt" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir una unidad de Guardianes de Van Sclhedt como Unidad Especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ea91-9f2c-ec71-5858" name="Casa van Raemerswijk" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="54a9-28d2-b0b4-77cb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="22a2-0398-fbae-dc22" type="max"/>
          </constraints>
          <profiles>
            <profile id="ac5c-283b-60f0-c52a" name="Casa van Raemerswijk" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir una única Batería ligera de pólvora como Unidad Singular. Si incluyes un tesorero puedes añadir una batería ligera de pólvora adicional como Unidad Especial (aparte de la singular).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="eaa3-e3b0-f537-df36" name="Casa Fooger" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4b24-fb7e-4fab-4286" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="d9a6-4f20-7db2-2932" type="max"/>
          </constraints>
          <profiles>
            <profile id="c79a-a37f-07c1-0aba" name="Casa Fooger" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir la Milicia enana como Unidad Singular. Además, el Tesorero o Pagador que permitió su inclusión podrá sustituir su Armadura pesada o Armadura ligera por Armadura de gromril (+5 puntos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b461-97c2-6478-3f2c" name="Casa van den Nijmenk" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="c86c-ec23-01e2-bdfd" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="c68b-2110-16e7-3d2c" type="max"/>
          </constraints>
          <profiles>
            <profile id="1747-7836-7163-d79f" name="Casa van den Nijmenk" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir la milicia privada de Van Den Nijmenk como Unidad Básica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9425-cf15-6bbd-5cdc" name="Casa den Euwe" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="72e9-fcee-a008-9b96" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="3cd4-0166-127b-eb87" type="max"/>
          </constraints>
          <profiles>
            <profile id="bab8-a724-b1e7-348d" name="Casa den Euwe" hidden="false" typeId="4c2e-af32-6247-c264" typeName="Casa de Mariemburgo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a25c-0ed4-3f72-955b">Puedes incluir una Milicia privada Samurai como Unidad Singular. El Tesorero o Pagador que permitió su inclusión puede equiparse con Katana (+2 puntos) y obtiene las reglas especiales Honor ancestral y Samurai exiliado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="8d41-7c93-9c9c-ddde" name="Honor ancestral" hidden="false">
              <description>Las miniaturas con esta regla tendrán las reglas especiales Inmune a Miedo y Sangre fría. Un personaje con esta regla especial no puede unirse a unidades que no la tengan.</description>
            </rule>
            <rule id="ad35-3cac-1d2d-7c2e" name="Samurái exiliado" hidden="false">
              <description>Las miniaturas con esta regla especial no podrán equiparse con Escudo. Los personajes y oficiales con esta regla
especial tienen la regla Orgullo marcial. Además, las miniaturas con esta regla especial obtienen siempre un bonificador de +1 a su tirada de salvación por armadura en combate cuerpo a cuerpo y superan automáticamente los chequeos de pánico provocados por unidades amigas sin esta regla especial. </description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a274-4a40-1df8-6ba9" name="Armas mágicas. Mariemburgo. Armas emparejadas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b026-60d8-f5bd-ceb4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4116-ff60-7625-8a50" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d67e-546f-a265-74fb" name="Hijas de la noche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f54d-17f9-4949-da40" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="54d3-2944-5754-32cc" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a83-3ce9-0b8e-2bca" name="Hijas de la noche" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Armas emparejadas. El portador obtiene +3 Iniciativa en combate cuerpo a cuerpo. Los ataques efectuados con estas dagas obtienen las reglas especiales Poder de penetración y ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d044-ddfb-97fe-2d75" name="Poder de penetración" hidden="false" targetId="29d3-6624-40c6-885f" type="rule"/>
            <infoLink id="2331-87fc-6929-94cf" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
            <infoLink id="c53d-d6ea-26b0-25d5" name="Arma de mano adicional" hidden="false" targetId="45d0-c304-d4fd-5b8f" type="profile"/>
            <infoLink id="c674-a276-65b5-2432" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0987-6548-d73d-129d" name="Armaduras mágicas. Reliquias. Mariemburgo. Armadura ligera" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="53d9-94e9-bf90-70c2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="691b-22c0-53c4-b17f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b2e4-1630-5966-e1ab" name="Escamas de sirena" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2a72-b3ff-c5b4-5c8f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8e53-fe0a-5a1d-18a2" type="max"/>
          </constraints>
          <profiles>
            <profile id="0882-72d2-7eb5-a4cc" name="Escamas de sirena" hidden="false" typeId="219b-aed3-c65c-d46d" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e0ed-7366-4856-8f3d">Armadura ligera. Otorga al portador las reglas especiales Piel escamosa (5+) y Esquivar (4+). Adicionalmente, los enemigos en contacto con el portador verán reducido en 1 su atributo de Ataques (hasta un mínimo de 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="63ef-3d22-9add-5863" name="Esquivar (4+)" hidden="false" targetId="89b2-357c-6f88-920c" type="rule"/>
            <infoLink id="6523-a5f4-acc4-8d71" name="Armadura pesada" hidden="false" targetId="1ee5-2441-2c69-5965" type="profile"/>
            <infoLink id="3eb4-33f0-c528-0733" name="Piel escamosa (5+)" hidden="false" targetId="b1c5-6add-797c-2d07" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="3c7c-71fe-081c-69d9" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
