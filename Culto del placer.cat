            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="cda9-8b8f-e8cf-1162" type="max"/>
          </constraints>
          <profiles>
            <profile id="3381-d4b1-a6a4-f021" name="Almizcle soporífero" hidden="false" typeId="29a5-f327-998c-299d" typeName="Regalo demoníaco">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9340-4cc0-f29c-206f">Las miniaturas enemigas en contacto con el demonio verán sus atributos de Habilidad de Armas e Iniciativa reducidos en un punto.</characteristic>
