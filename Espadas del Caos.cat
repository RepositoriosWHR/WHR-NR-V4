              <rules>
                <rule id="8beb-9cf6-5c6a-e2bd" name="Marca de Nurgle. Elegidos de Nurgle en záganos de la plaga" hidden="false">
                  <description>Tanto los Elegidos de Nurgle como los Zánganos de plaga portan la Marca de Nurgle, por la que obtienen las reglas especiales Ataques envenenados e Inmune a veneno. Los enemigos tienen un penalizador de -1 para impactarles con proyectiles. Los enemigos en contacto peana con peana tendrán -1 a su Habilidad de armas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="55cd-a44f-a650-f85d" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
                <infoLink id="9cce-a13d-2ac8-a1b8" name="Inmune al veneno" hidden="false" targetId="0338-1cb0-0dc1-2892" type="rule"/>
              </infoLinks>
            </entryLink>
          </entryLinks>
        </selectionEntryGroup>
      </selectionEntryGroups>
