          <profiles>
            <profile id="8028-6352-53de-8f83" name="Grandes cuernos" hidden="false" typeId="c41e-b78a-d6e4-14ca" typeName="Recompensa del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="390b-454b-3cef-f653">El personaje obtiene la regla especial Impactos por carga (1). Si ya causaba Impactos por carga, estos aumentan en +1.</characteristic>
              </characteristics>
