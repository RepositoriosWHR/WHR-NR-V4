              <profiles>
                <profile id="d004-bb63-abdf-4d1e" name="Korona de loz Túmuloz" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Si Gorblum o cualquier unidad amiga a 12” o menos pierden un combate, nunca aplicarán un penalizador mayor de -2 a su chequeo de desmoralización (por ejemplo, si Gorblum pierde un combate por 6 puntos de diferencia, sólo aplicará un penalizador de -2 a su Liderazgo para el chequeo de desmoralización).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
