        <characteristic name="Fuerza" typeId="537472656e67746823232344415441232323">6</characteristic>
        <characteristic name="Reglas especiales" typeId="5370656369616c2052756c657323232344415441232323">Heridas múltiples (2), Arma de mano adicional: Un Cepo de mano se usa siempre junto a una Maza ogra tratando al Cepo de mano como un Arma de mano adicional. Sólo puede hacerse un ataque con el Cepo de mano.</characteristic>
      </characteristics>
    </profile>
    <profile id="f7dc-73c1-9a83-df73" name="Piel de Cuernospétreos" hidden="false" typeId="322d-2622-d325-8e5a" typeName="Objeto">
