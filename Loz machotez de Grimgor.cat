      </constraints>
      <selectionEntries>
        <selectionEntry id="85ae-3bd7-52f1-1494" name="Zetaz de la zuerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="2930-c768-36cb-1adb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="8e4f-c779-533a-16f5" type="max"/>
          </constraints>
          <profiles>
            <profile id="0aee-3137-d3d7-1729" name="Zetaz de la zuerte" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Sólo hechicero. Antes del despliegue, tira 1D6: Con un resultado de 2+, el chamán contará con una Herida más en su perfil de atributos y la regla especial Regeneración (6+), o aumentará en +1 si ya disponía de esa regla especial. Sin embargo, con un resultado de 1 el chamán sufrirá una herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a26f-4f0e-c447-6656" name="Regeneración (6+)" hidden="false" targetId="4aee-7485-a141-cd20" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
