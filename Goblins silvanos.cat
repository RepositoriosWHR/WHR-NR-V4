              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb94-e12a-aef4-ebc0">El portador obtiene una tirada de salvación especial de 3+ contra impactos de F4 ó inferior; de 4+ contra impactos de F5 ó F6, y de 5+ contra impactos de F7 o superior, o sin valor de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
