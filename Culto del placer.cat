    </selectionEntryGroup>
    <selectionEntryGroup id="c16d-4919-0805-d2e0" name="Objetos hechizados. Reliquias. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="237b-ba8f-a260-3016" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="48d8-e6aa-a9f5-1366" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4601-8bbe-b17e-0d50" name="Capa del crepúsculo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="5198-b855-ebff-df58" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9241-a082-b52d-55f5" type="max"/>
          </constraints>
          <profiles>
            <profile id="060a-9665-c4d4-166d" name="Capa del crepúsculo" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">No puede ser utilizada por miniaturas con potencia de unidad 5 o superior. Proporciona a su portador una tirada de salvación especial de 3+ contra proyectiles y hechizos del tipo Proyectil mágico. Todos los enemigos que ataquen en combate cuerpo a cuerpo al portador sufrirán un penalizador de -1 a su HA. Su portador obtiene la regla especial Carga devastadora y gana +1 ataque adicional en el turno en el que realiza una carga exitosa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="70ff-236f-6c50-0c3a" name="Carga devastadora" hidden="false" targetId="dbe6-c910-7f37-aeac" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="f4c8-7b5d-3946-776c" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="25aa-c934-b217-3e5d" name="Objetos hechizados. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0b6-7961-4b77-d3af" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e80-3c60-9e12-e2bd" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c091-3a63-3b02-d387" name="Gema de cristal oscuro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="a37a-7f1a-173f-456c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9e49-b9a5-09a1-3fd1" type="max"/>
          </constraints>
          <profiles>
            <profile id="30c9-9910-a480-3499" name="Gema de cristal oscuro" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. Puedes utilizar la Gema al inicio de cualquier de tus turnos. Elige uno de los hechiceros rivales situados a 24” o menos del usuario. El hechicero objetivo perderá uno de sus hechizos determinado al azar. No podrá utilizar ese hechizo durante el resto de la batalla. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a111-f4c2-2720-765a" name="Gema de las pesadillas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f25a-ff6d-4676-9a80" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="ea26-1375-1b03-9cef" type="max"/>
          </constraints>
          <profiles>
            <profile id="3424-7bcf-9ba4-914b" name="Gema de las pesadillas" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">El portador y la unidad donde se encuentre causará Miedo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a785-34f0-193a-d3b7" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1e9f-7736-3bad-3b2c" name="Portal a la Dimensión oscura" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="65e0-57a7-73a4-a318" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="559f-2dd9-abe5-4baf" type="max"/>
          </constraints>
          <profiles>
            <profile id="a930-dc07-b1a5-5ff2" name="Portal a la Dimensión oscura" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. El portador podrá activar el poder del objeto en cualquier momento del juego. El portador y todas las miniaturas enemigas en contacto peana con peana con éste deberán realizar un chequeo de Fuerza. Cualquier miniatura que no supere dicho chequeo sufrirá inmediatamente 1D6 heridas sin tirada de salvación por armadura; en el caso de ser activado durante una ronda de combate, las heridas causadas contarán para la resolución del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="74f6-1592-db5e-de3c" name="Cadenas de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d604-d8a8-3f32-077c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="6fa2-2f37-9bb8-ad87" type="max"/>
          </constraints>
          <profiles>
            <profile id="a31b-f681-fb0e-3bff" name="Cadenas de Slaanesh" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">En combate cuerpo a cuerpo, el portador realiza 1D6 ataques adicionales que se resuelven con Iniciativa 10, utilizando los valores de Habilidad de Armas y Fuerza del portador (no se beneficiarán del efecto de ningún arma mundana o mágica del portador, aunque sí de las Recompensas del Caos que pudiera tener).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="95cf-5dcf-6c32-1d3d" name="Cristal de medianoche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9581-f6da-301d-43bb" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1a7e-1e2c-a9fa-398c" type="max"/>
          </constraints>
          <profiles>
            <profile id="10e7-f7ed-4ac5-8be2" name="Cristal de medianoche" hidden="false" typeId="5d17-3511-0c13-e904" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="0ef8-5055-c22e-455a">Un solo uso. El portador podrá activar el poder del objeto al inicio de cualquier fase de magia (propia o del oponente). Uno de los hechiceros enemigos situados a 12” o menos del portador verá reducido en 1 su nivel de magia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3af8-7489-f48c-4c82" name="Estandartes mágicos. Reliquias. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d333-7c63-3421-2bd0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="74ba-5ee6-a006-45b5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dc75-74cd-427f-a56f" name="Estandarte de su oscura majestad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="351a-eafb-5291-016c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2809-f2fa-035c-ce94" type="max"/>
          </constraints>
          <profiles>
            <profile id="84f0-4339-f8bb-759d" name="Estandarte de su oscura majestad" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador de este estandarte y la unidad que lo acompañe obtienen la regla especial Indesmoralizable. Además, todos los ataques y disparos dirigidos contra todas las unidades amigas a 12” con la marca de Slaanesh y/o la regla especial Demonio (Slaanesh) obtienen un penalizador de -1 en sus tiradas para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="18e2-dd22-805f-15ad" name="Indesmoralizable" hidden="false" targetId="4362-3d7f-a24a-3309" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="25ab-bba6-3741-1401" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c5f7-154c-745d-68ab" name="Estandartes mágicos. Culto del placer. Caballeros gélidos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1b2a-c395-673e-690f" type="min"/>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cdfd-cead-1c04-6e82" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e788-da8f-38f9-7a54" name="Pabellón del gélido" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="1111-2935-1af9-f9f9" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="dd20-20fe-49d6-b5db" type="max"/>
          </constraints>
          <profiles>
            <profile id="7de3-61d0-022e-3f7a" name="Pabellón del gélido" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Sólo Caballeros Gélidos. Los Gélidos de la unidad superarán automáticamente sus chequeos de Estupidez y obtendrán un bonificador de +1 a sus tiradas para impactar en combate cuerpo a cuerpo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fe3d-f9f5-4d16-731e" name="Estandartes mágicos. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5c0b-342f-a33f-b185" type="min"/>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="05c7-d0fd-b3f2-abf4" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c23d-ee6b-284b-e44f" name="Estandarte de la masacre" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="98e5-69a8-74fd-ba9b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="fa67-b4f4-58ee-1c8c" type="max"/>
          </constraints>
          <profiles>
            <profile id="ddb4-58b1-20ff-b245" name="Estandarte de la masacre" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">En cualquier turno en el que la unidad en que se encuentra este estandarte realizase con éxito una carga obtendrá un bonificador de +1D3 al resultado del combate. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b71a-c488-8115-d631" name="Macabro estandarte bendito" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="56f9-d57c-124c-cc01" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="abcf-cff6-b6b7-e45c" type="max"/>
          </constraints>
          <profiles>
            <profile id="9497-bad5-7b61-be3a" name="Macabro estandarte bendito" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad obtienen la regla especial Aura demoníaca (5+) o aumenta en +1 si ya la tenían (hasta un máximo de 3+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="40b3-1566-bf17-5b22" name="Aura demoníaca (5+)" hidden="false" targetId="e5ed-5149-3d72-6aa4" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b26b-0962-c5b6-365f" name="Estandarte siniestro" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="fef6-bb26-6621-8c21" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4b96-7a02-fc00-f580" type="max"/>
          </constraints>
          <profiles>
            <profile id="b5cb-4c45-cb0f-bc4d" name="Estandarte siniestro" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador y su unidad causarán Miedo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8d8f-1cd1-3d81-8e5d" name="Miedo" hidden="false" targetId="e1b7-26dc-52c2-c3a7" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7aae-0870-7b89-ab8e" name="Estandarte del éxtasis" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f54c-f212-3c4d-b8f7" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="7c99-8545-e9e8-fdfe" type="max"/>
          </constraints>
          <profiles>
            <profile id="f8bb-2f2c-1fd4-aa7f" name="Estandarte del éxtasis" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">Si el portador y su unidad obtienen un resultado de dobles al efectuar un chequeo de desmoralización, se considerará que ha obtenido un resultado de doble uno. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f5a2-c6cc-9e3f-9757" name="Estandarte vertiginoso" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="d69a-af97-4aff-b952" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="adcd-2b3b-1afa-b961" type="max"/>
          </constraints>
          <profiles>
            <profile id="2228-6bd2-723d-1901" name="Estandarte vertiginoso" page="0" hidden="false" typeId="5441-5d99-9a3f-dce8" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="eb3c-0420-d3ad-ee60">El portador de este estandarte y la unidad que lo acompañe obtienen la regla especial Veloz. Además, obtienen un bonificador de +1 a su atributo de Movimiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5122-4421-ef38-3e72" name="Veloz" hidden="false" targetId="6d32-e54e-896e-0d9f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ad9d-8777-1e48-6f74" name="Artefactos arcanos. Reliquias. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b18f-bc79-b4c4-2bcc" type="min"/>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e87-c4f5-f689-0958" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="248f-8093-b032-4358" name="Vara de Kharaidon" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="206c-beb6-aa42-b4f5" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="5799-3ea2-8379-4a2f" type="max"/>
          </constraints>
          <profiles>
            <profile id="5ef5-d3a9-9e6d-3d21" name="Vara de Kharaidon" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Una vez en cada una de tus fases de magia, el portador puede realizar un chequeo de Resistencia: si lo supera, podrá lanzar uno de sus hechizos sin invertir dados de energía (el hechizo será lanzado a su dificultad básica; no puedes lanzar un hechizo potenciado con la Vara). Sin embargo, si falla el chequeo, perderá la concentración y sufrirá una herida sin tirada de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink id="78b4-06c9-65a9-b1aa" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="60.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0360-ae20-f848-a302" name="Artefactos arcanos. Culto del placer" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8c6e-35bf-c3f4-f233" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a8e-2147-7340-7124" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ca98-738d-4846-0ffb" name="Báculo negro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="690b-dd86-a5f1-7a1f" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1f4f-c077-17aa-3f77" type="max"/>
          </constraints>
          <profiles>
            <profile id="e804-2825-a71c-0001" name="Báculo negro" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El portador podrá utilizar cualquier número de dados de energía para lanzar sus hechizos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ece3-f5ae-c61d-2d13" name="Daga del sacrificio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="00b6-27d9-8f0c-ade4" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a8b1-43c4-0abb-bf72" type="max"/>
          </constraints>
          <profiles>
            <profile id="322c-2a98-354d-c737" name="Daga del sacrificio" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El portador puede utilizarla tras haber realizado la tirada de lanzamiento de cualquier hechizo. Podrá sacrificar a una de las miniaturas de su unidad para tirar un Dado de energía adicional en ese hechizo. La miniatura sacrificada deberá retirarse inmediatamente como baja de forma irremediable. Esto deberá realizarse antes de que tenga lugar cualquier posible intento de dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fdb9-a3aa-715e-e200" name="Familiar del Caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="58f4-6b01-e35f-0862" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="4a21-eaf4-6f13-9848" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a4f-616e-7a8e-b468" name="Familiar del Caos" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">El personaje genera un dado adicional de Energía o Dispersión en cada fase de magia. Aunque puedes representarlo con una pequeña miniatura de familiar, no puede ser atacado, y deberá retirarse si su dueño se retira como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d8a9-259e-3fbf-29ed" name="Cetro de la dominación de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="7ec6-4258-c76e-826a" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="a4f2-494a-eb8c-38d2" type="max"/>
          </constraints>
          <profiles>
            <profile id="5384-2f68-653a-bced" name="Cetro de la dominación de Slaanesh" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Objeto portahechizos, Nivel de energía 6. Puede utilizarse en cada fase de magia propia contra una unidad enemiga no trabada en combate a 18” o menos del portador. Esta unidad deberá realizar un chequeo de Liderazgo tirando 3D6 y descartando el resultado menor. Si lo falla, no podrá cargar, marchar ni disparar durante su siguiente turno. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="914d-c426-2064-3cbf" name="Gema del rencor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="f8fb-ef03-fcc1-2915" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="1ebd-7f76-30ac-d90c" type="max"/>
          </constraints>
          <profiles>
            <profile id="c5e9-12c8-35c8-4f57" name="Gema del rencor" hidden="false" typeId="e4ac-4b4d-a272-410e" typeName="Artefacto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2cab-b0ef-2a60-b01b">Siempre que el portador sufra una disfunción, los hechiceros enemigos a 12” o menos sufren impacto de F6. Los hechiceros enemigos pueden descartar un dado de dispersión para anular las Heridas provocadas por la Gema.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="30f1-aa06-99e9-888c" name="Armas mágicas. Reliquias. Culto del placer. Arma de mano" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d17-ecf6-3598-2321" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="99f7-4f36-78cd-37a6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7509-767c-a4e1-2a5d" name="Filo venenoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="e328-d7bc-8e65-e9b8" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="21e8-9a3a-ce80-6ff5" type="max"/>
          </constraints>
          <profiles>
            <profile id="981e-7d35-c08b-719e" name="Filo venenoso" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los ataques efectuados con esta espada se beneficiarán de las reglas especiales Ataques envenenados y Heridas múltiples 1D3. No podrán efectuarse tiradas de salvación por armadura contra los ataques realizados con Filo Venenoso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4738-97db-a460-d429" name="Ataques envenenados" hidden="false" targetId="9867-a512-772e-f61c" type="rule"/>
            <infoLink id="ac6b-0434-a1c3-557f" name="Heridas múltiples (1D3)" hidden="false" targetId="efc4-703c-5d20-0686" type="rule"/>
            <infoLink id="1773-eac3-2514-114c" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="3935-d75a-5c24-d1c0" name="Reliquia" hidden="false" collective="false" import="true" targetId="a485-24d0-42b1-23c7" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="pts" typeId="points" value="80.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ee86-43bf-4c25-e5b2" name="Alfiler del éxtasis" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="4702-272d-5d29-725e" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="91ed-170d-0163-5880" type="max"/>
          </constraints>
          <profiles>
            <profile id="a5eb-8a2f-ee85-bd81" name="Alfiler del éxtasis" hidden="false" typeId="ce18-64ea-b98c-dc9d" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="28f4-dde2-505a-99d6">Arma de mano. Los impactos con este arma no permiten tiradas de salvación por armadura. Si causa una herida a una unidad enemiga, la unidad quedará Apabullada ese turno y tendrá un penalizador de -1 en sus tiradas para impactar durante esa fase de combate cuerpo a cuerpo. </characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bd54-fc57-b19a-048f" name="Arma de mano" hidden="false" targetId="891d-c74a-2555-793e" type="profile"/>
