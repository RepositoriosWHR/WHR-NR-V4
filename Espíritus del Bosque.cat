          <profiles>
            <profile id="56c7-73d3-ebab-ce6d" name="Enjambre de duendes" hidden="false" typeId="31db-7b3b-839f-a176" typeName="Rasgos, Duendes y Hadas">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="bb6f-2db2-c116-79a5">Se trata de un ataque de proyectiles con alcance 12” que impacta siempre a 3+ y se resuelve con Fuerza 2 y las reglas especiales Disparos múltiples (1D6) y Ataques envenenados. Además, si la miniatura está trabada en combate, podrás efectuar 1D6 ataques adicionales que se resuelven con HA2, F2, I8 y la regla especial Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
