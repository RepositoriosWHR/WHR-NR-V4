          </constraints>
          <profiles>
            <profile id="ac75-de4a-093a-c1e6" name="Desove sagrado de Xokha" hidden="false" typeId="b4fe-0f5d-c558-9ec9" typeName="Desove">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="776f-590a-f508-e275">Cuando una miniatura perteneciente a este desove sea retirada como baja durante una fase de combate cuerpo a cuerpo, podrá realizar inmediatamente un único ataque contra la unidad que acabó con ella. Estos ataques se realizan inmediatamente y las bajas que causen cuentan para la resolución de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0.0"/>
